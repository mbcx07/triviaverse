rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // PROTOTYPE RULES
    // This app uses a simple nickname+PIN login WITHOUT Firebase Auth.
    // Because Firestore rules cannot validate a PIN sent from the client, this is intentionally open.
    // For production: add Firebase Auth and restrict reads/writes by request.auth.

    match /{document=**} {
      allow read, write: if true;
    }
  }
}
