    qTF('Fibonacci descubrió su sucesión estudiando la reproducción de conejos (1202).', true, 'Leonardo de Pisa (Fibonacci) modeló el crecimiento de conejos y descubrió esta fascinante secuencia.'),
    qOrder('Ordena estos tipos de sucesiones de más simples a más complejas:', ['Aritmética (+ constante)','Geométrica (× constante)','Triangulares (n(n+1)/2)','Fibonacci (suma previos)','Primos (sin fórmula)'], 'De reglas simples determinísticas a patrones profundamente misteriosos.'),
    qMatch('Relaciona cada sucesión con su nombre:', [{left:'2, 4, 6, 8, 10...',right:'Pares (d=2)'},{left:'1, 4, 9, 16, 25...',right:'Cuadrados perfectos'},{left:'1, 3, 6, 10, 15...',right:'Triangulares'},{left:'1, 1, 2, 3, 5, 8...',right:'Fibonacci'}], 'Cada sucesión tiene su propio encanto y aplicación en la naturaleza.'),
