    qMC('Convertir 4,500 mL a litros:', ['4.5 L (4,500÷1,000)','45 L','0.45 L','450 L'], 0, 'mL→L: ÷1,000. 4,500÷1,000=4.5 L.'),
    qMC('2.5 horas a minutos:', ['150 min (2.5×60)','250 min','125 min','25 min'], 0, 'Horas→minutos: ×60. 2.5×60=150 min.'),
    qMC('¿Cuántos kilómetros son 50,000 metros?', ['50 km','5 km','500 km','0.5 km'], 0, 'm→km: ÷1,000. 50,000÷1,000=50 km. Es la distancia de un maratón (42.195 km más un extra).'),
    qTF('Para convertir metros a centímetros se multiplica por 100.', true, 'm→cm: hay 2 escalones (m→dm→cm), cada uno ×10. Total: ×100.'),
    qOrder('Ordena los pasos para convertir 2.3 kg a miligramos:', ['kg→g: 2.3×1,000=2,300 g','g→mg: 2,300×1,000=2,300,000 mg','Resultado: 2,300,000 mg'], 'Conversión múltiple: puedes hacerlo en pasos o de un salto (×1,000,000).'),
    qMatch('Relaciona cada conversión con su factor:', [{left:'km → m',right:'×1,000'},{left:'m → cm',right:'×100'},{left:'kg → g',right:'×1,000'},{left:'L → mL',right:'×1,000'}], 'Todas las conversiones del sistema métrico usan potencias de 10.'),
    qMC('Una alberca tiene 25,000 litros de agua. ¿Cuántos metros cúbicos son?', ['25 m³ (1 m³=1,000 L)','2.5 m³','250 m³','2,500 m³'], 0, '25,000÷1,000=25 m³. 1 metro cúbico = 1,000 litros exactamente.'),
    qWrite('Convierte 72 horas a días.', ['3'], '72÷24=3 días.'),
    qWrite('Convierte 72 horas a días.', ['3'], '72÷24=3 días.'),
  ],

  // ===== M25: Problemas con unidades de medida =====
  [
    qMC('Juan corre 5 km diarios. ¿Cuántos metros corre en una semana?', ['35,000 metros','5,000 metros','30,000 metros','7,000 metros'], 0, '5×7=35 km. 35×1,000=35,000 m. Problemas con unidades múltiples.'),
    qMC('Un tinaco tiene 1,200 L. Se gastan 350 L y se añaden 500 L. ¿Cuánto queda?', ['1,350 litros','1,050 litros','850 litros','1,700 litros'], 0, '1,200-350+500=1,350 L. Operaciones con capacidades.'),
    qMC('La Torre Latinoamericana mide 182 metros. ¿Cuántos cm son?', ['18,200 cm','1,820 cm','182,000 cm','18.2 cm'], 0, '182×100=18,200 cm. Edificio emblemático de CDMX.'),
    qMC('Un vuelo de CDMX a Cancún dura 2 h 15 min. En minutos:', ['135 minutos','125 minutos','215 minutos','150 minutos'], 0, '2×60=120. 120+15=135 min.'),
    qMC('Tres costales de harina pesan: 25.5 kg, 18.75 kg y 32.25 kg. ¿Peso total?', ['76.5 kg','76.5','75 kg','77 kg'], 0, '25.5+18.75+32.25=76.5 kg. Suma de masas con decimales.'),
    qMC('Un ciclista recorre 42.5 km en 2.5 horas. Velocidad promedio:', ['17 km/h','20 km/h','15 km/h','10.6 km/h'], 0, '42.5÷2.5=17 km/h. Velocidad = distancia ÷ tiempo.'),
    qTF('El kilómetro es la unidad más adecuada para medir el largo de un lápiz.', false, 'Para un lápiz (~15 cm) usamos centímetros, no kilómetros. Elegir la unidad apropiada es clave.'),
    qOrder('Ordena estos objetos por su masa estimada de menor a mayor:', ['Clip (1 g)','Manzana (150 g)','Libro (500 g)','Gato adulto (4 kg)','Refrigerador (80 kg)'], 'Estimar masas con unidades apropiadas: intuición y comparación.'),
    qMatch('Relaciona cada objeto con la unidad más adecuada:', [{left:'Distancia entre ciudades',right:'Kilómetros (km)'},{left:'Largo de una mesa',right:'Metros (m)'},{left:'Diámetro de una moneda',right:'Milímetros (mm)'},{left:'Peso de una persona',right:'Kilogramos (kg)'}], 'Seleccionar la unidad correcta evita números incómodos (grandes o muy pequeños).'),
    qMC('Un camión cisterna transporta 25,000 L de agua. ¿Cuántos tanques de 500 L se llenan?', ['50 tanques','100 tanques','25 tanques','500 tanques'], 0, '25,000÷500=50 tanques. División de capacidad.'),
    qWrite('Un tinaco de 850 L se llena con cubetas de 25 L. ¿Cuántas cubetas?', ['34'], '850÷25=34 cubetas.'),
    qWrite('Un tinaco de 850 L se llena con cubetas de 25 L. ¿Cuántas?', ['34'], '850÷25=34 cubetas.'),
  ],

  // ===== M26: Perímetro de figuras planas =====
  [
    qMC('El perímetro de una figura es:', ['La suma de las longitudes de todos sus lados (el CONTORNO)','El área interior','El volumen','La altura'], 0, 'Perímetro = contorno. Si caminas alrededor de un parque rectangular, la distancia recorrida es su perímetro.'),
    qMC('El perímetro de un cuadrado de lado 8 cm es:', ['32 cm','64 cm','16 cm','8 cm'], 0, 'Cuadrado: 4 lados iguales. P=4×8=32 cm.'),
    qMC('Para un rectángulo de 12 m de largo y 5 m de ancho, su perímetro es:', ['34 m (2×12 + 2×5 = 24+10)','60 m','17 m','22 m'], 0, 'Rectángulo: P=2×largo + 2×ancho = 2(largo+ancho).'),
    qMC('El perímetro de un triángulo equilátero de lado 15 cm es:', ['45 cm','30 cm','15 cm','60 cm'], 0, 'Triángulo equilátero: 3 lados iguales. P=3×15=45 cm.'),
    qMC('Un pentágono regular tiene lados de 7 m. Su perímetro:', ['35 m','28 m','49 m','14 m'], 0, 'Polígono regular: todos los lados iguales. P=número de lados × longitud del lado. P=5×7=35 m.'),
    qMC('Para calcular el perímetro de un círculo (circunferencia):', ['C=2×π×r (donde π≈3.1416 y r=radio)','C=π×d²','C=r×r×π','No tiene perímetro'], 0, 'Circunferencia = π×diámetro = 2πr. Si r=5 cm, C≈31.416 cm.'),
    qTF('El perímetro de un rectángulo de 10 m × 6 m es 32 m.', true, 'P=2(10+6)=2(16)=32 m. Correcto.'),
    qOrder('Ordena los pasos para calcular el perímetro de un hexágono regular de lado 9 dm:', ['Identificar: hexágono = 6 lados iguales','Multiplicar: 6×9=54 dm','Resultado: 54 dm'], 'Fórmula general para polígono regular: P=n×L donde n=número de lados.'),
    qMatch('Relaciona cada figura con la fórmula de su perímetro:', [{left:'Cuadrado de lado L',right:'P=4×L'},{left:'Rectángulo de lados a,b',right:'P=2a+2b'},{left:'Triángulo equilátero lado L',right:'P=3×L'},{left:'Círculo de radio r',right:'C=2πr'}], 'Conocer las fórmulas permite calcular cercas, marcos y bordes en la vida real.'),
    qMC('Se quiere cercar un jardín rectangular de 25 m × 18 m. ¿Cuántos metros de cerca se necesitan?', ['86 metros','43 metros','450 metros','68 metros'], 0, 'P=2(25+18)=2(43)=86 m de cerca. Problema práctico de construcción.'),
    qWrite('¿Perímetro de un pentágono regular de lado 12 cm?', ['60','60 cm'], '5×12=60 cm.'),
    qWrite('¿Perímetro de un pentágono regular de lado 12 cm?', ['60','60 cm'], '5×12=60 cm.'),
  ],

  // ===== M27: Área de cuadrados y rectángulos =====
  [
    qMC('El área de una figura es:', ['La medida de su SUPERFICIE (lo que ocupa en el plano)','Su perímetro','Su volumen','Su altura'], 0, 'Área = superficie interior. Se mide en unidades cuadradas: m², cm², km².'),
    qMC('El área de un cuadrado de lado 7 cm es:', ['49 cm²','28 cm²','14 cm²','7 cm²'], 0, 'Cuadrado: A=lado×lado = lado². 7×7=49 cm².'),
    qMC('Para el área de un rectángulo de 15 m × 4 m:', ['60 m² (base × altura)','19 m²','60 m','30 m²'], 0, 'Rectángulo: A=base×altura. 15×4=60 m². Siempre en unidades cuadradas.'),
    qMC('¿Cuántos metros cuadrados tiene una habitación de 6 m × 4 m?', ['24 m²','20 m²','10 m²','24 m'], 0, 'Superficie de piso: 6×4=24 m². Importante para comprar piso, alfombra o pintura.'),
    qMC('Un terreno rectangular mide 20 m × 35 m. Su área es:', ['700 m²','110 m²','55 m²','700 m'], 0, '20×35=700 m². Áreas grandes se usan para terrenos y construcciones.'),
    qMC('Para convertir 1 m² a cm²:', ['1 m² = 10,000 cm² (100×100)','1 m² = 100 cm²','1 m² = 1,000 cm²','No se puede'], 0, '1 m=100 cm. 1 m² = (100 cm)² = 10,000 cm². La conversión de áreas usa factor 100 por dimensión.'),
    qTF('El área se expresa SIEMPRE en unidades cuadradas (m², cm², km²).', true, 'Siempre al cuadrado. Si olvidas el ², la respuesta es incorrecta dimensionalmente.'),
    qOrder('Ordena estos pasos para calcular cuántas losetas de 50 cm×50 cm se necesitan para una habitación de 4 m × 3 m:', ['Calcular área de habitación: 4×3=12 m²','Convertir a cm²: 12×10,000=120,000 cm²','Calcular área de cada loseta: 50×50=2,500 cm²','Dividir: 120,000÷2,500=48 losetas'], 'Problema real: cálculo de materiales para construcción o remodelación.'),
    qMatch('Relaciona cada figura con su fórmula de área:', [{left:'Cuadrado (lado L)',right:'A=L²'},{left:'Rectángulo (base b, altura h)',right:'A=b×h'},{left:'Romboide (base b, altura h)',right:'A=b×h'},{left:'Triángulo (base b, altura h)',right:'A=(b×h)÷2'}], 'Las fórmulas del área varían según la figura. Memorizarlas es esencial.'),
    qMC('Un campo de fútbol mide aproximadamente 100 m × 70 m. Su área es:', ['7,000 m² = 0.7 hectáreas','170 m²','7,000 m','700 m²'], 0, '100×70=7,000 m². 1 hectárea = 10,000 m², así que 7,000 m² = 0.7 ha.'),
    qWrite('¿Área de un rectángulo de 20 m × 5 m?', ['100','100 m²'], '20×5=100 m².'),
    qWrite('¿Área de un rectángulo de 20 m × 5 m?', ['100','100 m²'], '20×5=100 m².'),
  ],

  // ===== M28: Área de triángulos =====
  [
    qMC('El área de un triángulo es:', ['(base × altura) ÷ 2','base × altura','base + altura','base × 2'], 0, 'Un triángulo es exactamente la MITAD de un rectángulo con la misma base y altura.'),
    qMC('Triángulo con base 10 cm y altura 6 cm, su área es:', ['30 cm²','60 cm²','16 cm²','36 cm²'], 0, 'A=(10×6)÷2=60÷2=30 cm².'),
    qMC('La altura de un triángulo es:', ['La distancia PERPENDICULAR desde la base hasta el vértice opuesto','Cualquier lado','El lado más largo','El perímetro'], 0, 'Altura = segmento perpendicular a la base que llega al vértice opuesto. Esencial para el área.'),
    qMC('Un triángulo rectángulo tiene catetos de 8 cm y 6 cm. Su área:', ['24 cm² (8×6÷2)','48 cm²','14 cm²','28 cm²'], 0, 'En triángulo rectángulo, los catetos son base y altura entre sí. A=(8×6)/2=24 cm².'),
    qMC('Triángulo de base 25 m y altura 12 m. Área:', ['150 m²','300 m²','37 m²','150 m'], 0, 'A=(25×12)÷2=300÷2=150 m².'),
    qMC('El área del triángulo se relaciona con el paralelogramo:', ['2 triángulos iguales forman un paralelogramo de área base×altura','No tienen relación','El triángulo es más grande','Es lo mismo'], 0, 'Al duplicar un triángulo obtienes un paralelogramo. Por eso A(triángulo) = b×h/2.'),
    qTF('El área de un triángulo de 14 cm de base y 5 cm de altura es 35 cm².', true, '(14×5)÷2=70÷2=35 cm². Correcto.'),
    qOrder('Ordena los pasos para hallar el área de un triángulo:', ['Identificar la base (b)','Identificar la altura (h), perpendicular a la base','Multiplicar b×h','Dividir el producto entre 2'], 'Procedimiento universal para cualquier tipo de triángulo.'),
    qMatch('Relaciona cada triángulo con su área:', [{left:'Base=8, altura=5',right:'20 u²'},{left:'Base=12, altura=9',right:'54 u²'},{left:'Base=20, altura=3',right:'30 u²'},{left:'Base=16, altura=10',right:'80 u²'}], 'Practica con diferentes combinaciones de base y altura.'),
    qMC('La vela de un barco es triangular, base 4 m, altura 6 m. Área:', ['12 m²','24 m²','10 m²','48 m²'], 0, '(4×6)÷2=24÷2=12 m² de tela para la vela.'),
    qWrite('¿Área de un triángulo de base 30 cm y altura 12 cm?', ['180','180 cm²'], '(30×12)÷2=180 cm².'),
    qWrite('¿Área de un triángulo de base 30 cm y altura 12 cm?', ['180','180 cm²'], '(30×12)÷2=180 cm².'),
  ],

  // ===== M29: Área de figuras compuestas =====
  [
    qMC('Para hallar el área de una figura compuesta:', ['Se DESCOMPONE en figuras simples (rectángulos, triángulos) y se suman sus áreas','Se ignora','Solo perímetro','Se calcula igual que un rectángulo'], 0, 'Divide en formas conocidas, calcula el área de cada parte, suma los resultados.'),
    qMC('Una figura en forma de "L" se puede dividir en:', ['2 rectángulos (calculas cada área y las sumas)','1 triángulo grande','No se puede','Solo 1 cuadrado'], 0, 'La figura en L = rectángulo vertical + rectángulo horizontal. Calcula cada uno por separado.'),
    qMC('Una casa dibujada = rectángulo (paredes) + triángulo (techo). Área total:', ['Área rectángulo + Área triángulo = área combinada','Solo rectángulo','Solo triángulo','Perímetro'], 0, 'Figuras compuestas comunes: casa (rectángulo + triángulo), bandera (varias franjas), terrenos irregulares.'),
    qMC('Un terreno "T" se divide en 2 rectángulos: 10×4 m y 6×8 m. Área total:', ['40+48=88 m²','40 m²','88 m','14 m²'], 0, 'Suma las áreas de las partes componentes, siempre en unidades cuadradas.'),
    qMC('Para calcular el área de una figura con "hueco":', ['Área total exterior - Área del hueco interior','Solo el área exterior','Ignorar el hueco','No se puede'], 0, 'Ej: marco de pintura = área rectángulo exterior - área rectángulo interior.'),
    qMC('Un jardín circular con radio 5 m tiene una fuente cuadrada de 2 m de lado al centro. Área de pasto:', ['π×5² - 2² ≈78.54-4=74.54 m²','78.54 m²','25 m²','21 m²'], 0, 'Área total del círculo - área de la fuente = área con pasto. Problemas de resta de áreas.'),
    qTF('Las figuras compuestas se resuelven dividiéndolas en figuras simples conocidas.', true, 'Estrategia universal: descomponer en rectángulos, triángulos y círculos cuyas fórmulas ya conoces.'),
    qOrder('Ordena los pasos para hallar el área de una bandera de México (3 franjas rectangulares iguales):', ['Identificar: 3 rectángulos iguales','Calcular área de 1 franja: ancho×largo','Multiplicar área por 3 (hay 3 franjas)','Resultado: área total'], 'Muchas figuras compuestas están formadas por repeticiones de la misma forma básica.'),
    qMatch('Relaciona la figura compuesta con su descomposición:', [{left:'Casa',right:'Rectángulo + Triángulo'},{left:'Cruz',right:'5 Cuadrados iguales'},{left:'Marco',right:'Rectángulo grande - Rectángulo chico'},{left:'Trapecista',right:'2 Triángulos + 1 Rectángulo'}], 'La clave es visualizar las partes simples que forman la figura.'),
    qMC('Un logo es un cuadrado de 12 cm con un círculo inscrito de radio 6 cm. Área fuera del círculo:', ['144 - 113.1 ≈ 30.9 cm²','12 cm²','144 cm²','0 cm²'], 0, 'Área cuadrado=144. Área círculo=π×6²≈113.1. Resta=30.9 cm².'),
    qWrite('En figura compuesta de 3 rectángulos de 10 m² c/u, ¿área total?', ['30','30 m²'], '3×10=30 m².'),
    qWrite('En figura compuesta de 3 rectángulos de 10 m², ¿área total?', ['30','30 m²'], '3×10=30 m².'),
  ],

  // ===== M30: Volumen de prismas rectangulares =====
  [
    qMC('El volumen mide:', ['El ESPACIO que ocupa un cuerpo en tres dimensiones','La superficie','El contorno','El peso'], 0, 'Volumen = largo × ancho × alto. Se expresa en unidades cúbicas: m³, cm³.'),
    qMC('El volumen de un cubo de arista 5 cm:', ['125 cm³ (5³)','25 cm³','15 cm³','50 cm³'], 0, 'Cubo: V=lado³=5³=5×5×5=125 cm³.'),
    qMC('Para un prisma rectangular (caja) de 8×3×4 cm:', ['96 cm³ (8×3×4)','96 cm²','15 cm³','56 cm³'], 0, 'V=largo×ancho×alto=8×3×4=96 cm³.'),
    qMC('¿Cuántos centímetros cúbicos hay en 1 metro cúbico?', ['1,000,000 cm³ (100³)','1,000 cm³','100 cm³','10,000 cm³'], 0, '1m=100cm. 1 m³ = (100 cm)³ = 1,000,000 cm³. Enorme diferencia dimensional.'),
    qMC('Un tinaco cilíndrico de radio 1 m y altura 2 m, su volumen:', ['π×1²×2 ≈ 6.28 m³ = 6,280 litros','3.14 m³','2 m³','1 m³'], 0, 'Cilindro: V=πr²h. 3.14×1×2≈6.28 m³. Cada m³ = 1,000 litros.'),
    qMC('El volumen de una caja de zapatos (30×20×12 cm) es:', ['7,200 cm³','62 cm³','7,200 cm²','720 cm³'], 0, '30×20×12=7,200 cm³. Volúmenes cotidianos en centímetros cúbicos.'),
    qTF('1 litro equivale a 1,000 cm³ (1 dm³).', true, '1 L = 1,000 cm³ = 1 dm³. Esta relación es exacta y muy práctica.'),
    qOrder('Ordena los pasos para calcular el volumen de una alberca rectangular de 10×5×1.5 m:', ['Multiplicar las tres dimensiones: 10×5×1.5=75 m³','Convertir a litros: 75×1,000=75,000 L','Resultado: 75,000 litros de agua'], 'El cálculo de volumen es indispensable para saber capacidad de contenedores.'),
    qMatch('Relaciona cada cuerpo con su fórmula de volumen:', [{left:'Cubo (arista a)',right:'V=a³'},{left:'Prisma (l×a×h)',right:'V=largo×ancho×alto'},{left:'Cilindro (r,h)',right:'V=πr²h'},{left:'Pirámide (Ab,h)',right:'V=Ab×h÷3'}], 'Cada figura tridimensional tiene su propia fórmula pero todas se basan en dimensiones lineales.'),
    qMC('Una pecera de 50×30×40 cm tiene volumen de:', ['60,000 cm³ = 60 litros','6,000 cm³','600 litros','20 litros'], 0, '50×30×40=60,000 cm³=60 litros. Ideal para calcular el agua necesaria.'),
    qWrite('¿Volumen de un prisma de 10×4×3 cm?', ['120','120 cm³'], '10×4×3=120 cm³.'),
    qWrite('¿Volumen de un prisma de 10×4×3 cm?', ['120','120 cm³'], '10×4×3=120 cm³.'),
  ],

  // ===== M31: Figuras geométricas - Clasificación de polígonos =====
  [
    qMC('Un polígono es:', ['Una figura plana cerrada formada por segmentos de recta','Cualquier figura','Solo los cuadrados','Una figura con curvas'], 0, 'Polígono = figura cerrada de lados rectos. Triángulo, cuadrado, pentágono... Número de lados determina su nombre.'),
    qMC('¿Cuántos lados tiene un octágono?', ['8 lados','6 lados','10 lados','7 lados'], 0, 'Oct- = 8. Octágono = 8 lados. Las señales de alto (STOP) son octágonos.'),
    qMC('Un polígono es REGULAR cuando:', ['Todos sus lados y todos sus ángulos son IGUALES','Tiene curvas','Solo lados iguales','No importa'], 0, 'Regular = equilátero (lados iguales) Y equiángulo (ángulos iguales). El cuadrado es regular, el rectángulo no.'),
    qMC('La suma de los ángulos internos de un triángulo es:', ['SIEMPRE 180°','90°','270°','360°'], 0, 'Cualquier triángulo: suma de 3 ángulos internos = 180°. Propiedad fundamental.'),
    qMC('Un decágono tiene:', ['10 lados','12 lados','8 lados','9 lados'], 0, 'Deca- = 10. Decágono regular: cada ángulo interno = 144°.'),
    qMC('Un polígono convexo tiene:', ['Todos sus ángulos internos MENORES de 180°','Algún ángulo >180°','Curvas','Solo 3 lados'], 0, 'Convexo: al unir dos puntos cualesquiera dentro, el segmento queda dentro. Cóncavo: alguno >180°.'),
    qTF('Un rectángulo es un polígono regular.', false, 'Rectángulo tiene ángulos iguales (90°) pero lados no iguales (largo≠ancho). Para ser regular necesita AMBOS.'),
    qOrder('Ordena estos polígonos por número de lados (menor a mayor):', ['Triángulo (3)','Cuadrilátero (4)','Pentágono (5)','Hexágono (6)','Octágono (8)'], 'Prefijos griegos: tri=3, tetra=4, penta=5, hexa=6, hepta=7, octa=8, nona=9, deca=10.'),
    qMatch('Relaciona cada polígono con sus características:', [{left:'Triángulo equilátero',right:'3 lados iguales, 60° cada ángulo'},{left:'Cuadrado',right:'4 lados iguales, 4 ángulos de 90°'},{left:'Pentágono regular',right:'5 lados iguales, 108° cada ángulo'},{left:'Hexágono regular',right:'6 lados iguales, 120° cada ángulo'}], 'Los polígonos regulares tienen propiedades simétricas muy útiles en ingeniería y diseño.'),
    qMC('Un cuadrilátero es un polígono de 4 lados. Ejemplos:', ['Cuadrado, rectángulo, rombo, trapecio','Solo cuadrado','Triángulo','Pentágono'], 0, 'Familia de los cuadriláteros incluye muchas formas con propiedades diferentes.'),
    qWrite('¿Cuántos lados tiene un heptágono?', ['7','siete'], 'Hepta = 7. Heptágono: 7 lados.'),
    qWrite('¿Cuántos lados tiene un heptágono?', ['7','siete'], 'Hepta = 7. Heptágono: 7 lados.'),
  ],

  // ===== M32: Triángulos - Clasificación =====
  [
    qMC('Un triángulo equilátero tiene:', ['3 lados IGUALES y 3 ángulos de 60°','2 lados iguales','Ningún lado igual','1 ángulo recto'], 0, 'Equilátero = la máxima simetría en triángulos. Todos los ángulos = 60°.'),
    qMC('Un triángulo isósceles:', ['Tiene DOS lados iguales (y dos ángulos iguales)','3 lados iguales','Todos diferentes','Un ángulo recto'], 0, 'Isósceles: 2 lados congruentes. Los ángulos opuestos a esos lados también son iguales.'),
    qMC('Un triángulo escaleno tiene:', ['Todos sus lados DIFERENTES (y todos sus ángulos diferentes)','Dos lados iguales','Tres lados iguales','Un ángulo recto'], 0, 'Escaleno = sin simetría de lados. Es el tipo de triángulo más general.'),
    qMC('Según sus ÁNGULOS, un triángulo acutángulo tiene:', ['Los 3 ángulos AGUDOS (todos < 90°)','Un ángulo recto (90°)','Un ángulo obtuso (>90°)','Ángulos de 60°'], 0, 'Acutángulo = todos los ángulos < 90°. El equilátero es un caso especial de acutángulo.'),
    qMC('Un triángulo obtusángulo:', ['Tiene UN ángulo mayor de 90° (obtuso)','Todos los ángulos rectos','Todos agudos','No existe'], 0, 'Solo UNO de los 3 ángulos puede ser >90° porque la suma total es 180°.'),
    qMC('En un triángulo rectángulo:', ['Un ángulo mide EXACTAMENTE 90°, los otros dos suman 90°','Todos los ángulos son rectos','No tiene ángulo recto','Todos los lados iguales'], 0, 'Rectángulo = un ángulo de 90°. Los otros dos son complementarios (suman 90°). Base del Teorema de Pitágoras.'),
    qTF('Un triángulo puede tener dos ángulos rectos.', false, 'Imposible: 90°+90°=180°, el tercero sería 0°. La suma SIEMPRE es 180°.'),
    qOrder('Ordena estos pasos para clasificar un triángulo con lados 7, 7, 10 cm:', ['Comparar lados: 7=7 ≠ 10 → isósceles','Si fuera por ángulos, verificar Pitágoras','7²+7²=98 < 100=10² → obtusángulo','Resultado: isósceles obtusángulo'], 'Un triángulo tiene dos clasificaciones: por lados Y por ángulos.'),
    qMatch('Relaciona cada triángulo con su clasificación:', [{left:'Lados: 5, 5, 5 cm',right:'Equilátero (y acutángulo)'},{left:'Lados: 6, 6, 8 cm',right:'Isósceles'},{left:'Ángulos: 90°, 45°, 45°',right:'Rectángulo isósceles'},{left:'Lados: 7, 9, 11 cm',right:'Escaleno'}], 'La clasificación por lados y por ángulos son independientes y complementarias.'),
    qMC('El triángulo más famoso de la historia matemática es:', ['El triángulo rectángulo 3-4-5 (egipcio)','El equilátero','El isósceles','El escaleno'], 0, '3²+4²=9+16=25=5². Los egipcios lo usaban para trazar ángulos rectos en construcciones.'),
    qWrite('Clasifica un triángulo con lados 6, 6, 6 cm.', ['equilatero','equilátero'], 'Tres lados iguales: equilátero.'),
    qWrite('Clasifica un triángulo con lados 6, 6, 6 cm.', ['equilatero','equilátero'], 'Tres lados iguales: equilátero.'),
  ],

  // ===== M33: Cuadriláteros - Clasificación =====
  [
    qMC('Un paralelogramo es un cuadrilátero con:', ['Lados opuestos PARALELOS e iguales','Solo ángulos rectos','Solo lados iguales','Todos los lados diferentes'], 0, 'Paralelogramo: cuadrado, rectángulo, rombo, romboide. Gran familia geométrica.'),
    qMC('El cuadrado es:', ['Un paralelogramo con 4 lados iguales Y 4 ángulos rectos','Solo 4 lados iguales','Solo 4 ángulos rectos','Un triángulo'], 0, 'Cuadrado = el más "perfecto" de los cuadriláteros. Cumple todas las propiedades de paralelogramo, rectángulo y rombo.'),
    qMC('Un rombo se caracteriza por:', ['Tener 4 lados IGUALES (pero ángulos NO necesariamente rectos)','Ángulos rectos','Lados desiguales','Diagonales iguales'], 0, 'Rombo = "cuadrado inclinado". Sus diagonales son perpendiculares y se bisecan.'),
    qMC('Un trapecio es un cuadrilátero con:', ['AL MENOS un par de lados paralelos','Todos los lados paralelos','Ningún lado paralelo','Solo ángulos rectos'], 0, 'Trapecio: un par de bases paralelas. Trapecio isósceles: lados no paralelos iguales.'),
    qMC('Un trapezoide es:', ['Un cuadrilátero SIN lados paralelos','Un cuadrilátero con paralelos','Un triángulo','Un polígono regular'], 0, 'Trapezoide = el cuadrilátero más general. Sin lados paralelos.'),
    qMC('La suma de los ángulos internos de CUALQUIER cuadrilátero es:', ['SIEMPRE 360°','180°','270°','540°'], 0, 'Se puede dividir en 2 triángulos: 2×180°=360°. Todo cuadrilátero cumple esto.'),
    qTF('El cuadrado es un tipo especial de rectángulo y de rombo.', true, 'Cuadrado = rectángulo (ángulos rectos) + rombo (lados iguales). Hereda propiedades de ambos.'),
    qOrder('Ordena estos cuadriláteros del más general al más específico:', ['Trapezoide (sin lados paralelos)','Trapecio (1 par paralelo)','Paralelogramo (2 pares paralelos)','Rombo/Rectángulo (paralelogramo especial)','Cuadrado (rombo Y rectángulo)'], 'Jerarquía de cuadriláteros: cada nivel hereda las propiedades del anterior.'),
    qMatch('Relaciona cada cuadrilátero con sus propiedades:', [{left:'Paralelogramo',right:'Lados opuestos paralelos e iguales'},{left:'Rectángulo',right:'4 ángulos rectos'},{left:'Rombo',right:'4 lados iguales'},{left:'Trapecio',right:'Al menos 1 par de lados paralelos'}], 'Cada tipo de cuadrilátero agrega restricciones al tipo más general.'),
    qMC('Un papalote (cometa) es un cuadrilátero con:', ['Dos pares de lados CONSECUTIVOS iguales','Lados opuestos iguales','Todos los lados iguales','Ángulos rectos'], 0, 'Cometa o deltoide: útil en geometría para demostraciones sobre diagonales.'),
    qWrite('¿Qué cuadrilátero tiene 4 lados iguales y 4 ángulos rectos?', ['cuadrado'], 'Es el único con ambas propiedades.'),
    qWrite('¿Qué cuadrilátero tiene 4 lados iguales y 4 ángulos rectos?', ['cuadrado'], 'Es el único con ambas propiedades.'),
  ],

  // ===== M34: Círculo y circunferencia =====
  [
    qMC('La circunferencia es:', ['El conjunto de puntos a IGUAL distancia (radio) de un centro','El área del círculo','El diámetro','Un polígono'], 0, 'Circunferencia = el contorno curvo. Círculo = la superficie interior + la circunferencia.'),
    qMC('El radio de un círculo es:', ['La distancia del CENTRO a CUALQUIER punto de la circunferencia','El doble del diámetro','El perímetro','El área'], 0, 'Radio (r) = mitad del diámetro. d=2r. Todas las fórmulas del círculo usan r.'),
    qMC('El diámetro de un círculo:', ['Atraviesa el centro y une 2 puntos de la circunferencia. d=2r','Es el radio','Es el perímetro','Es la mitad del radio'], 0, 'Diámetro = la cuerda más larga posible en un círculo. Siempre pasa por el centro.'),
    qMC('La longitud de una circunferencia de radio 10 cm es:', ['≈ 62.83 cm (2πr = 2×3.1416×10)','≈ 31.42 cm','≈ 314.16 cm','≈ 20 cm'], 0, 'C=2πr=2×3.1416×10=62.832 cm. π (pi) ≈ 3.1415926535...'),
    qMC('El área de un círculo de radio 7 cm es:', ['≈ 153.94 cm² (πr² = 3.1416×49)','≈ 49 cm²','≈ 21.99 cm²','≈ 100 cm²'], 0, 'A=πr²=3.1416×7²=3.1416×49≈153.94 cm².'),
    qMC('El número π (pi) es la razón entre:', ['La circunferencia y el diámetro de CUALQUIER círculo (C/d ≈ 3.1416)','El área y el radio','La circunferencia y el radio','El diámetro y el área'], 0, 'π = C/d siempre constante. Es un número IRRACIONAL (decimales infinitos no periódicos). Pi Day: 14 de marzo (3/14).'),
    qTF('El área de un círculo se calcula con π×r².', true, 'A=πr². Si tienes el diámetro: divide entre 2 para obtener r. Si r=5 → A≈78.54.'),
    qOrder('Ordena los pasos para calcular el área de un círculo de diámetro 14 cm:', ['Calcular radio: r=14÷2=7 cm','Elevar al cuadrado: 7²=49','Multiplicar por π: 49×3.1416≈153.94','Resultado: ≈153.94 cm²'], 'Siempre parte del radio, aunque te den el diámetro. r = d/2.'),
    qMatch('Relaciona cada medida del círculo:', [{left:'Radio = 5',right:'Diámetro = 10, C ≈ 31.42, A ≈ 78.54'},{left:'Diámetro = 20',right:'Radio = 10, C ≈ 62.83, A ≈ 314.16'},{left:'C ≈ 31.416',right:'d = 10, r = 5'},{left:'A = 201.06',right:'r = 8, d = 16, C ≈ 50.27'}], 'Conociendo UNA sola medida del círculo puedes calcular todas las demás.'),
    qMC('Una pizza mediana tiene diámetro de 30 cm. Su área es:', ['≈ 706.86 cm² (π×15²)','≈ 94.25 cm²','≈ 900 cm²','≈ 450 cm²'], 0, 'r=15 cm. A=π×15²=3.1416×225≈706.86 cm².'),
    qWrite('¿Cuál es el área de un círculo de radio 10 cm? (π≈3.14)', ['314','314 cm²'], 'π×10²=3.14×100=314 cm².'),
    qWrite('¿Cuál es el área de un círculo de radio 10 cm? (π≈3.14)', ['314','314 cm²'], 'π×10²=3.14×100=314 cm².'),
  ],

  // ===== M35: Cuerpos geométricos - Prismas y pirámides =====
  [
    qMC('Un cuerpo geométrico se diferencia de una figura plana en:', ['Tiene 3 DIMENSIONES (largo, ancho y alto = volumen)','Es más bonito','Tiene colores','No tienen diferencia'], 0, 'Figura plana = 2D (largo y ancho). Cuerpo geométrico = 3D (tiene volumen). Cubo vs cuadrado.'),
    qMC('Un prisma es un cuerpo geométrico con:', ['Dos bases IGUALES y PARALELAS (polígonos) unidas por caras rectangulares','Solo caras curvas','Una sola base','Forma de pelota'], 0, 'Prisma = 2 bases congruentes en planos paralelos. Rectangular, triangular, pentagonal, hexagonal...'),
    qMC('Las caras laterales de un prisma recto son:', ['RECTÁNGULOS','Triángulos','Círculos','Hexágonos'], 0, 'En un prisma recto las aristas laterales son perpendiculares a las bases. Si es oblicuo, son romboides.'),
    qMC('Una pirámide tiene:', ['UNA SOLA base (polígono) y caras TRIANGULARES que se unen en un vértice','Dos bases iguales','Puras caras rectangulares','Es como un prisma'], 0, 'Pirámide = base + caras triangulares. Pirámide de Egipto: base cuadrada. Tetraedro: pirámide triangular.'),
    qMC('El volumen de un prisma es:', ['Área de la base × altura (V = Ab × h)','(Ab × h) ÷ 3','base × altura ÷ 2','largo + ancho + alto'], 0, 'Formula general: Vprisma = Ab × h. Para prisma rectangular: V=l×a×h.'),
    qMC('El volumen de una pirámide es:', ['(Área de la base × altura) ÷ 3 (V = Ab×h/3)','Área de la base × altura','Igual que el prisma','No tiene volumen'], 0, 'Una pirámide ocupa 1/3 del prisma con misma base y altura. Relación descubierta por los griegos.'),
    qTF('Un cubo es un prisma especial (prisma cuadrangular con altura = lado de la base).', true, 'Cubo = prisma de base cuadrada con altura igual al lado. Todas sus caras son cuadrados.'),
    qOrder('Ordena estas formas de menor a mayor volumen (misma base y altura):', ['Pirámide (1/3 del prisma)','Prisma (el volumen completo)','Cilindro (π×r²×h)','No se pueden comparar sin datos'], 'Para misma base y altura: prisma = 3× pirámide. Cilindro vs prisma depende de la forma de la base.'),
    qMatch('Relaciona cada cuerpo con sus elementos:', [{left:'Prisma pentagonal',right:'2 bases pentagonales + 5 caras rectangulares'},{left:'Pirámide cuadrada',right:'1 base cuadrada + 4 caras triangulares'},{left:'Cubo',right:'6 caras cuadradas iguales'},{left:'Prisma triangular',right:'2 bases triangulares + 3 caras rectangulares'}], 'El nombre del prisma/pirámide viene de la forma de su base.'),
    qMC('Un tetraedro es:', ['Una pirámide de base triangular (4 caras triangulares, TODAS iguales si es regular)','Un prisma','Un cubo','Un cilindro'], 0, 'Tetraedro regular: 4 caras = 4 triángulos equiláteros. Es el poliedro regular más simple.'),
    qWrite('¿Cuántos vértices tiene un prisma triangular?', ['6'], '2 triángulos de 3 vértices cada uno = 6.'),
    qWrite('¿Cuántos vértices tiene un prisma triangular?', ['6'], '2 triángulos de 3 vértices cada uno = 6.'),
  ],

  // ===== M36: Ángulos - Conceptos y medición =====
  [
    qMC('Un ángulo se forma por:', ['Dos rayos (semirrectas) que comparten un origen común (vértice)','Dos líneas paralelas','Un triángulo','Una curva'], 0, 'Ángulo = abertura entre dos semirrectas con el mismo origen. Se mide en grados (°).'),
    qMC('La unidad de medida de ángulos es:', ['El grado (°). Un círculo completo = 360°','El metro','El litro','El porcentaje'], 0, '360°= división babilónica antigua. 1°=60 minutos, 1 minuto=60 segundos (sistema sexagesimal).'),
    qMC('Un ángulo de 90° se llama:', ['Ángulo RECTO','Ángulo agudo','Ángulo obtuso','Ángulo llano'], 0, 'Recto = exactamente 90°. Es el ángulo de las esquinas de un cuadrado o las paredes con el piso.'),
    qMC('Un ángulo AGUDO mide:', ['Menos de 90° (entre 0° y 90°)','Exactamente 90°','Más de 90°','Exactamente 180°'], 0, 'Agudo = "afilado". Todos los ángulos de un triángulo equilátero (60°) son agudos.'),
    qMC('Un ángulo OBTUSO mide:', ['Más de 90° pero MENOS de 180°','Exactamente 90°','Exactamente 180°','Menos de 90°'], 0, 'Obtuso = "romo". Si abres un abanico a más de 90°, formas un ángulo obtuso.'),
    qMC('Un ángulo LLANO mide:', ['Exactamente 180° (una línea recta)','90°','270°','360°'], 0, 'Llano = media vuelta. Las manecillas del reloj a las 6:00 forman un ángulo llano.'),
    qTF('Un ángulo de 360° es un ángulo completo (vuelta entera).', true, '360° = giro completo. Vuelves al punto de partida.'),
    qOrder('Ordena estos ángulos de menor a mayor apertura:', ['30° (agudo)','90° (recto)','120° (obtuso)','180° (llano)','270° (cóncavo)','360° (completo)'], 'Los ángulos representan la abertura entre dos líneas. Cada tipo define un rango específico.'),
    qMatch('Relaciona cada ángulo con su clasificación:', [{left:'45°',right:'Agudo'},{left:'90°',right:'Recto'},{left:'135°',right:'Obtuso'},{left:'180°',right:'Llano'}], 'Clasificar ángulos por su medida es una habilidad básica de geometría.'),
    qMC('Para medir un ángulo se usa:', ['El transportador (regla semicircular graduada en grados)','Una regla común','Un compás','La vista'], 0, 'Transportador: alinea el centro con el vértice del ángulo y lee la escala donde pasa el otro rayo.'),
    qWrite('¿Cómo se llama un ángulo de 150°?', ['obtuso'], 'Mayor de 90° y menor de 180° = obtuso.'),
    qWrite('¿Cómo se llama un ángulo de 150°?', ['obtuso'], 'Mayor de 90° y menor de 180° = obtuso.'),
  ],

  // ===== M37: Clasificación de ángulos por su posición =====
  [
    qMC('Dos ángulos son COMPLEMENTARIOS si:', ['Suman EXACTAMENTE 90°','Suman 180°','Suman 360°','Son iguales'], 0, 'Ej: 30° y 60° son complementarios porque 30+60=90°. Complementario viene de "completar" un ángulo recto.'),
    qMC('Dos ángulos son SUPLEMENTARIOS si:', ['Suman EXACTAMENTE 180°','Suman 90°','Suman 360°','Son complementarios'], 0, 'Ej: 110° y 70° son suplementarios. "Suplemento" = lo que falta para llegar a 180° (ángulo llano).'),
    qMC('Ángulos ADYACENTES son los que:', ['Comparten el vértice y un lado, sin solaparse','Están lejos','Son opuestos','No tienen relación'], 0, 'Adyacente = "al lado de". Comparten un rayo y el vértice. Sus otros rayos están en lados opuestos del rayo común.'),
    qMC('Ángulos OPUESTOS POR EL VÉRTICE:', ['Son IGUALES (misma medida)','Suman 90°','Suman 180°','Son complementarios'], 0, 'Cuando dos rectas se cruzan, los ángulos enfrentados son iguales. Propiedad fundamental.'),
    qMC('Si dos ángulos son opuestos por el vértice y uno mide 75°, el otro mide:', ['75° (son iguales)','105°','15°','180°'], 0, 'Propiedad: ángulos opuestos por el vértice SIEMPRE son congruentes (misma medida).'),
    qMC('Ángulos CONSECUTIVOS:', ['Comparten el vértice y un lado, uno al lado del otro','No se tocan','Son opuestos','Suma 90°'], 0, 'Consecutivos = adyacentes en secuencia. Los ángulos internos de un polígono son consecutivos.'),
    qTF('Dos ángulos suplementarios siempre suman 180°.', true, 'Definición: α + β = 180°. Si α=120°, β=60°.'),
    qOrder('Ordena las relaciones angulares de menor a mayor suma:', ['Complementarios (suma 90°)','Suplementarios (suma 180°)','Opuestos por el vértice (son iguales)','Conjugados (suma 360°)'], 'Cada relación define una suma específica o propiedad de igualdad entre ángulos.'),
    qMatch('Relaciona la descripción con el tipo de ángulos:', [{left:'Suman 90°',right:'Complementarios'},{left:'Suman 180°',right:'Suplementarios'},{left:'Se forman al cruzar 2 rectas',right:'Opuestos por el vértice'},{left:'Comparten vértice y lado',right:'Adyacentes'}], 'Conocer estas relaciones permite calcular ángulos desconocidos en figuras.'),
    qMC('El complemento de 35° es:', ['55° (porque 35+55=90)','145°','65°','125°'], 0, 'Complemento = 90° - ángulo dado. Suplemento = 180° - ángulo dado.'),
    qWrite('Si un ángulo mide 30°, ¿cuánto mide su complemento?', ['60','60°'], '90-30=60°.'),
    qWrite('Si un ángulo mide 30°, ¿cuánto mide su complemento?', ['60','60°'], '90-30=60°.'),
  ],

  // ===== M38: Rectas paralelas y perpendiculares =====
  [
    qMC('Dos rectas son PARALELAS si:', ['NUNCA se cruzan, mantienen la MISMA distancia entre sí','Se cruzan en un punto','Forman un ángulo de 90°','Son la misma recta'], 0, 'Paralelas: misma dirección, no se intersectan. Vías del tren. Se denotan con símbolos: a ∥ b.'),
    qMC('Dos rectas son PERPENDICULARES si:', ['Se cruzan formando ángulos de EXACTAMENTE 90°','Nunca se cruzan','Se cruzan en cualquier ángulo','Son paralelas'], 0, 'Perpendiculares: intersección a 90°. Esquinas de un cuaderno. Símbolo: a ⊥ b.'),
    qMC('Cuando una recta CORTA a dos paralelas, los ángulos alternos internos son:', ['IGUALES entre sí','Diferentes','Suman 90°','Suman 180°'], 0, 'Propiedad clave de paralelas cortadas por secante: alternos internos iguales, correspondientes iguales, colaterales suplementarios.'),
    qMC('Dos rectas secantes son:', ['Rectas que se CRUZAN en un punto (no necesariamente a 90°)','Rectas paralelas','La misma recta','Rectas que no se tocan'], 0, 'Secantes = se cortan en un punto. Perpendiculares es un caso especial de secantes (a 90°).'),
    qMC('En rectas paralelas cortadas por una secante, los ángulos correspondientes:', ['Son IGUALES','Suman 180°','Suman 90°','Son agudos'], 0, 'Correspondientes = misma posición respecto a la secante. Si uno mide 50°, su correspondiente también mide 50°.'),
    qMC('La distancia entre dos rectas paralelas:', ['Es SIEMPRE CONSTANTE (misma separación en cualquier punto)','Varía','No existe','Es cero'], 0, 'Definición: la distancia perpendicular de un punto en una recta a la otra recta siempre es la misma.'),
    qTF('Las rectas perpendiculares son un caso especial de rectas secantes.', true, 'Secantes = se cruzan. Perpendiculares = se cruzan a 90°. Toda perpendicular es secante, no al revés.'),
    qOrder('Ordena del concepto más simple al más complejo:', ['Recta (infinita, sin grosor)','Semirrecta (origen fijo, infinita en una dirección)','Segmento (origen y fin definidos)','Rectas secantes (se cruzan)','Rectas paralelas (no se cruzan)'], 'Evolución de conceptos de recta: de lo más básico a relaciones entre rectas.'),
    qMatch('Relaciona cada situación con el tipo de rectas:', [{left:'Vías del tren',right:'Paralelas (∥)'},{left:'Esquinas de un libro',right:'Perpendiculares (⊥)'},{left:'Calles que se cruzan (no a 90°)',right:'Secantes'},{left:'Rieles de una escalera',right:'Paralelas'}], 'En la vida cotidiana encuentras estos tres tipos de relaciones entre líneas.'),
    qMC('En un mapa, la Av. Reforma y Av. Insurgentes (CDMX) se cruzan. Son:', ['Rectas secantes','Rectas paralelas','Coincidentes','No se pueden clasificar'], 0, 'Se cruzan en un punto (glorieta). No son perpendiculares exactas, pero son secantes.'),
    qWrite('¿Qué nombre reciben rectas que se cruzan formando 90°?', ['perpendiculares','rectas perpendiculares'], 'Perpendiculares = cruce a 90°.'),
    qWrite('¿Qué nombre reciben rectas que se cruzan formando 90°?', ['perpendiculares','rectas perpendiculares'], 'Perpendiculares = cruce a 90°.'),
  ],

  // ===== M39: Ángulos entre paralelas y secante =====
  [
    qMC('Ángulos alternos internos: están DENTRO de las paralelas y en lados OPUESTOS de la secante. Son:', ['IGUALES','Suplementarios (suman 180°)','Complementarios (suman 90°)','No tienen relación'], 0, 'Si la secante corta dos paralelas, los ángulos alternos internos miden lo mismo.'),
    qMC('Ángulos colaterales internos (mismo lado de la secante, entre las paralelas):', ['Suman 180° (son SUPLEMENTARIOS)','Son iguales','Suman 90°','Suman 360°'], 0, 'También llamados conjugados internos. Si uno mide 120°, el otro mide 60°.'),
    qMC('Si una secante corta dos paralelas y un ángulo interno mide 55°, su alterno interno mide:', ['55° (son iguales)','125°','35°','180°'], 0, 'Alternos internos: misma medida. Correspondientes: misma medida. Colaterales: suman 180° (suplementarios).'),
    qMC('Los ángulos correspondientes se encuentran en:', ['La misma posición relativa respecto a la secante, uno en cada intersección','Lados opuestos','Dentro de las paralelas','Solo en una intersección'], 0, 'Correspondientes: como si deslizaras la figura de una intersección a la otra. Son IGUALES entre sí.'),
    qMC('Dos paralelas cortadas por secante forman 8 ángulos en total. ¿Cuántos valores distintos hay?', ['Solo 2 valores distintos (si uno es x, los otros 3 grupos)','8 valores distintos','4 valores distintos','1 solo valor'], 0, 'Grupo 1: x. Grupo 2: 180°-x. Los 8 ángulos se reparten en solo 2 medidas distintas.'),
    qMC('Si un ángulo agudo entre paralelas mide 70°, el ángulo obtuso relacionado mide:', ['110° (porque suman 180°)','70°','20°','90°'], 0, 'El agudo y el obtuso en esta configuración son suplementarios: 70°+110°=180°.'),
    qTF('Los ángulos alternos externos también son IGUALES entre sí.', true, 'Alternos externos: están fuera de las paralelas. También son congruentes (misma medida).'),
    qOrder('Ordena los pasos para hallar todos los ángulos si uno mide 60° entre dos paralelas:', ['Agudo=60°','Obtuso=180°-60°=120°','Alternos internos = 60° (si son agudos)','Correspondientes = 60°','Colaterales = 120°'], 'Conociendo un solo ángulo, puedes deducir los otros 7 usando las propiedades.'),
    qMatch('Relaciona cada par de ángulos entre paralelas:', [{left:'Alternos internos',right:'IGUALES'},{left:'Correspondientes',right:'IGUALES'},{left:'Colaterales internos',right:'SUMAN 180°'},{left:'Opuestos por el vértice',right:'IGUALES'}], 'Tres tipos de relación, pero solo dos patrones: o son iguales o suman 180°.'),
    qMC('Esta configuración es la base para demostrar que:', ['La suma de ángulos de un triángulo es 180°','Los cuadrados tienen 4 lados','Los círculos son redondos','No sirve para nada'], 0, 'Se traza una paralela a un lado por el vértice opuesto. Los tres ángulos del triángulo quedan alineados = 180°.'),
    qWrite('Si alternos internos miden 65°, ¿cuánto miden los colaterales?', ['115','115°'], 'Colaterales: 180°-65°=115°.'),
    qWrite('Si alternos internos miden 65°, ¿cuánto miden colaterales?', ['115','115°'], 'Colaterales: 180°-65°=115°.'),
  ],

  // ===== M40: Bisectriz y mediatriz =====
  [
    qMC('La bisectriz de un ángulo es:', ['La semirrecta que DIVIDE el ángulo en DOS partes IGUALES','La línea que une dos puntos','El lado opuesto','La perpendicular'], 0, 'Bisectriz = "que corta en dos partes iguales". Cada punto de la bisectriz equidista de los lados del ángulo.'),
    qMC('Si un ángulo mide 80° y trazamos su bisectriz, cada parte mide:', ['40°','80°','160°','20°'], 0, '80°÷2=40°. La bisectriz siempre divide exactamente a la MITAD.'),
    qMC('La mediatriz de un segmento es:', ['La recta PERPENDICULAR al segmento en su PUNTO MEDIO','Un ángulo','Cualquier línea','El segmento mismo'], 0, 'Mediatriz: perpendicular + pasa por el punto medio. Sus puntos equidistan de los extremos del segmento.'),
    qMC('En un triángulo, el punto donde se cruzan las 3 bisectrices de los ángulos se llama:', ['INCENTRO (centro de la circunferencia inscrita)','Baricentro','Ortocentro','Circuncentro'], 0, 'Incentro: equidista de los 3 lados. Centro del círculo INS-crito (dentro del triángulo).'),
    qMC('El circuncentro es el punto donde se cruzan:', ['Las 3 MEDIATRICES de los lados del triángulo','Las bisectrices','Las alturas','Las medianas'], 0, 'Circuncentro: equidista de los 3 vértices. Centro del círculo CIRCUN-scrito (rodea el triángulo).'),
    qMC('La bisectriz de un ángulo de 60° da:', ['Dos ángulos de 30° cada uno','Un ángulo de 60°','Dos ángulos de 60°','Un ángulo de 120°'], 0, '60°÷2=30°. La bisectriz garantiza la división exacta.'),
    qTF('La mediatriz de un segmento es SIEMPRE perpendicular a ese segmento.', true, 'Dos condiciones de mediatriz: 1) perpendicular al segmento, 2) pasa por el punto medio.'),
    qOrder('Ordena los pasos para construir la mediatriz de un segmento AB:', ['Abrir compás más de la mitad de AB','Pinchar en A, trazar arco arriba y abajo','Pinchar en B, mismo radio, trazar arcos','Unir los puntos de intersección de los arcos','Esa recta es la mediatriz'], 'Construcción con regla y compás. Método clásico: los arcos deben tener el mismo radio.'),
    qMatch('Relaciona cada punto notable del triángulo con su origen:', [{left:'Incentro',right:'Intersección de 3 bisectrices'},{left:'Circuncentro',right:'Intersección de 3 mediatrices'},{left:'Baricentro',right:'Intersección de 3 medianas'},{left:'Ortocentro',right:'Intersección de 3 alturas'}], 'Cada punto notable surge de la intersección de 3 rectas especiales del triángulo.'),
    qMC('En un triángulo equilátero, los 4 puntos notables:', ['COINCIDEN en un mismo punto (gran simetría)','Están separados','Son diferentes','No existen'], 0, 'En el equilátero: incentro = circuncentro = baricentro = ortocentro. Única figura con esta propiedad.'),
    qWrite('El punto de intersección de las 3 alturas de un triángulo es el:', ['ortocentro'], 'Ortocentro = intersección de alturas.'),
    qWrite('El punto de intersección de las 3 alturas es el:', ['ortocentro'], 'Ortocentro = intersección de alturas.'),
  ],

  // ===== M41: Tablas de frecuencia y pictogramas =====
  [
    qMC('Una tabla de frecuencia sirve para:', ['ORGANIZAR datos contando cuántas veces aparece cada valor','Hacer dibujos','Sumar números','No sirve para nada'], 0, 'Frecuencia = número de veces que se repite un dato. Fundamental en estadística.'),
    qMC('En una encuesta sobre mascotas: 12 perros, 8 gatos, 5 peces. La frecuencia total (muestra) es:', ['25 mascotas en total','12 mascotas','20 mascotas','8 mascotas'], 0, 'Sumas todas las frecuencias: 12+8+5=25. Es el total de datos recolectados.'),
    qMC('La moda en estadística es:', ['El valor que más se REPITE (mayor frecuencia)','El valor promedio','El valor central','El valor más pequeño'], 0, 'Moda = dato más frecuente. Si hay empate, puede haber más de una moda o ser bimodal.'),
    qMC('Un pictograma representa datos mediante:', ['DIBUJOS o símbolos (cada ícono = cierta cantidad)','Solo números','Solo barras','Solo líneas'], 0, 'Pictograma: ideal para datos cualitativos. Ej: cada 🌮 = 10 tacos vendidos.'),
    qMC('En un pictograma, si 😊 = 5 alumnos y hay 7 caritas, el total es:', ['35 alumnos (7×5)','12 alumnos','5 alumnos','7 alumnos'], 0, 'Multiplica el número de íconos por el valor de cada uno.'),
    qMC('La frecuencia absoluta es:', ['El conteo REAL de veces que aparece un dato','El porcentaje','Un promedio','La moda'], 0, 'Frecuencia absoluta = conteo directo. Frecuencia relativa = (absoluta/total)×100 (porcentaje).'),
    qTF('La frecuencia relativa se expresa como porcentaje del total.', true, 'Frecuencia relativa = (frecuencia absoluta ÷ total) × 100%. Ej: 12 de 25 = 48%.'),
    qOrder('Ordena los pasos para construir una tabla de frecuencia:', ['Recolectar datos','Listar categorías o valores','Contar cuántos hay de cada uno (frecuencia)','Calcular frecuencia relativa (si se pide)','Presentar en tabla organizada'], 'Proceso básico de cualquier estudio estadístico.'),
    qMatch('Relaciona cada concepto estadístico con su definición:', [{left:'Frecuencia absoluta',right:'Conteo real de cada categoría'},{left:'Frecuencia relativa',right:'Porcentaje respecto al total'},{left:'Moda',right:'Dato con mayor frecuencia'},{left:'Muestra',right:'Total de datos recolectados'}], 'Conceptos fundamentales para leer y crear gráficas y reportes.'),
    qMC('En una clase: 10 niños prefieren fútbol, 6 basquetbol, 4 voleibol. La moda es:', ['Fútbol (mayor frecuencia: 10)','Basquetbol','Voleibol','Todos igual'], 0, 'Moda = fútbol con 10 preferencias.'),
    qWrite('Datos: 5, 3, 7, 3, 5. ¿Cuál es la moda?', ['3 y 5','bimodal','3,5'], '3 y 5 aparecen 2 veces cada uno = bimodal.'),
    qWrite('Datos: 5, 3, 7, 3, 5. ¿Cuál es la moda?', ['3 y 5','bimodal','3,5'], 'Ambos aparecen 2 veces = bimodal.'),
  ],

  // ===== M42: Gráficas de barras =====
  [
    qMC('Una gráfica de barras se usa para:', ['COMPARAR cantidades entre diferentes categorías','Mostrar tendencias en el tiempo','Dibujar','Sumar'], 0, 'Barras: rectángulos cuya ALTURA es proporcional a la frecuencia de cada categoría.'),
    qMC('En una gráfica de barras, el eje HORIZONTAL (X) muestra:', ['Las CATEGORÍAS (ej: meses, colores, deportes)','Las frecuencias','Los números','No muestra nada'], 0, 'Eje X = categorías. Eje Y = frecuencia o cantidad. Lee correctamente para interpretar.'),
    qMC('La altura de cada barra representa:', ['La FRECUENCIA o cantidad de esa categoría','El color','El grosor','La posición'], 0, 'A mayor barra, mayor frecuencia. Compara visualmente las alturas.'),
    qMC('Ventas mensuales: Ene=$500, Feb=$800, Mar=$650. La barra más alta es:', ['Febrero ($800)','Enero','Marzo','Son iguales'], 0, 'Febrero = $800 = barra más alta. Visualización inmediata.'),
    qMC('Si una gráfica de barras muestra temperaturas: Lun=25°, Mar=28°, Mié=22°, Jue=30°. El día más caluroso:', ['Jueves (30°C)','Martes','Lunes','Miércoles'], 0, 'Buscas la barra más alta = jueves 30°C.'),
    qMC('Para leer el valor exacto de una barra:', ['Proyectas una línea horizontal desde la cima de la barra hasta el eje Y (vertical)','Adivinas','Mides con regla','No es importante'], 0, 'Lectura precisa: traza línea imaginaria al eje de valores.'),
    qTF('Las gráficas de barras pueden ser horizontales o verticales.', true, 'Ambas son válidas. Vertical es más común. Horizontal es útil cuando las categorías tienen nombres largos.'),
    qOrder('Ordena los pasos para interpretar una gráfica de barras:', ['Leer el título (de qué trata la gráfica)','Identificar categorías en eje X','Leer la escala del eje Y','Comparar alturas de barras','Sacar conclusiones (moda, diferencias, total)'], 'Lectura sistemática de gráficas: del contexto general a los detalles específicos.'),
    qMatch('Relaciona el tipo de dato con su representación:', [{left:'Colores favoritos',right:'Gráfica de barras'},{left:'Temperatura diaria por un mes',right:'Gráfica de líneas'},{left:'Partes de un presupuesto',right:'Gráfica circular'},{left:'Conteo simple con dibujos',right:'Pictograma'}], 'Cada tipo de gráfica es más adecuada para cierto tipo de datos y mensaje.'),
    qMC('En una encuesta de frutas: 🍎25, 🍌18, 🍊15, 🍇22. ¿Cuál barra es la más baja?', ['Naranja (🍊) con 15','Manzana','Plátano','Uvas'], 0, 'La barra más baja corresponde a la menor frecuencia: naranja con solo 15.'),
    qWrite('Si la barra más alta tiene valor 95, ¿es la moda? Sí/No', ['si','sí'], 'Sí, la mayor frecuencia es la moda.'),
    qWrite('Si la barra más alta tiene valor 95, ¿es la moda?', ['si','sí'], 'Sí, la mayor frecuencia = moda.'),
  ],

  // ===== M43: Gráficas de líneas (poligonales) =====
  [
    qMC('Una gráfica de líneas es ideal para:', ['Mostrar CAMBIOS o TENDENCIAS a lo largo del TIEMPO','Comparar categorías fijas','Mostrar partes de un todo','Hacer dibujos'], 0, 'Líneas = evolución temporal. Temperatura por día, crecimiento de planta, valor de acciones.'),
    qMC('En una gráfica de líneas, los puntos se unen con segmentos para:', ['Mostrar la TENDENCIA (sube, baja, estable)','Decorar','Confundir','No tienen uso'], 0, 'La línea conecta puntos consecutivos en el tiempo revelando el patrón de cambio.'),
    qMC('Si una línea sube de izquierda a derecha, indica:', ['TENDENCIA CRECIENTE (aumento)','Disminución','Estabilidad','No significa nada'], 0, 'Pendiente positiva = crecimiento. Interpretación económica, científica y cotidiana.'),
    qMC('Una línea horizontal (plana) indica:', ['Estabilidad = NO HAY CAMBIO en ese período','Crecimiento rápido','Caída','Error en los datos'], 0, 'Horizontal = valor constante. Ej: peso estable durante una semana.'),
    qMC('Temperaturas: Lun 15°, Mar 18°, Mié 16°, Jue 20°, Vie 22°. La tendencia es:', ['CRECIENTE (de 15° a 22°, subió 7°)','Decreciente','Estable','Aleatoria'], 0, 'Aunque baja de Martes a Miércoles, la tendencia general es ascendente.'),
    qMC('Una gráfica de líneas puede mostrar más de una serie:', ['Sí, usando distintos colores o estilos (comparar 2 poblaciones, 2 productos, etc.)','No, solo una','Depende','Solo 2'], 0, 'Multiserie: comparas patrones. Ej: ventas 2025 vs 2026 en mismas fechas.'),
    qTF('Una gráfica de líneas es más adecuada que una de barras para datos en el tiempo.', true, 'Barras = comparar categorías. Líneas = tendencias temporales.'),
    qOrder('Ordena estos pasos para crear una gráfica de líneas de temperatura semanal:', ['Dibujar ejes (X=días, Y=temperatura)','Marcar puntos (día, °C)','Unir puntos con segmentos de recta','Poner título y etiquetas'], 'Construcción paso a paso: ejes → puntos → unión → etiquetas.'),
    qMatch('Relaciona la tendencia con el significado:', [{left:'Línea sube',right:'Aumento'},{left:'Línea baja',right:'Disminución'},{left:'Línea plana',right:'Estabilidad'},{left:'Línea en zigzag',right:'Variabilidad'}], 'Interpretar pendientes y patrones es fundamental para leer noticias con gráficas.'),
    qMC('Lluvia mensual en La Paz BCS: Jul=15mm, Ago=50mm, Sep=80mm, Oct=30mm. El mes pico:', ['Septiembre (80 mm = punto más alto de la línea)','Julio','Agosto','Octubre'], 0, 'El pico es el punto más alto: septiembre. Estacionalidad de lluvias.'),
    qWrite('¿Qué indica una línea que BAJA en gráfica temporal?', ['disminucion','disminución','decrece'], 'Decrecimiento en el tiempo.'),
    qWrite('¿Qué indica una línea que BAJA en gráfica temporal?', ['disminucion','disminución','decrece'], 'Decrecimiento en el tiempo.'),
  ],

  // ===== M44: Gráficas circulares (de pastel) =====
  [
    qMC('Una gráfica circular (de pastel) representa:', ['PARTES de un TODO (100% = círculo completo)','Tendencias temporales','Comparación de barras','Datos sueltos'], 0, 'Pastel = proporciones. Cada sector (rebanada) representa una fracción o porcentaje del total.'),
    qMC('Si un sector ocupa 1/4 del círculo, representa:', ['25% del total','50%','75%','100%'], 0, '1/4 del círculo = 90° (ángulo del sector). 90/360 = 1/4 = 25%.'),
    qMC('Para calcular el ángulo de un sector que representa 30%:', ['360° × 0.30 = 108°','30°','360°','90°'], 0, 'Regla: ángulo del sector = (% ÷ 100) × 360°. 30% = 0.30 × 360° = 108°.'),
    qMC('La suma de todos los sectores de una gráfica circular es:', ['360° (círculo completo) = 100%','180°','90°','270°'], 0, 'El círculo entero = 360° = 100% de los datos.'),
    qMC('En un presupuesto familiar: Renta 40%, Comida 25%, Transporte 15%, Ahorro 10%, Otros 10%. El sector más grande es:', ['Renta (40% = 144°)','Comida','Transporte','Ahorro'], 0, 'A mayor porcentaje, mayor sector. Renta domina con 40%.'),
    qMC('Para calcular cuánto dinero representa 25% de $8,000:', ['$2,000 (8,000×0.25)','$2,500','$250','$25,000'], 0, 'Multiplica el total por el porcentaje en decimal. 25% = 0.25.'),
    qTF('La gráfica circular es ideal para mostrar cambios a través del tiempo.', false, 'Para cambios temporales usa gráfica de líneas. Circular es para composición de un todo en un momento dado.'),
    qOrder('Ordena los pasos para construir una gráfica circular:', ['Calcular el ángulo de cada categoría (% × 360°)','Dibujar el círculo','Trazar sectores con transportador empezando desde la vertical','Colorear y etiquetar cada sector'], 'Construcción precisa: requiere transportador para los ángulos de cada sector.'),
    qMatch('Relaciona cada porcentaje con su ángulo en gráfica circular:', [{left:'25%',right:'90°'},{left:'50%',right:'180°'},{left:'75%',right:'270°'},{left:'10%',right:'36°'}], 'Conversión clave: % × 3.6 = grados del sector.'),
    qMC('Uso del tiempo diario: Dormir 8h, Escuela 7h, Tareas 3h, Comer 2h, Juego 4h. ¿Mayor sector?', ['Dormir (8/24 = 33.3% = 120°)','Escuela','Juego','Tareas'], 0, '8 horas de 24 = 33.3% = sector de 120°.'),
    qWrite('En gráfica circular, 30% equivale a ¿cuántos grados?', ['108','108°'], '360°×0.30=108°.'),
    qWrite('En gráfica circular, 30% equivale a ¿cuántos grados?', ['108','108°'], '360°×0.30=108°.'),
  ],

  // ===== M45: Media aritmética (promedio) =====
  [
    qMC('La media aritmética (promedio) se calcula:', ['SUMANDO todos los valores y DIVIDIENDO entre el número de datos','Tomando el valor central','El que más se repite','El valor máximo menos el mínimo'], 0, 'Promedio = (suma de valores) ÷ n. Ej: (8+7+9+6)÷4 = 30÷4 = 7.5.'),
    qMC('El promedio de 8, 12, 15 y 9 es:', ['11 (suma=44, 44÷4=11)','12','10','44'], 0, '44÷4=11. El promedio no tiene que ser uno de los datos originales.'),
    qMC('Tres exámenes: 85, 90, 95. Promedio:', ['90 (270÷3=90)','85','95','92'], 0, '85+90+95=270. 270÷3=90.'),
    qMC('El promedio de 5 números es 20. La suma total de esos números es:', ['100 (porque 20×5=100)','20','5','25'], 0, 'Suma = promedio × n. 20×5=100. Relación inversa muy útil.'),
    qMC('Para subir el promedio de 70 a 80 con un nuevo examen (actualmente 3 exámenes):', ['Necesitas sacar el promedio nuevo total: (4×80)-(3×70)=320-210=110','Sacar 80','Sacar 90','No se puede'], 0, 'Para n=4 con promedio 80, suma=320. Suma actual=210. Diferencia=110. Pero máximo es 100, imposible subir tanto.'),
    qMC('Promedio de temperaturas: 22°, 24°, 20°, 26°, 23°:', ['23° (suma=115, 115÷5=23)','24°','22°','25°'], 0, '115÷5=23°C. El promedio suaviza los datos.'),
    qTF('El promedio puede ser afectado fuertemente por valores extremos (muy altos o bajos).', true, 'Ej: edades 10, 11, 10, 10, 60 → promedio=20.2 (distorsionado por la persona de 60). No siempre es representativo.'),
    qOrder('Ordena los pasos para calcular el promedio de un grupo:', ['Sumar todos los valores','Contar cuántos valores hay (n)','Dividir la suma entre n','El resultado es el promedio aritmético'], 'Procedimiento universal de la media, aplicable a cualquier conjunto de datos numéricos.'),
    qMatch('Relaciona cada situación con su promedio:', [{left:'10, 20, 30',right:'20'},{left:'5, 5, 5, 5',right:'5'},{left:'100, 0, 50',right:'50'},{left:'7, 8, 9, 10, 11',right:'9'}], 'El promedio sintetiza un conjunto de datos en un solo número representativo.'),
    qMC('Edades: 12, 14, 13, 12, 14, 13 años. Promedio:', ['13 años','12 años','14 años','12.5'], 0, '(12+14+13+12+14+13)÷6=78÷6=13 años.'),
    qWrite('Calcula el promedio de: 12, 18, 24, 30', ['21'], '(12+18+24+30)÷4=84÷4=21.'),
    qWrite('Calcula el promedio de: 12, 18, 24, 30', ['21'], '(12+18+24+30)÷4=84÷4=21.'),
  ],

  // ===== M46: Probabilidad - Conceptos básicos =====
  [
    qMC('La probabilidad se define como:', ['Casos FAVORABLES ÷ Casos POSIBLES (mide la posibilidad de que algo ocurra)','Un número al azar','Siempre 50%','No existe'], 0, 'P = favorables/posibles. Si lanzo un dado, P(sacar 3) = 1/6. Siempre entre 0 y 1.'),
    qMC('La probabilidad se puede expresar como:', ['Fracción (1/2), decimal (0.5) o porcentaje (50%)','Solo como número entero','Solo como letras','No se expresa'], 0, 'Tres formas equivalentes: 1/4 = 0.25 = 25%. Todas representan la misma probabilidad.'),
    qMC('Un evento SEGURO tiene probabilidad:', ['1 (o 100%). OCURRIRÁ con certeza','0','0.5','2'], 0, 'P=1 = seguro. Ej: al lanzar un dado, sacar un número del 1 al 6. Siempre ocurre.'),
    qMC('Un evento IMPOSIBLE tiene probabilidad:', ['0 (o 0%). NO PUEDE OCURRIR','1','0.5','100%'], 0, 'P=0 = imposible. Ej: lanzar un dado normal y sacar 7. Nunca ocurre.'),
    qMC('Al lanzar una moneda, la probabilidad de obtener águila es:', ['1/2 = 0.5 = 50%','1/3','1','0'], 0, 'Dos resultados posibles (águila, sol), ambos igualmente probables. P=1/2.'),
    qMC('En una urna con 3 pelotas rojas, 2 azules y 5 verdes, P(sacar roja):', ['3/10 = 0.3 = 30%','3/5','1/3','5/10'], 0, 'Favorables=3 rojas. Posibles=10 total. P=3/10=30%.'),
    qTF('La probabilidad SIEMPRE está entre 0 y 1 (0% y 100%).', true, 'Ninguna probabilidad puede ser negativa ni mayor a 1. Si te da fuera de rango, hay error.'),
    qOrder('Ordena estos eventos del más al menos probable:', ['Que salga el sol mañana (P≈1)','Águila al lanzar moneda (P=0.5)','Sacar 6 en un dado (P≈0.167)','Ganar la lotería (P≈0.0000001)'], 'De evento seguro a evento casi imposible. La probabilidad cuantifica la certeza.'),
    qMatch('Relaciona el valor de probabilidad con su significado:', [{left:'P=0',right:'Imposible'},{left:'P=0.5',right:'Igual de probable que improbable'},{left:'P=1',right:'Seguro'},{left:'P=0.25',right:'Poco probable (1 de cada 4)'}], 'Interpretar valores de probabilidad para tomar decisiones.'),
    qMC('En una rifa con 100 boletos, compras 5. Tu probabilidad de ganar es:', ['5/100 = 5%','1/100 = 1%','5/1 = 500%','100%'], 0, 'Tienes 5 de los 100 boletos. P=5/100=1/20=5%.'),
    qWrite('¿Cuál es la probabilidad de sacar sol en una moneda?', ['1/2','0.5','50%'], '1 favorable de 2 posibles.'),
    qWrite('¿Cuál es P(sacar sol en una moneda)?', ['1/2','0.5','50%'], '1 favorable de 2 posibles.'),
  ],

  // ===== M47: Probabilidad experimental vs teórica =====
  [
    qMC('La probabilidad TEÓRICA es:', ['Lo que la teoría predice ANTES de experimentar (basado en resultados igualmente probables)','El resultado de un experimento','Siempre 50%','No existe'], 0, 'Teórica: P(águila)=1/2 porque hay 2 lados igualmente probables.'),
    qMC('La probabilidad EXPERIMENTAL se calcula:', ['Realizando el experimento MUCHAS veces: P(exp)=éxitos/intentos','Con fórmulas teóricas','Adivinando','Siempre da lo mismo'], 0, 'Experimental: si lanzas 100 veces y salen 47 águilas, P≈47/100=0.47. No es exactamente 0.5.'),
    qMC('La Ley de los Grandes Números dice:', ['Al repetir MUCHAS VECES un experimento, la frecuencia se acerca a la probabilidad teórica','Todo es aleatorio','La probabilidad cambia','No existe esa ley'], 0, 'Entre más lanzamientos, más cerca de 50% estará la frecuencia de águilas. La teoría emerge con la práctica.'),
    qMC('Si lanzas una moneda 10 veces y salen 7 águilas, la probabilidad experimental de águila es:', ['7/10 = 0.7 = 70%','1/2 = 0.5','7/3','50%'], 0, 'Con pocos intentos puede alejarse mucho del 50% teórico. ¡Normal!'),
    qMC('Para que la probabilidad experimental sea CONFIABLE necesitas:', ['MUCHAS repeticiones (cientos o miles)','Solo 1 intento','10 repeticiones máximo','No importa'], 0, 'Pocas repeticiones = resultado poco confiable. Muchas repeticiones = se acerca a la teoría.'),
    qMC('La probabilidad teórica de sacar "6" en un dado es 1/6 ≈ 0.1667. Si lanzas 600 veces esperas:', ['APROXIMADAMENTE 100 veces (600/6)','Exactamente 100','600 veces','Nunca'], 0, 'Valor esperado = n×P = 600×(1/6)=100. Puede ser 98, 102... por variación aleatoria.'),
    qTF('La probabilidad experimental y la teórica siempre coinciden exactamente.', false, 'Casi nunca coinciden exactamente. La experimental se ACERCA a la teórica con muchas repeticiones.'),
    qOrder('Ordena los pasos para calcular probabilidad experimental de un dado:', ['Lanzar el dado muchas veces (ej: 300)','Anotar cuántas veces salió cada número','Calcular: frecuencia del número ÷ total de lanzamientos','Esta es la P experimental de ese número'], 'Método experimental: observar, contar, dividir. Así validamos las predicciones teóricas.'),
    qMatch('Relaciona cada ejemplo con el tipo de probabilidad:', [{left:'Calcular P(sacar as) = 4/52',right:'Teórica'},{left:'Repartir 200 cartas y contar ases',right:'Experimental'},{left:'Moneda: 500 lanzamientos, 260 águilas',right:'Experimental = 0.52'},{left:'Dado: P(par) = 3/6 = 1/2',right:'Teórica'}], 'Ambos tipos de probabilidad se complementan para entender el azar.'),
    qMC('Un jugador de basquetbol encestó 7 de 10 tiros libres en un partido. Su P experimental:', ['70% (7/10)','50%','100%','7%'], 0, 'P experimental = 7/10 = 70% en ese partido. Otro día puede variar.'),
    qWrite('Lanzas dado 500 veces, sale 4 en 90. P experimental de 4:', ['0.18','18%','90/500'], '90/500=0.18=18%.'),
    qWrite('Lanzas dado 500 veces, sale 4 en 90. P experimental:', ['0.18','18%','90/500'], '90/500=0.18=18%.'),
  ],

  // ===== M48: Juegos de azar y probabilidad =====
  [
    qMC('En un dado normal de 6 caras, P(sacar número PAR):', ['3/6 = 1/2 = 50%','2/6 = 1/3','1/6','4/6 = 2/3'], 0, 'Pares: 2, 4, 6. Son 3 de 6 = 1/2.'),
    qMC('Al lanzar DOS dados, ¿cuántos resultados posibles hay?', ['6×6 = 36 resultados posibles','12','6','36/2=18'], 0, 'Cada dado tiene 6 resultados. Principio fundamental de conteo: 6×6=36.'),
    qMC('Al lanzar 2 dados, P(la suma sea 7):', ['6/36 = 1/6 (combinaciones: 1+6,2+5,3+4,4+3,5+2,6+1)','1/36','7/36','1/2'], 0, 'Hay 6 formas distintas de sumar 7 de las 36 posibles. Es la suma más probable.'),
    qMC('En una baraja de 52 cartas, P(sacar un corazón):', ['13/52 = 1/4 = 25%','1/52','4/52','26/52 = 1/2'], 0, '4 palos: 13 cartas cada uno. Corazones = 13 de 52.'),
    qMC('En una ruleta mexicana (38 números: 0,00,1-36), P(acertar un número específico):', ['1/38 ≈ 2.63%','1/36','1/37','50%'], 0, 'Un número entre 38 posibles. Cada número tiene igual probabilidad.'),
    qMC('Al lanzar una moneda 3 veces, P(todas águilas):', ['(1/2)³ = 1/8','1/3','3/8','1/2'], 0, 'Probabilidad de eventos independientes: multiplicas. 1/2×1/2×1/2=1/8.'),
    qTF('En una moneda, águila y sol tienen probabilidad 0.5 cada uno.', true, 'Moneda ideal: 2 lados, ambos igual de probables (50%). Monedas reales muy cercanas a eso.'),
    qOrder('Ordena estos juegos del más favorable al jugador al menos favorable:', ['Volado (P ganar=0.5)','Dado acertar número (P=1/6≈0.167)','Lotería (P≈0.000001)','No se puede comparar sin más datos'], 'Entender las probabilidades ayuda a tomar decisiones informadas sobre juegos y riesgos.'),
    qMatch('Relaciona cada situación con su probabilidad teórica:', [{left:'Moneda: águila',right:'1/2 (50%)'},{left:'Dado: número 4',right:'1/6 (≈16.7%)'},{left:'Baraja: rey',right:'4/52 = 1/13 (≈7.7%)'},{left:'2 dados: suma 12',right:'1/36 (≈2.8%)'}], 'Cada juego tiene sus propias probabilidades. Conocerlas es ventaja.'),
    qMC('En una tómbola con 10 premios y 100 boletos, ¿vale la pena comprar 1 boleto?', ['P ganar = 10/100 = 10%. Depende del costo del boleto y valor del premio','Sí, siempre','No, nunca','50% de probabilidad'], 0, 'Decisión informada: comparar ganancia esperada con costo. Valor esperado = P(ganar)×premio - costo.'),
    qWrite('En baraja de 52 cartas, P(carta negra):', ['1/2','0.5','50%'], '26 cartas negras de 52 = 1/2.'),
    qWrite('En baraja de 52 cartas, P(carta negra):', ['1/2','0.5','50%'], '26 negras de 52 = 1/2.'),
  ],

  // ===== M49: Diagrama de árbol =====
  [
    qMC('Un diagrama de árbol se usa para:', ['MOSTRAR todas las combinaciones posibles de eventos sucesivos','Plantar árboles','Contar dinero','Sumar fracciones'], 0, 'Herramienta visual para probabilidad y conteo. Cada "rama" = una opción. Ramificaciones = combinaciones.'),
    qMC('Para calcular combinaciones con árbol: lanzar 2 monedas, ¿cuántas ramas finales?', ['4 ramas finales (AA, AS, SA, SS)','2 ramas','6 ramas','8 ramas'], 0, 'Primer lanzamiento (2), segundo (2 cada uno). 2×2=4 resultados finales.'),
    qMC('En un restaurante: 3 sopas y 4 platos fuertes. ¿Cuántas combinaciones posibles?', ['12 combinaciones (3×4)','7 combinaciones','1 combinación','No se puede'], 0, 'Principio de multiplicación: 3×4=12 menús diferentes. Cada rama del árbol = combinación.'),
    qMC('El principio fundamental de conteo dice:', ['Si un evento A tiene m opciones y B tiene n, las combinaciones totales = m×n','Siempre se suma','Solo aplica a monedas','No existe'], 0, 'Regla del producto: m×n. Para 3 eventos: m×n×p. Así cuentas combinaciones sin dibujar todo.'),
    qMC('Lanzar 1 moneda y 1 dado: resultados posibles:', ['2×6 = 12 resultados (A1, A2... S6)','8 resultados','36 resultados','2 resultados'], 0, 'Moneda (2) × Dado (6) = 12 combinaciones distintas.'),
    qMC('Tienes 3 camisas (roja, azul, blanca) y 2 pantalones (negro, azul). Combinaciones:', ['6 outfits diferentes (3×2)','5 outfits','3 outfits','2 outfits'], 0, '3×2=6. Árbol: camisa→cada una se bifurca en 2 pantalones.'),
    qTF('Un diagrama de árbol ayuda a visualizar y contar TODAS las posibilidades sin olvidar ninguna.', true, 'Herramienta poderosa de organización mental. Muy usada en probabilidad, genética y toma de decisiones.'),
    qOrder('Ordena los pasos para construir un diagrama de árbol de "elegir 3 toppings de helado (chocolate, vainilla, fresa) con 2 salsas (caramelo, chocolate)":', ['Primer nivel: 3 ramas (sabores de helado)','De CADA sabor, sacar 2 ramas (salsas)','Contar ramas finales: 3×2=6','Interpretar: 6 combinaciones posibles'], 'El árbol crece nivel a nivel. Cada nuevo nivel multiplica las opciones del anterior.'),
    qMatch('Relaciona el problema con el total de combinaciones:', [{left:'2 camisas × 3 pantalones',right:'6'},{left:'Lanzar 3 monedas',right:'8 (2³)'},{left:'Candado de 3 dígitos',right:'1,000 (10³)'},{left:'3 sopas × 4 platos × 2 postres',right:'24 (3×4×2)'}], 'Cuando se agregan niveles al árbol, multiplicas todas las opciones de cada nivel.'),
    qMC('Un candado de combinación usa 3 dígitos (0-9). ¿Cuántas combinaciones posibles?', ['10³ = 1,000 combinaciones','30 combinaciones','100 combinaciones','3,000 combinaciones'], 0, 'Cada dígito tiene 10 opciones. 10×10×10=1,000. Si se repiten dígitos es válido.'),
    qWrite('Con 4 playeras y 3 pantalones, ¿cuántas combinaciones?', ['12'], '4×3=12 combinaciones.'),
    qWrite('Con 4 playeras y 3 pantalones, ¿cuántas combinaciones?', ['12'], '4×3=12 combinaciones.'),
  ],

  // ===== M50: Probabilidad compuesta =====
  [
    qMC('Eventos INDEPENDIENTES son aquellos donde:', ['El resultado de uno NO AFECTA la probabilidad del otro','Siempre dependen','Son lo mismo','No existen'], 0, 'Ej: lanzar moneda y dado. Son independientes porque lo que salga en la moneda no cambia las probabilidades del dado.'),
    qMC('Para probabilidad de A Y B (independientes):', ['P(A y B) = P(A) × P(B) (se MULTIPLICAN)','P(A) + P(B) (se suman)','P(A) - P(B)','No se puede'], 0, 'Multiplicación. P(águila y 6) = 1/2 × 1/6 = 1/12 ≈ 8.3%.'),
    qMC('Eventos MUTUAMENTE EXCLUYENTES:', ['NO pueden ocurrir AL MISMO TIEMPO','Siempre ocurren juntos','Son independientes','No existen'], 0, 'Ej: al lanzar un dado, sacar 2 y sacar 5. No pueden pasar simultáneamente.'),
    qMC('Para probabilidad de A O B (mutuamente excluyentes):', ['P(A o B) = P(A) + P(B) (se SUMAN)','P(A) × P(B)','P(A) - P(B)','No se calcula'], 0, 'Suma. P(sacar 1 o 6 en un dado) = 1/6 + 1/6 = 2/6=1/3≈33.3%.'),
    qMC('P(águila en moneda Y 5 en dado) = ?', ['1/2 × 1/6 = 1/12 ≈ 8.3%','1/2 + 1/6 = 2/3','1/8','50%'], 0, 'Eventos independientes: multiplicas.'),
    qMC('En una urna con 3 rojas y 2 azules, P(sacar roja O azul en 1 intento):', ['1 (100%, porque son todos los resultados posibles)','3/5','2/5','1/5'], 0, 'Todos los eventos posibles = probabilidad 1. Seguro que saldrá roja o azul.'),
    qTF('Para eventos mutuamente excluyentes A y B: P(A y B) = 0.', true, 'Si son mutuamente excluyentes NO pueden pasar juntos, por lo tanto P(A y B)=0.'),
    qOrder('Ordena los pasos para calcular P(sacar 2 águilas en 2 volados):', ['Identificar eventos independientes','P(águila en 1er volado)=1/2','P(águila en 2do volado)=1/2','Multiplicar: 1/2×1/2=1/4=25%'], 'Probabilidad compuesta independiente: siempre multiplica.'),
    qMatch('Relaciona la operación con el tipo de probabilidad:', [{left:'A Y B (independientes)',right:'P(A)×P(B)'},{left:'A O B (mut. excluyentes)',right:'P(A)+P(B)'},{left:'A O B (NO excluyentes)',right:'P(A)+P(B)-P(A y B)'},{left:'Evento complementario de A',right:'1 - P(A)'}], 'Cada combinación lógica (Y, O) tiene su fórmula probabilística propia.'),
    qMC('P(no sacar 6 en un dado) =', ['1 - 1/6 = 5/6 ≈ 83.3%','1/6','0','6/6=1'], 0, 'Evento complementario. Si P(éxito)=1/6, P(fracaso)=5/6.'),
    qWrite('P(sacar rey Y que sea de corazones en 1 sola carta):', ['1/52'], 'Solo existe el rey de corazones, 1 de 52.'),
    qWrite('P(sacar rey Y que sea de corazones en 1 carta):', ['1/52'], 'Solo existe el rey de corazones.'),
  ],

  // ===== M51: Números positivos y negativos - Introducción =====
  [
    qMC('Los números negativos representan:', ['Cantidades por DEBAJO de CERO (deudas, temperaturas bajo cero, profundidades)','Números más grandes','No existen','Solo son para matemáticas avanzadas'], 0, 'Los negativos aparecen en la vida real: -5°C (hiela), -$200 (debo dinero), -10 m (bajo nivel del mar).'),
    qMC('El cero en la recta numérica es:', ['El punto de REFERENCIA que separa positivos (derecha) de negativos (izquierda)','Un número positivo','Un número negativo','No es un número'], 0, 'Cero = origen. Derecha = números más grandes (positivos). Izquierda = números más pequeños (negativos).'),
    qMC('¿Qué número es MENOR: -8 o -3?', ['-8 es MENOR (está más a la IZQUIERDA en la recta)','-3 es menor','Son iguales','No se puede comparar'], 0, 'Más negativo = más pequeño. -8 < -3. Debo $8 es peor que deber $3.'),
    qMC('El valor absoluto de un número es:', ['Su DISTANCIA al cero (siempre positivo). |-5| = 5','El número con signo contrario','El doble','La mitad'], 0, 'Valor absoluto ignora el signo. |-8| = 8, |5| = 5. Distancias siempre son positivas.'),
    qMC('Números SIMÉTRICOS u OPUESTOS:', ['Tienen el MISMO valor absoluto pero signo contrario. Opuesto de 7 es -7','Son el mismo número','No existen','Suman cero'], 0, '7 y -7 son simétricos respecto al cero. Su suma = 0. Distancia al cero = 7 en ambos.'),
    qMC('Los números ENTEROS incluyen:', ['Positivos, negativos y el CERO (..., -3, -2, -1, 0, 1, 2, 3, ...)','Solo positivos','Solo negativos','Solo el cero'], 0, 'ℤ = {..., -3, -2, -1, 0, 1, 2, 3, ...}. Conjunto de los números enteros.'),
    qTF('-5 es mayor que -10.', true, '-5 está a la DERECHA de -10 en la recta numérica. Entre más negativo, menor es el número. -5 > -10.'),
    qOrder('Ordena estos números de MENOR a MAYOR:', ['-12','-5','0','3','8'], 'En la recta numérica: izquierda (menor) a derecha (mayor).'),
    qMatch('Relaciona cada situación con el número entero que la representa:', [{left:'Deber $50',right:'-50'},{left:'Subir 3 pisos',right:'+3'},{left:'5°C bajo cero',right:'-5'},{left:'Nivel del mar',right:'0'}], 'Los enteros modelan situaciones cotidianas con dos direcciones opuestas.'),
    qMC('¿Cuál es el valor absoluto de -15?', ['15','-15','0','30'], 0, '|-15|=15. El valor absoluto elimina el signo: es la distancia al cero.'),
    qWrite('¿Qué número es MENOR: -15 o -3?', ['-15','menos quince'], 'En la recta, -15 está más a la izquierda.'),
    qWrite('¿Qué número es MENOR: -15 o -3?', ['-15','menos quince'], 'Más a la izquierda en la recta.'),
  ],

  // ===== M52: Suma con números enteros =====
  [
    qMC('Para sumar 5 + (-3):', ['5 + (-3) = 2 (avanzas 5 a la derecha, retrocedes 3 = llegas a 2)','5 + (-3) = 8','5 + (-3) = -8','5 + (-3) = -2'], 0, 'Sumar un negativo = RESTAR. 5+(-3) = 5-3 = 2.'),
    qMC('Sumar (-4) + (-6):', ['-4+(-6) = -10 (debo 4, debo 6 = debo 10)','-4+(-6) = 2','-4+(-6) = 10','-4+(-6) = -2'], 0, 'Signos iguales se suman y se conserva el signo. Ambas deudas se acumulan.'),
    qMC('(-3) + 7 =', ['4 (retrocedo 3, avanzo 7 = llego a 4)','-4','-10','10'], 0, 'De deuda 3 a tener 7 = ganancia neta de 4. Signos diferentes: resta valores absolutos, signo del mayor.'),
    qMC('(-8) + 5 =', ['-3 (más deuda que saldo)','3','13','-13'], 0, 'Valores absolutos: 8 y 5, diferencia=3. Signo del mayor (8): negativo. Resultado: -3.'),
    qMC('(+10) + (-10) =', ['0 (son opuestos, se anulan)','20','-20','-10'], 0, 'Suma de opuestos = cero. Elemento inverso aditivo.'),
    qMC('Para sumar varios enteros rápidamente: (-5)+(+12)+(-8)+(-2) =', ['-3 (agrupa positivos 12, negativos -5-8-2=-15. 12-15=-3)','17','3','0'], 0, 'Estrategia mental: suma positivos aparte, negativos aparte, luego combina.'),
    qTF('Sumar un número negativo equivale a RESTAR su valor absoluto.', true, 'a + (-b) = a - b. 8+(-3)=8-3=5.'),
    qOrder('Ordena los pasos para sumar (-7) + (+10) + (-3):', ['Sumar positivos: 10','Sumar negativos: -7+(-3)=-10','Combinar: 10 + (-10) = 0','Resultado: 0'], 'Estrategia de agrupación para simplificar sumas con múltiples enteros.'),
    qMatch('Relaciona cada suma de enteros con su resultado:', [{left:'6 + (-9)',right:'-3'},{left:'(-4) + (-5)',right:'-9'},{left:'(-2) + 8',right:'6'},{left:'15 + (-15)',right:'0'}], 'Dominar las reglas de signos permite operar con confianza en problemas reales.'),
    qMC('Un buzo desciende 15 m (hasta -15) y luego sube 8 m. Su posición final:', ['-7 metros (15m bajo, subió 8 = 7m bajo nivel del mar)','-23 m','+7 m','+23 m'], 0, '-15 + (+8) = -7 m. Problema de profundidades con enteros.'),
    qWrite('Calcula: (-20) + 8 - (-4) =?', ['-8'], '-20+8+4 = -8.'),
    qWrite('Calcula: (-20) + 8 - (-4) =?', ['-8'], '-20+8+4 = -8.'),
  ],

  // ===== M53: Resta con números enteros =====
  [
    qMC('Restar un número negativo: 8 - (-3):', ['8 - (-3) = 8 + 3 = 11','8 - (-3) = 5','8 - (-3) = -5','8 - (-3) = -11'], 0, 'Restar un negativo = SUMAR. -(-3) = +3. "Quitar una deuda" es ganancia.'),
    qMC('La regla para restar enteros es:', ['a - b = a + (opuesto de b). Restar = sumar el OPUESTO','Siempre se restan los valores absolutos','No hay regla','Depende del número'], 0, 'Transforma toda resta en suma: cambia el signo del sustraendo. 5-(-3)=5+3=8.'),
    qMC('(-6) - (+2) =', ['-8','-4','4','8'], 0, '(-6) - (+2) = (-6) + (-2) = -8. Restar 2 = sumar -2.'),
    qMC('4 - 9 =', ['-5','5','13','-13'], 0, '4-9 = 4+(-9) = -5. El resultado puede ser negativo aunque empieces con positivo.'),
    qMC('(-3) - (-7) =', ['4','-4','-10','10'], 0, '(-3)-(-7)=(-3)+7=4. Restar -7 es sumar 7.'),
    qMC('Diferencia entre -5°C y -12°C:', ['7°C (distancia entre ellos: |-5 - (-12)| = |7| = 7)','-17°C','17°C','-7°C'], 0, 'Diferencia = valor absoluto de la resta. |(-5)-(-12)|=|7|=7°C de diferencia.'),
    qTF('Restar un número es equivalente a sumar su opuesto.', true, 'a - b = a + (-b). Esta regla unifica suma y resta de enteros.'),
    qOrder('Ordena los pasos para resolver 10 - (+3) - (-5):', ['Convertir resta en suma: 10 + (-3) + (+5)','Sumar paso a paso: 10+(-3)=7','7+5=12','Resultado: 12'], 'Método: cada resta → suma del opuesto. Luego operas normalmente.'),
    qMatch('Relaciona cada resta con su resultado:', [{left:'5 - (-8)',right:'13'},{left:'(-4) - (+6)',right:'-10'},{left:'(-2) - (-9)',right:'7'},{left:'0 - (+7)',right:'-7'}], 'Restar enteros es sencillo si recuerdas: cambia el signo y suma.'),
    qMC('Temperatura actual: -3°C. Si BAJA otros 5°, la nueva temperatura es:', ['-8°C (-3 - 5 = -3 + (-5) = -8)','+2°C','-2°C','+8°C'], 0, 'Bajar la temperatura = restar grados. -3 - 5 = -8. Más frío aún.'),
    qWrite('Resuelve: 0 - (-12) =?', ['12'], 'Restar -12 = sumar 12.'),
    qWrite('Resuelve: 0 - (-12) =?', ['12'], 'Restar -12 = sumar 12.'),
  ],

  // ===== M54: Multiplicación con números enteros =====
  [
    qMC('La regla de signos para multiplicar: POSITIVO × NEGATIVO =', ['NEGATIVO. (+5)×(-3) = -15','POSITIVO','CERO','Depende'], 0, 'Signos DIFERENTES → producto NEGATIVO.'),
    qMC('NEGATIVO × NEGATIVO =', ['POSITIVO. (-4)×(-3) = +12','NEGATIVO','CERO','Depende'], 0, 'Signos IGUALES → producto POSITIVO. "Menos por menos = más."'),
    qMC('¿Por qué (-2)×(-5)=+10?', ['Pierdes una deuda de 5, dos veces = ganas 10. O: es el opuesto de 2×(-5)','Es porque sí','No hay razón','No es cierto'], 0, 'Interpretación: quitar una deuda repetidas veces es como ganar dinero. Matemáticamente consistente.'),
    qMC('Multiplicar por -1:', ['CAMBIA el signo del número. (-1)×8=-8, (-1)×(-7)=7','No hace nada','Duplica','Divide'], 0, '-1 es el "cambiador de signo". Su efecto es dar el número opuesto.'),
    qMC('(-3)×(-2)×(-4) =', ['-24 (impar de negativos → negativo)','+24','-9','12'], 0, 'Tres negativos = número IMPAR → negativo. (3×2×4=24, con signo -).'),
    qMC('Para saber el signo final de una multiplicación:', ['Cuenta el número de factores NEGATIVOS. PAR → positivo, IMPAR → negativo','Siempre es positivo','Siempre es negativo','No importa'], 0, 'Regla mnemotécnica: par de negativos se cancelan. Impar deja uno negativo.'),
    qTF('(+7)×(-3) = -21.', true, 'Signo diferente → negativo. 7×3=21 con signo -. Correcto.'),
    qOrder('Ordena los pasos para calcular (-2)×(+5)×(-3)×(-1):', ['Identificar signos: 2 negativos, 2 positivos (pero -1 es negativo)','Contar negativos: -2, -3, -1 = 3 negativos','IMPAR de negativos → resultado NEGATIVO','Multiplicar valores absolutos: 2×5×3×1=30','Resultado: -30'], 'Sistemático: primero determina el signo, luego multiplica los valores absolutos.'),
    qMatch('Relaciona cada multiplicación con su resultado:', [{left:'6×(-4)',right:'-24'},{left:'(-5)×(-7)',right:'35'},{left:'(-8)×3',right:'-24'},{left:'(-2)×(-2)×(-2)',right:'-8'}], 'La regla de signos es una de las herramientas más poderosas del álgebra.'),
    qMC('Si debes $15 a cada uno de 4 amigos, tu deuda total se expresa como:', ['4 × (-15) = -$60 (deuda total)','4 × 15 = $60','-4 × 15 = -$60','15 - 4 = $11'], 0, 'Modelado: personas × deuda individual = 4×(-15)=-$60.'),
    qWrite('¿Cuánto es (-7) × (-2) × (-1)?', ['-14'], '3 negativos (impar) → resultado negativo.'),
    qWrite('¿Cuánto es (-7) × (-2) × (-1)?', ['-14'], '3 negativos (impar) → negativo.'),
  ],

  // ===== M55: División con números enteros =====
  [
    qMC('Las reglas de signos para división:', ['Son las MISMAS que para multiplicación. Signos iguales→positivo, diferentes→negativo','Son diferentes','No aplican','Siempre positivo'], 0, 'División y multiplicación comparten reglas de signo. (+12)÷(-3)=-4. (-15)÷(-5)=3.'),
    qMC('(+24) ÷ (-6) =', ['-4','+4','6','-6'], 0, 'Signo diferente → negativo. 24÷6=4 con signo - → -4.'),
    qMC('(-30) ÷ (-5) =', ['6','-6','-25','25'], 0, 'Signos iguales → positivo. 30÷5=6.'),
    qMC('La división NO es conmutativa:', ['(+8) ÷ (-2) = -4, pero (-2) ÷ (+8) = -0.25','Sí es conmutativa','No importa el orden','Depende'], 0, 'El orden IMPORTA en división. No comparte esa propiedad con la multiplicación.'),
    qMC('(-48) ÷ (+8) =', ['-6','+6','-48','+48'], 0, 'Signos diferentes → negativo. 48÷8=6 con signo -.'),
    qMC('Para dividir números grandes con signos: (-120) ÷ (-15):', ['Ignora signos: 120÷15=8. Signos iguales: +8','-8','15','No se puede'], 0, 'Método: 1) divide valores absolutos, 2) aplica regla de signos al resultado.'),
    qTF('(-100) ÷ (+25) = -4.', true, 'Signos diferentes → negativo. 100÷25=4 → -4. Correcto.'),
    qOrder('Ordena los pasos para resolver (-72) ÷ (+9) ÷ (-2):', ['Primera división: (-72)÷(+9)=-8 (signos diferentes)','Segunda división: (-8)÷(-2)=4 (signos iguales→positivo)','Resultado final: 4'], 'En división secuencial, aplica las reglas de signo en CADA paso.'),
    qMatch('Relaciona cada división de enteros con su cociente:', [{left:'(+36)÷(-4)',right:'-9'},{left:'(-50)÷(-10)',right:'5'},{left:'(-81)÷(+9)',right:'-9'},{left:'(+64)÷(-8)',right:'-8'}], 'La división con enteros es directa si dominas las reglas de signos.'),
    qMC('Un submarino desciende 120 metros en 6 minutos a ritmo constante. Velocidad de descenso:', ['-20 metros/minuto (120÷6=20, descenso es negativo)','+20 m/min','-120 m/min','+6 m/min'], 0, 'Descenso = cambio negativo. -120÷6 = -20 m/min. Baja 20 metros cada minuto.'),
    qWrite('Calcula: (-144) ÷ 12 =?', ['-12'], '144÷12=12. Signos diferentes → -12.'),
    qWrite('Calcula: (-144) ÷ 12 =?', ['-12'], '144÷12=12. Diferente signo → -12.'),
  ],

  // ===== M56: Múltiplos =====
  [
    qMC('Un múltiplo de un número es:', ['El resultado de MULTIPLICAR ese número por cualquier entero positivo','El número dividido','El número sumado','Un número primo'], 0, 'Múltiplos de 3: 3, 6, 9, 12, 15... (3×1, 3×2, 3×3...). Infinitos.'),
    qMC('¿Es 48 múltiplo de 6?', ['SÍ, porque 6×8=48','NO, no es múltiplo','Depende','Solo si es par'], 0, '48÷6=8 exacto. Si la división es exacta, es múltiplo.'),
    qMC('Los primeros 5 múltiplos de 7 son:', ['7, 14, 21, 28, 35 (7×1 al 7×5)','7, 17, 27, 37, 47','1, 7, 14, 21, 28','No existen'], 0, 'Secuencia de múltiplos naturales: n×1, n×2, n×3...'),
    qMC('¿55 es múltiplo de 11?', ['SÍ (11×5=55)','NO','A veces','Solo los pares'], 0, '55÷11=5 exacto. Es múltiplo.'),
    qMC('Los múltiplos de 2 se llaman:', ['Números PARES','Números impares','Números primos','Números compuestos'], 0, 'Todo múltiplo de 2 es par: 2, 4, 6, 8, 10... Terminan en 0, 2, 4, 6 u 8.'),
    qMC('Cero es múltiplo de cualquier número:', ['SÍ, 0 = n×0 para cualquier n. Pero no se considera en secuencias naturales','NO','Solo de algunos números','Depende'], 0, 'Técnicamente 0 es múltiplo de todo número (n×0=0), pero al listar múltiplos naturales empezamos desde ×1.'),
    qTF('Los múltiplos de un número son INFINITOS.', true, 'Siempre puedes multiplicar por un entero más grande. Para 5: 5, 10, 15... hasta donde quieras.'),
    qOrder('Ordena estos números según sean múltiplos de 3:', ['9 (3×3)','15 (3×5)','21 (3×7)','30 (3×10)','100 (NO es múltiplo, 100÷3=33.33)'], 'Verifica: ¿la división es exacta? Si tiene residuo, no es múltiplo.'),
    qMatch('Relaciona cada número con el conjunto de sus primeros múltiplos:', [{left:'4',right:'4, 8, 12, 16, 20...'},{left:'6',right:'6, 12, 18, 24, 30...'},{left:'9',right:'9, 18, 27, 36, 45...'},{left:'12',right:'12, 24, 36, 48, 60...'}], 'Observa: hay números que aparecen en varias listas = múltiplos COMUNES.'),
    qMC('Los múltiplos comunes de 4 y 6 incluyen:', ['12, 24, 36, 48... (números que están en AMBAS tablas)','Solo 4','Solo 6','No existen'], 0, 'intersección de las dos listas de múltiplos. El menor es el mcm (mínimo común múltiplo).'),
    qWrite('¿Es 96 múltiplo de 8? Responde Sí o No', ['si','sí'], '96÷8=12 exacto. Sí.'),
    qWrite('¿Es 96 múltiplo de 8? Responde Sí o No', ['si','sí'], '96÷8=12 exacto. Sí.'),
  ],

  // ===== M57: Divisores =====
  [
    qMC('Un divisor de un número es:', ['Un número que lo divide EXACTAMENTE (residuo CERO)','Un número mayor','Solo el número mismo','Cualquier número'], 0, 'Divisores de 12: 1, 2, 3, 4, 6, 12. Todos dividen exactamente a 12.'),
    qMC('Los divisores de 15 son:', ['1, 3, 5, 15','1, 2, 3, 5','Solo 1 y 15','3 y 5'], 0, '15÷1=15, 15÷3=5, 15÷5=3, 15÷15=1. Exactamente 4 divisores.'),
    qMC('TODO número es divisible entre:', ['1 y entre SÍ MISMO','Solo 1','Solo sí mismo','Ninguno'], 0, 'Los divisores triviales: 1 y el propio número. Siempre existen.'),
    qMC('¿Cuántos divisores tiene el número 36?', ['9 divisores (1,2,3,4,6,9,12,18,36)','6 divisores','12 divisores','4 divisores'], 0, 'Lista completa: 1,2,3,4,6,9,12,18,36. Nueve en total.'),
    qMC('Un número PRIMO tiene:', ['Exactamente DOS divisores: 1 y él mismo','Muchos divisores','Ningún divisor','Un solo divisor'], 0, 'Primo: solo divisible entre 1 y sí mismo. 2, 3, 5, 7, 11, 13, 17, 19, 23...'),
    qMC('Un número COMPUESTO tiene:', ['Más de DOS divisores','Exactamente 2 divisores','Ningún divisor','Es primo'], 0, 'Compuesto = tiene al menos un divisor no trivial. 4, 6, 8, 9, 10, 12...'),
    qTF('El número 1 NO es primo ni compuesto.', true, '1 tiene solo UN divisor (él mismo). Por definición no califica como primo (necesita 2 divisores) ni compuesto (más de 2).'),
    qOrder('Ordena los pasos para encontrar TODOS los divisores de 24:', ['Probar división con 1: 24÷1=24 ✓','Probar con 2: 24÷2=12 ✓','Probar con 3: 24÷3=8 ✓','Probar con 4: 24÷4=6 ✓','Probar con 6: Ya lo tenemos (es el par de 4)','Lista completa: 1,2,3,4,6,8,12,24'], 'Busca hasta la raíz cuadrada del número. Los demás divisores son los pares complementarios.'),
    qMatch('Relaciona cada número con su cantidad de divisores:', [{left:'7 (primo)',right:'2 divisores (1 y 7)'},{left:'10',right:'4 divisores (1,2,5,10)'},{left:'16',right:'5 divisores (1,2,4,8,16)'},{left:'30',right:'8 divisores (1,2,3,5,6,10,15,30)'}], 'Contar divisores ayuda a clasificar números y resolver problemas de agrupación.'),
    qMC('Si 48 se reparte en grupos iguales, ¿de qué tamaños pueden ser?', ['Grupos de 1,2,3,4,6,8,12,16,24,48 (todos los divisores de 48)','Solo de 2','Solo de 48','Grupos de 5'], 0, 'Los divisores determinan formas posibles de agrupar o repartir sin que sobre nada.'),
    qWrite('¿Cuántos divisores tiene el número 25?', ['3','tres'], '1, 5, 25. Tres divisores.'),
    qWrite('¿Cuántos divisores tiene el número 25?', ['3','tres'], '1, 5, 25. Tres divisores.'),
  ],

  // ===== M58: Criterios de divisibilidad =====
  [
    qMC('Un número es divisible entre 2 si:', ['Termina en 0, 2, 4, 6 u 8 (es PAR)','Termina en 1, 3, 5, 7, 9','Cualquier número','Solo si es 2'], 0, 'Criterio más simple: mira el último dígito. 346 es par (termina en 6), 581 no lo es.'),
    qMC('Un número es divisible entre 3 si:', ['La SUMA de sus dígitos es divisible entre 3','Termina en 3, 6 o 9','Es múltiplo de 6','Solo el número 3'], 0, 'Ej: 471 → 4+7+1=12, 12÷3=4 → SÍ es divisible.'),
    qMC('¿Es 1,245 divisible entre 5?', ['SÍ, porque termina en 5','NO','Solo si es 10','Depende'], 0, 'Criterio de 5: termina en 0 o 5. 1,245 termina en 5 → SÍ.'),
    qMC('Un número es divisible entre 4 si:', ['Sus ÚLTIMOS 2 dígitos forman un múltiplo de 4','Termina en 4','Es par','Suma sus dígitos da 4'], 0, 'Ej: 2,316 → 16 es múltiplo de 4 → SÍ es divisible. 2,322 → 22 no es múltiplo de 4 → NO.'),
    qMC('Para saber si un número es divisible entre 6:', ['Debe ser divisible entre 2 Y entre 3 SIMULTÁNEAMENTE','Solo si termina en 6','Todos los números','Solo si es par'], 0, '6=2×3. 132: sí es par (÷2) y 1+3+2=6 (÷3) → SÍ es divisible entre 6.'),
    qMC('El criterio más potente para 9:', ['La SUMA de sus dígitos debe ser divisible entre 9','Terminar en 9','Ser múltiplo de 3','Ninguno'], 0, 'Similar al 3 pero más estricto. 6,381 → 6+3+8+1=18, 18÷9=2 → SÍ. 1,236 → 1+2+3+6=12, 12÷9 no exacto → NO.'),
    qTF('Para saber si un número es divisible entre 10, debe terminar en 0.', true, 'Criterio más fácil: termina en 0 → divisible entre 10. 520 sí, 525 no.'),
    qOrder('Ordena los criterios de divisibilidad por frecuencia de uso:', ['Entre 2: último dígito par','Entre 3: suma de dígitos ÷3','Entre 5: termina en 0 o 5','Entre 10: termina en 0','Entre 4: últimos 2 dígitos ÷4'], 'Dominar estos criterios ahorra tiempo en divisiones y simplificación de fracciones.'),
    qMatch('Relaciona cada número con el criterio que lo hace divisible:', [{left:'846 (par, suma=18)',right:'Divisible entre 2, 3, 6, 9'},{left:'1,735 (termina en 5)',right:'Divisible entre 5'},{left:'9,876 (últimos 2 díg: 76=4×19)',right:'Divisible entre 4'},{left:'4,320 (termina en 0)',right:'Divisible entre 2,3,4,5,6,9,10'}], 'Algunos números "estrella" son divisibles entre muchos números. Muy útiles.'),
    qMC('¿Es 7,281 divisible entre 3?', ['SÍ (7+2+8+1=18, 18÷3=6)','NO','Solo a veces','Depende'], 0, 'Suma=18 → múltiplo de 3 → SÍ.'),
    qWrite('¿Es 2475 divisible entre 9? Suma sus dígitos.', ['si','sí'], '2+4+7+5=18, 18÷9=2. Sí.'),
    qWrite('¿Es 2475 divisible entre 9? Suma sus dígitos.', ['si','sí'], '2+4+7+5=18, 18÷9=2. Sí.'),
  ],

  // ===== M59: MCD (Máximo Común Divisor) =====
  [
    qMC('El MCD de dos o más números es:', ['El MAYOR número que divide EXACTAMENTE a todos ellos','El más pequeño','La suma','El producto'], 0, 'MCD(12,18)=6. 6 es el máximo número que divide a 12 y 18 exactamente.'),
    qMC('Para calcular MCD(24, 36):', ['Divisores de 24: 1,2,3,4,6,8,12,24. De 36: 1,2,3,4,6,9,12,18,36. Comunes: 1,2,3,4,6,12. MCD=12','Sumas los números','Multiplicas','Siempre es 1'], 0, 'Método por lista: encuentra divisores, identifica comunes, toma el mayor.'),
    qMC('MCD(15, 28) =', ['1 (son coprimos, no comparten divisores >1)','3','5','7'], 0, '15 y 28 no comparten divisores (15:1,3,5,15; 28:1,2,4,7,14,28). Solo 1 en común → MCD=1.'),
    qMC('El método de DESCOMPOSICIÓN para MCD:', ['Descomponer ambos números en factores PRIMOS. MCD = producto de factores COMUNES con MENOR exponente','Solo descomponer uno','No se usa','Es lo mismo que sumar'], 0, 'Ej: 12=2²×3, 18=2×3². Comunes: 2¹ y 3¹. MCD=2×3=6.'),
    qMC('MCD(20, 30, 50):', ['10 (factores comunes: 2×5=10)','5','20','50'], 0, 'Descomposición: 20=2²×5, 30=2×3×5, 50=2×5². Comunes: 2¹×5¹=10.'),
    qMC('Si MCD(a,b)=1, los números se llaman:', ['COPRIMOS o primos entre sí','Números compuestos','Múltiplos','Iguales'], 0, 'Coprimos: su único divisor común es 1. 8 y 9 son coprimos. 14 y 21 no (MCD=7).'),
    qTF('El MCD de dos números NUNCA puede ser mayor que el menor de ellos.', true, 'MCD ≤ menor de los números. Debe dividir exactamente a ambos.'),
    qOrder('Ordena los pasos para calcular MCD(48, 72) por descomposición:', ['Descomponer 48 = 2⁴ × 3','Descomponer 72 = 2³ × 3²','Identificar comunes: 2³ y 3¹','Multiplicar: 2³×3 = 8×3 = 24','MCD = 24'], 'Método de factores primos: rápido y escalable para números grandes.'),
    qMatch('Relaciona cada par de números con su MCD:', [{left:'12 y 18',right:'6'},{left:'25 y 35',right:'5'},{left:'48 y 80',right:'16'},{left:'9 y 16',right:'1 (coprimos)'}], 'El MCD se usa para simplificar fracciones y repartir cosas en grupos iguales.'),
    qMC('Para hacer equipos mixtos iguales con 24 niños y 36 niñas, el MCD da:', ['Equipos de 12 personas (MCD=12)','Equipos de 6','Equipos de 24','Equipos de 36'], 0, 'MCD(24,36)=12. Máximo tamaño de equipos con igual número de niños y niñas por equipo.'),
    qWrite('MCD(100, 75) =?', ['25'], '100=2²×5², 75=3×5². MCD=5²=25.'),
    qWrite('MCD(100, 75) =?', ['25'], '100=2²×5², 75=3×5². MCD=5²=25.'),
  ],

  // ===== M60: mcm (Mínimo Común Múltiplo) =====
  [
    qMC('El mcm de dos o más números es:', ['El MENOR múltiplo COMÚN (el número más pequeño que es múltiplo de todos)','El mayor divisor','La suma','El producto'], 0, 'mcm(4,6)=12. 12 es el menor número que está en las listas de múltiplos de 4 y 6.'),
    qMC('mcm(5, 7) =', ['35 (5×7, porque son coprimos)','12','70','1'], 0, 'Si son coprimos: mcm = producto. 5×7=35.'),
    qMC('La RELACIÓN MCD × mcm = :', ['MCD(a,b) × mcm(a,b) = a × b (propiedad fundamental)','a + b','a - b','No existe relación'], 0, 'Verifica: MCD(12,18)=6, mcm(12,18)=36. 6×36=216. 12×18=216. ¡Cumple!'),
    qMC('Para mcm por DESCOMPOSICIÓN:', ['Descomponer en factores PRIMOS. mcm = producto de TODOS los factores con MAYOR exponente','Solo un número','Menor exponente','No se usa'], 0, 'Ej: 12=2²×3, 18=2×3². mcm = 2²×3² = 4×9 = 36. Factores comunes y no comunes con mayor exponente.'),
    qMC('mcm(8, 12, 15):', ['120 (8=2³, 12=2²×3, 15=3×5. mcm=2³×3×5=120)','60','24','30'], 0, 'Toma todos los factores primos con su mayor exponente.'),
    qMC('El mcm se usa para:', ['Sumar fracciones con distinto denominador (buscar denominador común)','Sumar enteros','Multiplicar','Dividir'], 0, 'Ej: 1/4+1/6. mcm(4,6)=12. Conviertes ambas a doceavos.'),
    qTF('El mcm de dos números SIEMPRE es al menos tan grande como el mayor de ellos.', true, 'mcm ≥ mayor de los números. Debe ser múltiplo de ambos.'),
    qOrder('Ordena los pasos para calcular mcm(15, 20, 30) por descomposición:', ['Descomponer: 15=3×5, 20=2²×5, 30=2×3×5','Identificar todos los factores: 2, 3, 5','Tomar mayor exponente de cada uno: 2²=4, 3¹=3, 5¹=5','Multiplicar: 4×3×5=60','mcm = 60'], 'Método sistemático de factores primos: el más confiable.'),
    qMatch('Relaciona cada par con su mcm:', [{left:'6 y 8',right:'24'},{left:'10 y 15',right:'30'},{left:'9 y 12',right:'36'},{left:'7 y 11',right:'77 (producto, son coprimos)'}], 'El mcm aparece constantemente en problemas de sincronización y ciclos.'),
    qMC('Dos autobuses salen juntos. Uno cada 15 min, otro cada 20 min. ¿Cada cuánto coinciden?', ['Cada 60 minutos (mcm(15,20)=60)','Cada 35 min','Cada 120 min','Cada 300 min'], 0, 'mcm(15,20)=60 min = 1 hora. Problema clásico de ciclos y sincronización.'),
    qWrite('mcm(11, 13) =? (Son primos)', ['143'], '11×13=143. Son coprimos.'),
    qWrite('mcm(11, 13) =? (Son primos)', ['143'], '11×13=143. Son coprimos.'),
  ],

  // ===== M61: Razón entre dos cantidades =====
  [
    qMC('Una RAZÓN es:', ['La COMPARACIÓN de dos cantidades mediante división (a:b o a/b)','Una suma','Una opinión','Una resta'], 0, 'Razón = cociente entre dos números. Ej: en un salón 15 niños y 10 niñas, razón niños:niñas = 15/10 = 3/2.'),
    qMC('La razón "2 de cada 5" se escribe como:', ['2/5 o 2:5','5/2','2+5','5×2'], 0, 'Notación: a/b o a:b. Ambas significan lo mismo.'),
    qMC('En una receta: 3 tazas de harina por 2 de azúcar. La razón harina:azúcar es:', ['3:2 (o 3/2 = 1.5)','2:3','3+2=5','3×2=6'], 0, 'Por cada 3 de harina, 2 de azúcar. La razón compara las cantidades relativas.'),
    qMC('Razón de 45 km en 3 horas:', ['15 km/h (45÷3)','45 km/h','3 km/h','135 km/h'], 0, 'Razón = velocidad promedio: distancia/tiempo.'),
    qMC('La razón áurea o número de oro (φ ≈ 1.618) aparece en:', ['La naturaleza (conchas, girasoles) y el arte (Leonardo da Vinci)','Solo en matemáticas','No existe','Solo en libros'], 0, 'φ = (1+√5)/2 ≈ 1.618. Proporción estética encontrada en el Partenón, La Gioconda y caracoles.'),
    qMC('Razón equivalente a 2/5:', ['4/10 = 6/15 = 8/20 (multiplicando ambos términos por el mismo número)','2/5×2 = 4/5','No tiene equivalentes','50%'], 0, 'Multiplica numerador y denominador por el mismo número.'),
    qTF('Una razón siempre compara dos cantidades de la MISMA unidad.', false, 'Pueden ser de distinta unidad. Km/h (distancia y tiempo), $/kg (dinero y masa).'),
    qOrder('Ordena los pasos para simplificar la razón 24:36:', ['Encontrar MCD(24,36)=12','Dividir ambos: 24÷12=2, 36÷12=3','Razón simplificada: 2:3'], 'Simplificar una razón = dividir ambos términos entre su MCD.'),
    qMatch('Relaciona cada situación con su razón:', [{left:'20 caramelos para 4 niños',right:'5 caramelos por niño (5:1)'},{left:'60 km en 2 horas',right:'30 km/h'},{left:'$150 por 3 kg',right:'$50/kg'},{left:'6 de cada 10 votos',right:'3/5 = 60%'}], 'Las razones aparecen en velocidad, precio unitario, proporciones y estadísticas.'),
    qMC('La densidad de población (hab/km²) es un ejemplo de razón:', ['Entre habitantes y kilómetros cuadrados, con unidades DIFERENTES','Solo números iguales','No es razón','Siempre 1'], 0, 'CDMX: ≈6,000 hab/km². La Paz BCS: mucho menor. Razones nos ayudan a comparar.'),
    qWrite('La razón 3:8 como decimal es:', ['0.375'], '3÷8=0.375.'),
    qWrite('La razón 3:8 como decimal:', ['0.375'], '3÷8=0.375.'),
  ],

  // ===== M62: Proporciones =====
  [
    qMC('Una PROPORCIÓN es:', ['La IGUALDAD entre DOS razones (a/b = c/d)','Una sola razón','Una suma','No existe'], 0, 'Ej: 1/2 = 3/6. Ambas razones representan la misma parte del todo.'),
    qMC('En la proporción 3/5 = 9/15, el producto cruzado:', ['3×15 = 5×9 = 45 (propiedad fundamental de proporciones)','3×9 = 5×15','3+15 = 5+9','No hay producto'], 0, 'En a/b = c/d: a×d = b×c. Producto de extremos = producto de medios.'),
    qMC('Para verificar si 4/10 = 6/15 forman proporción:', ['4×15=60, 10×6=60. Sí, son proporcionales','No se puede','No son proporcionales','Depende'], 0, 'Productos cruzados iguales = proporción verdadera.'),
    qMC('¿Cuál es el valor de x en x/8 = 3/4?', ['x = 6 (producto cruzado: 4x = 24, x=6)','x = 8','x = 4','x = 2'], 0, '4x = 24 → x = 6. Verifica: 6/8 = 3/4 ✓.'),
    qMC('En una proporción, "extremos" y "medios":', ['En a:b::c:d: a y d son EXTREMOS, b y c son MEDIOS. a×d=b×c','Son lo mismo','No existen','Solo en libros'], 0, 'Notación antigua: "a es a b como c es a d". Propiedad: extremos × extremos = medios × medios.'),
    qMC('Para encontrar el cuarto proporcional: 6/9 = ?/12:', ['6×12/9 = 72/9 = 8','4','12','6'], 0, 'Despeja usando producto cruzado: 6×12 = 9x → 72=9x → x=8.'),
    qTF('En una proporción, el producto de los extremos SIEMPRE es igual al producto de los medios.', true, 'Propiedad fundamental: a/b = c/d ⇔ a×d = b×c.'),
    qOrder('Ordena los pasos para resolver 15/x = 5/3:', ['Producto cruzado: 15×3 = 5×x','45 = 5x','Dividir: x = 45÷5 = 9','Verificar: 15/9 = 5/3 → 15×3=45, 9×5=45 ✓'], 'Método confiable: producto de extremos = producto de medios.'),
    qMatch('Relaciona cada proporción con la x faltante:', [{left:'2/3 = x/9',right:'x=6'},{left:'x/4 = 5/10',right:'x=2'},{left:'8/12 = 10/x',right:'x=15'},{left:'3/x = 9/15',right:'x=5'}], 'Resolver proporciones con el método de producto cruzado.'),
    qMC('La proporcionalidad se aplica en:', ['Escalas de mapas, recetas de cocina, fotografía, arquitectura','Solo matemáticas','No se usa','Solo exámenes'], 0, 'Proporcionalidad está en todas partes: diseño, construcción, arte, ciencia.'),
    qWrite('En la proporción 4/7 = 20/x, ¿cuánto vale x?', ['35'], '4x=140 → x=35.'),
    qWrite('En proporción 4/7 = 20/x, ¿cuánto vale x?', ['35'], '4x=140 → x=35.'),
  ],

  // ===== M63: Escalas =====
  [
    qMC('La ESCALA en un mapa significa:', ['La RELACIÓN entre la distancia en el mapa y la distancia REAL en el terreno','La temperatura','La altura','No tiene significado'], 0, 'Escala 1:100,000 → 1 cm en mapa = 100,000 cm reales = 1 km.'),
    qMC('En escala 1:50,000, ¿cuántos km reales son 4 cm en el mapa?', ['2 km (4×50,000=200,000 cm = 2,000 m = 2 km)','50 km','0.2 km','20 km'], 0, 'Conversión: cm×escala = cm reales. 200,000 cm = 2 km.'),
    qMC('Una escala REDUCTORA 1:10 significa:', ['1 unidad en el dibujo = 10 unidades en la realidad (dibujo MÁS PEQUEÑO)','Lo contrario','Dibujo más grande','No existe'], 0, 'Escala 1:n → reductor (planos arquitectónicos). n:1 → ampliador (detalles, insectos).'),
    qMC('Escala AMPLIADORA 5:1:', ['5 unidades en dibujo = 1 real (muestra detalles MUY pequeños)','Dibujo más chico','No se usa','Es igual'], 0, 'Usada para ver bacterias, circuitos electrónicos, detalles de insectos.'),
    qMC('Distancia real entre CDMX y Guadalajara ≈ 550 km. En mapa 1:5,000,000, serían:', ['11 cm en el mapa','5.5 cm','55 cm','550 cm'], 0, '550 km = 55,000,000 cm. 55,000,000÷5,000,000 = 11 cm en el mapa.'),
    qMC('En un plano arquitectónico a escala 1:100, una pared de 4 m reales se dibuja:', ['4 cm en el plano','40 cm','400 cm','0.4 cm'], 0, '4m=400cm. 400÷100=4 cm. Tamaño manejable en papel.'),
    qTF('La escala 1:1 significa que el dibujo es del MISMO tamaño que el objeto real.', true, 'Escala natural 1:1. Dibujo = realidad. Usada para objetos pequeños o detalles.'),
    qOrder('Ordena los pasos para calcular la distancia real a partir de un mapa 1:250,000 donde la distancia es 8 cm:', ['Multiplicar: 8×250,000 = 2,000,000 cm','Convertir a km: 2,000,000÷100,000=20 km','Resultado: 20 km reales'], 'Conversión: cm en mapa × denominador de escala / 100,000 = km reales.'),
    qMatch('Relaciona cada escala con su uso típico:', [{left:'1:1,000,000',right:'Mapa de carretera'},{left:'1:100',right:'Plano arquitectónico de casa'},{left:'10:1',right:'Detalle de pieza mecánica'},{left:'1:10,000',right:'Plano de ciudad'}], 'La escala se elige según el tamaño del objeto y el detalle que se necesita.'),
    qMC('En un mapa de La Paz BCS, la distancia al aeropuerto es 6 cm. Escala 1:200,000. Distancia real:', ['12 km (6×200,000=1,200,000 cm=12 km)','3 km','6 km','24 km'], 0, '1,200,000 cm = 12 km. Aproximadamente la distancia real del centro al aeropuerto.'),
    qWrite('En escala 1:500,000, 3 cm en mapa = ¿km reales?', ['15'], '3×500000=1500000 cm=15 km.'),
    qWrite('En escala 1:500000, 3 cm en mapa = ¿km?', ['15'], '3×500000=1500000 cm=15 km.'),
  ],

  // ===== M64: Proporcionalidad en tablas =====
  [
    qMC('Una tabla de proporcionalidad directa:', ['Mantiene constante la RAZÓN y/x = k en cada renglón','No tiene constante','Varía aleatoriamente','Es inversa'], 0, 'Si 1kg=$20, 2kg=$40, 3kg=$60... la razón precio/masa siempre = 20.'),
    qMC('Para completar una tabla proporcional: si 2→14, entonces 5→:', ['35 (k=14÷2=7, 5×7=35)','28','70','20'], 0, 'Encuentra la constante k y multiplica.'),
    qMC('En tabla de proporcionalidad INVERSA:', ['El PRODUCTO x·y es constante (2×60=120, 4×30=120)','La suma es constante','La razón es constante','No hay patrón'], 0, 'Para inversa: x×y=k. Si x se duplica, y se reduce a la mitad.'),
    qMC('Valor faltante en tabla: x:3,5,8; y:9,?,24. Constante k=', ['k=y/x=9/3=3. Para x=5: y=5×3=15. Verifica: 24/8=3 ✓','k=3/9=1/3','No hay k','k varía'], 0, 'Identifica la constante con los datos completos y aplica a los faltantes.'),
    qMC('Una tabla representa proporcionalidad si:', ['TODOS los cocientes y/x (directa) o TODOS los productos x·y (inversa) son CONSTANTES','Es una lista cualquiera','No hay manera','Depende'], 0, 'Prueba de consistencia: si cambia la razón en algún renglón, no es proporcional.'),
    qMC('Completar: litros de pintura: 2, 5, 8; m² que cubre: 30, 75, ?:', ['120 (k=30÷2=15 m²/L. 8×15=120 m²)','100','90','80'], 0, 'Constante=15 m² por litro. Problema de cobertura de pintura.'),
    qTF('En una tabla de proporcionalidad directa, la constante k = y/x es la misma para todos los pares.', true, 'Definición de proporcionalidad directa en formato tabla. Si varía, no es proporcional.'),
    qOrder('Ordena los pasos para verificar si una tabla es directamente proporcional:', ['Calcular y/x para cada par de valores','Si todos dan el MISMO resultado → es proporcional','Si los cocientes no son iguales → NO es proporcional','La constante es ese valor común'], 'Prueba de proporcionalidad: cociente constante en todos los pares de la tabla.'),
    qMatch('Relaciona la tabla con su constante:', [{left:'x:1,2,3; y:4,8,12',right:'k=4 (4÷1,8÷2,12÷3)'},{left:'x:5,10,15; y:25,50,75',right:'k=5'},{left:'x:2,4,8; y:10,20,40',right:'k=5'},{left:'x:3,6,9; y:12,24,36',right:'k=4'}], 'Identificar la constante es el paso clave para completar tablas de proporcionalidad.'),
    qMC('Ganancia: 2 hrs=$90, 5 hrs=? (directa):', ['$225 (k=$45/h. 5×45=225)','$180','$450','$90'], 0, 'Constante = $45 por hora de trabajo.'),
    qWrite('Si constante k=9 y x=6, en proporción directa y=?', ['54'], 'y=kx=9×6=54.'),
    qWrite('Si constante k=9 y x=6, en prop. directa y=?', ['54'], 'y=kx=9×6=54.'),
  ],

  // ===== M65: Porcentajes como razones =====
  [
    qMC('El porcentaje se puede entender como:', ['Una RAZÓN con denominador 100 (25% = 25/100 = 0.25)','Un número cualquiera','Solo 50%','Una suma'], 0, 'Visión de razones: % = parte/total × 100. 25% = 25:100 = 1:4.'),
    qMC('"3 de cada 4" expresado como razón es:', ['3:4 = 3/4 = 0.75 = 75%','4:3 = 133%','3:1 = 300%','No es razón'], 0, 'Parte/total = 3/4 = 75%. Conversión fluida entre razones, fracciones y porcentajes.'),
    qMC('La razón 1:5 como porcentaje:', ['20% (1÷5=0.20=20%)','5%','50%','15%'], 0, '1 de cada 5 = 1/5 = 0.20 = 20%.'),
    qMC('Para calcular qué % es 30 de 120 (razón 30:120):', ['25% (30÷120=0.25=25%)','30%','10%','40%'], 0, 'Simplifica la razón: 30/120 = 1/4 = 25%.'),
    qMC('Si 8 de cada 20 alumnos usan lentes, ¿qué porcentaje es?', ['40% (8÷20=0.4)','8%','20%','80%'], 0, '8/20=2/5=0.4=40%. Interpretación porcentual de razones.'),
    qMC('Una tienda ofrece "3×2" (3 productos al precio de 2). El descuento real:', ['33.3% de descuento (pagas 2, llevas 3 = ahorras 1 de 3)','50%','100%','0%'], 0, 'Pagas 2/3 del precio real. Descuento = (1-2/3)×100=33.3%. Las ofertas se analizan con razones.'),
    qTF('"1 de cada 4" equivale a 25%.', true, '1/4 = 0.25 = 25%. Correcto.'),
    qOrder('Ordena los pasos para convertir razón a porcentaje:', ['Escribir razón como fracción a/b','Dividir a÷b','Multiplicar por 100','Agregar el símbolo %'], 'Conversión sistemática: fracción → decimal → porcentaje.'),
    qMatch('Relaciona cada razón con su porcentaje equivalente:', [{left:'1:2',right:'50%'},{left:'1:4',right:'25%'},{left:'3:5',right:'60%'},{left:'7:10',right:'70%'}], 'Muchas razones de la vida cotidiana se expresan mejor como porcentajes.'),
    qMC('En una encuesta, la razón de aprobación es 3:5. ¿Porcentaje de aprobación?', ['60% (3/5=0.6)','40%','3%','5%'], 0, '3 de cada 5 aprueban. 3/5=0.60=60%.'),
    qWrite('Expresa la razón 7:8 como porcentaje.', ['87.5','87.5%'], '7÷8=0.875=87.5%.'),
    qWrite('Expresa la razón 7:8 como porcentaje.', ['87.5','87.5%'], '7÷8=0.875=87.5%.'),
  ],

  // ===== M66: Regla de tres simple directa =====
  [
    qMC('La regla de tres simple directa sirve para:', ['Encontrar un VALOR DESCONOCIDO en una proporción directa conociendo 3 datos','Sumar 3 números','Dividir todo','No sirve'], 0, 'Estructura: "Si A produce B, entonces C producirá X". Se resuelve con proporciones.'),
    qMC('Si 5 kg de manzana cuestan $150, ¿cuánto cuestan 8 kg?', ['$240 (5→150, 8→x; x=(8×150)÷5=240)','$300','$120','$200'], 0, 'Método: multiplica en CRUZ los conocidos y divide por el tercero.'),
    qMC('En una regla de tres directa, la relación entre magnitudes es:', ['A MÁS kg, MÁS dinero (proporción DIRECTA). La razón se mantiene','Inversa','Aleatoria','Fija'], 0, 'Primero identifica: ¿si una magnitud crece, la otra también? → Directa.'),
    qMC('3 metros de tela cuestan $270. ¿Cuánto cuestan 7 metros?', ['$630 (k=$90/m, 7×90=$630. O: (7×270)÷3=$630)','$270','$900','$540'], 0, 'Valor unitario × cantidad o producto cruzado. Ambos métodos dan lo mismo.'),
    qMC('Con 12 litros de gasolina se recorren 180 km. ¿Cuántos km con 20 litros?', ['300 km (12→180, 20→x; x=(20×180)÷12=300)','200 km','360 km','150 km'], 0, 'Rendimiento de combustible: 15 km/L × 20 = 300 km.'),
    qMC('Para resolver: "Si 4 obreros tardan 12 días..." piensa:', ['PRIMERO identifica si es DIRECTA o INVERSA. Aquí: más obreros→menos días = INVERSA','Siempre es directa','No importa','Es lo mismo'], 0, 'La regla de tres varía según el tipo. Directa: producto cruzado. Inversa: producto horizontal.'),
    qTF('En la regla de tres directa, se multiplican los valores en DIAGONAL y se divide entre el tercero.', true, 'Esquema: A→B, C→X. X=(C×B)÷A.'),
    qOrder('Ordena los pasos para resolver "Si 15 cuadernos cuestan $675, ¿cuánto 22?":', ['Identificar relación: DIRECTA (más cuadernos, más dinero)','Plantear: 15→$675, 22→X','Calcular: X=(22×675)÷15','22×675=14,850','14,850÷15=$990','Resultado: $990'], 'Método paso a paso: tipo → proporción → operación → resultado.'),
    qMatch('Relaciona cada problema con su solución por regla de tres:', [{left:'5 kg→$200, 8 kg→?',right:'$320'},{left:'3 h→15 km, 7 h→?',right:'35 km'},{left:'4 L→$96, 6 L→?',right:'$144'},{left:'2 docenas→$360, 5 docenas→?',right:'$900'}], 'Problemas cotidianos: compras, distancias, producción.'),
    qMC('Una receta usa 300 g de harina para 12 galletas. Para 20 galletas se necesita:', ['500 g (300/12=25g/cada una. 25×20=500g)','400 g','600 g','350 g'], 0, 'Valor unitario: 25g por galleta. Aplicación de regla de tres en cocina.'),
    qWrite('Si 3 boletos cuestan $240, ¿cuánto 5 boletos?', ['400','$400'], '240/3=80. 5×80=400.'),
    qWrite('Si 3 boletos cuestan $240, ¿cuánto 5?', ['400','$400'], '240/3=80. 5×80=400.'),
  ],

  // ===== M67: Regla de tres simple inversa =====
  [
    qMC('En la regla de tres INVERSA:', ['A MÁS de una magnitud, MENOS de la otra. Se multiplican los valores en HORIZONTAL','Es igual que la directa','Más es más','No hay diferencia'], 0, 'Esquema: A→B, C→X (inversa). X=(A×B)÷C.'),
    qMC('Si 6 pintores tardan 8 días, ¿cuánto tardan 4 pintores?', ['12 días (6×8÷4=12)','6 días','8 días','5.3 días'], 0, 'INVERSA: más pintores menos días. Producto constante: 6×8=48. 48÷4=12.'),
    qMC('Un coche a 90 km/h tarda 4 h. ¿Cuánto tarda a 120 km/h?', ['3 horas (distancia=360 km. 360÷120=3 h. O: 90×4÷120=3)','5 h','4 h','6 h'], 0, 'Más velocidad → menos tiempo. INVERSA. Distancia fija = 360 km.'),
    qMC('Para distinguir directa de inversa:', ['Si al aumentar una variable la otra AUMENTA → directa. Si DISMINUYE → inversa','Son iguales','No hay manera','Siempre es directa'], 0, 'Regla de decisión: ¿crecen o decrecen juntas? ¿o una crece y la otra decrece?'),
    qMC('Un grifo llena un tanque en 10 horas. 5 grifos iguales lo llenan en:', ['2 horas (1×10÷5=2)','50 horas','10 horas','5 horas'], 0, 'Más grifos, menos tiempo. Producto constante = 10 horas-grifo.'),
    qMC('Si un depósito alcanza para 15 vacas 20 días, ¿para 25 vacas?', ['12 días (15×20=300 raciones. 300÷25=12)','30 días','15 días','20 días'], 0, 'Más vacas, menos días que dura el alimento. INVERSA.'),
    qTF('En la regla de tres inversa, el producto de cada par de valores es CONSTANTE.', true, 'A×B = C×X. Esta propiedad permite calcular X como (A×B)/C.'),
    qOrder('Ordena los pasos para resolver "Si 3 obreros hacen una obra en 15 días, ¿cuánto tardan 9?":', ['Identificar: INVERSA (más obreros, menos días)','Multiplicar primer par: 3×15=45','Dividir: 45÷9=5 días','Resultado: 5 días'], 'Flujo: identifica el tipo, multiplica horizontal, divide entre el dato sobrante.'),
    qMatch('Relaciona cada problema inverso con su solución:', [{left:'4 llaves→6h, 12 llaves→?',right:'2 horas'},{left:'60 km/h→3h, 90 km/h→?',right:'2 horas'},{left:'8 máquinas→10h, 5 máquinas→?',right:'16 horas'},{left:'20 obreros→15d, 25 obreros→?',right:'12 días'}], 'Problemas inversos: la otra cara de la moneda de la proporcionalidad.'),
    qMC('Un ganadero tiene forraje para alimentar 40 borregos por 25 días. Si consigue 10 más:', ['20 días (40×25=1000. 1000÷50=20)','31.25 días','25 días','15 días'], 0, 'Más borregos → menos días. 40×25/50=20 días.'),
    qWrite('12 máquinas en 5h → ¿cuántas máquinas para 3h?', ['20'], '(12×5)/3=60/3=20 máquinas.'),
    qWrite('12 máquinas en 5h → ¿cuántas para 3h?', ['20'], '(12×5)/3=60/3=20 máquinas.'),
  ],

  // ===== M68: Reparto proporcional directo =====
  [
    qMC('Reparto proporcional directo significa:', ['Dividir una cantidad en partes PROPORCIONALES a ciertos números o índices','Repartir en partes iguales','Dar todo al primero','Aleatorio'], 0, 'Si 3 personas aportaron diferente y hay ganancia, se reparte según lo aportado.'),
    qMC('Repartir $1,000 entre A y B en proporción 3:2:', ['A=$600, B=$400 (total partes=5. Cada parte=$200. A=3×200, B=2×200)','A=$500, B=$500','A=$700, B=$300','A=$300, B=$700'], 0, 'Suma partes: 3+2=5. Factor=$1000/5=$200 por parte. Distribución: 3×$200 y 2×$200.'),
    qMC('Para reparto proporcional: suma los índices, luego:', ['Cantidad total ÷ suma de índices = VALOR de cada UNIDAD. Multiplica por cada índice','No se sabe','Reparte igual','Ignora'], 0, 'Paso clave: factor unitario = total ÷ suma de partes.'),
    qMC('Repartir 360 entre 3 hijos con edades 8, 10, 12 años (proporcional):', ['96, 120, 144 (suma=30. Factor=360/30=12. 8×12=96, 10×12=120, 12×12=144)','120 cada uno','No se puede','Depende'], 0, 'Más edad = más parte. Verifica: 96+120+144=360 ✓.'),
    qMC('Tres socios invierten: $20k, $30k, $50k. Ganancia de $200k, ¿cuánto le toca al segundo?', ['$60,000 (total=100k. Factor=200/100=2. 30×2=$60k)','$40,000','$100,000','$50,000'], 0, 'Proporcional a la inversión. Negocios reales: ganancias según capital aportado.'),
    qMC('La SUMA de los índices en reparto proporcional:', ['Es el TOTAL de "partes" en que se divide la cantidad','No importa','Es el resultado','Es constante'], 0, 'Determina cuántas "unidades de reparto" hay y el valor de cada una.'),
    qTF('En el reparto proporcional directo, a MAYOR índice, MAYOR cantidad.', true, 'Si tienes más partes (más capital, más horas, más edad), recibes más.'),
    qOrder('Ordena los pasos para repartir $2,400 en proporción 5:3:2:', ['Sumar los índices: 5+3+2=10','Calcular valor unitario: 2,400÷10=$240','Multiplicar: 5×240=$1,200','3×240=$720','2×240=$480','Verificar: 1,200+720+480=2,400 ✓'], 'Método: suma → valor unitario → multiplica cada índice → verifica.'),
    qMatch('Relaciona cada reparto con los resultados:', [{left:'$500 en 2:3',right:'$200, $300'},{left:'$900 en 1:2:3',right:'$150, $300, $450'},{left:'$1,200 en 5:3',right:'$750, $450'},{left:'$600 en 1:1:1',right:'$200, $200, $200'}], 'El reparto proporcional crea equidad (no igualdad): cada quien según su contribución.'),
    qMC('Repartir 100 dulces entre 3 niños según sus edades: 4, 6, 10 años:', ['20, 30, 50 dulces (total=20. Factor=100/20=5. 4×5=20, 6×5=30, 10×5=50)','33 cada uno aprox','No se puede','Según quieran'], 0, 'Verifica: 20+30+50=100 ✓.'),
    qWrite('Reparte $1,800 proporcionalmente a 4 y 5.', ['800 y 1000','$800 y $1000'], 'Suma=9. Factor=200. 4×200=800, 5×200=1000.'),
    qWrite('Reparte $1800 proporcionalmente a 4 y 5.', ['800 y 1000','$800 y $1000'], 'Suma=9. Factor=200.'),
  ],

  // ===== M69: Regla de tres compuesta =====
  [
    qMC('La regla de tres compuesta involucra:', ['MÁS de 2 magnitudes relacionadas. Mezcla de proporcionalidades directas e inversas','Solo 2 magnitudes','Una sola operación','No existe'], 0, 'Ej: tiempo de construcción según obreros, horas diarias y dificultad.'),
    qMC('5 obreros trabajando 8h/día hacen una obra en 12 días. ¿Cuánto tardan 10 obreros trabajando 6h/día?', ['8 días (relaciones: más obreros→menos días [inv.], más horas→menos días [inv.])','6 días','12 días','24 días'], 0, 'Analiza cada relación: obreros×horas×días constante. Compuesta: combina efectos.'),
    qMC('En regla de tres compuesta:', ['Se analiza MAGNITUD por magnitud: ¿cada una es directa o inversa con la incógnita?','Todo es igual','Se ignora','Solo directas'], 0, 'Paso crucial: compara CADA magnitud con la que contiene la incógnita.'),
    qMC('Para "más obreros, menos días" la relación es:', ['INVERSA (al crecer obreros, decrecen los días necesarios)','Directa','No existe','Depende'], 0, 'Identificación correcta de cada relación para plantear la ecuación compuesta.'),
    qMC('Método práctico: producto de las directas entre producto de las inversas:', ['Cantidad×Directas/Inversas = constante en problemas compuestos','No funciona','Solo sumas','No aplica'], 0, 'Fórmula de proporcionalidad compuesta para problemas de trabajo.'),
    qMC('12 vacas comen 300 kg de forraje en 5 días. ¿Cuánto forraje para 20 vacas en 8 días?', ['800 kg (más vacas→más forraje [dir], más días→más forraje [dir]. 300×(20/12)×(8/5)=800)','500 kg','600 kg','300 kg'], 0, 'Ambas son directas (más vacas=+forraje, más días=+forraje). Producto de razones.'),
    qTC('La regla de tres compuesta solo funciona con 3 magnitudes.', false, 'Puede funcionar con cualquier número de magnitudes. Se analizan de par en par con la incógnita.'),
    qOrder('Ordena los pasos para "15 obreros, 8h/día, 10 días → ¿cuántos obreros para 6h/día, 20 días?":', ['Comparar obreros-horas: INVERSA (más obreros=menos horas)','Comparar obreros-días: INVERSA (más obreros=menos días)','Plantear: 15×(8/6)×(10/20)=15×(4/3)×(1/2)=15×(4/6)=10','Resultado: 10 obreros'], 'Análisis individual de cada relación con la incógnita.'),
    qMatch('Relaciona cada relación con su tipo:', [{left:'Obreros vs Tiempo',right:'INVERSA'},{left:'Horas/día vs Tiempo',right:'INVERSA'},{left:'Cantidad de trabajo vs Obreros',right:'DIRECTA'},{left:'Días trabajados vs Obra hecha',right:'DIRECTA'}], 'Cada par de magnitudes requiere identificación individual.'),
    qMC('3 máquinas producen 240 piezas en 8 horas. ¿Cuántas piezas producen 5 máquinas en 12 horas?', ['600 piezas (más máquinas→más piezas, más horas→más piezas. 240×(5/3)×(12/8)=600)','400 piezas','360 piezas','480 piezas'], 0, 'Ambas directas. Aumentan producción. Cálculo compuesto sencillo.'),
    qWrite('Completa: 8×(10/5)×(6/12) =?', ['8'], '8×2×0.5=8.'),
    qWrite('Completa: 8×(10/5)×(6/12) =?', ['8'], '8×2×0.5=8.'),
  ],

  // ===== M70: Reparto proporcional inverso =====
  [
    qMC('En el reparto proporcional INVERSO:', ['Se reparte INVERSAMENTE a los índices dados (a mayor índice, MENOR cantidad).','Es igual al directo','No se reparte','Siempre igual'], 0, 'Ej: repartir dinero entre hijos según su necesidad. El que tiene más, recibe menos ayuda.'),
    qMC('Para repartir INVERSAMENTE a 2, 3 y 6:', ['Se usan los inversos: 1/2, 1/3, 1/6. Luego se reparte proporcionalmente a esos valores','Se multiplican','Se suman','No se puede'], 0, 'Inversos: 1/2, 1/3, 1/6. Se homogenizan: 3/6, 2/6, 1/6. Proporción: 3:2:1.'),
    qMC('Repartir $330 en proporción INVERSA a los números 2 y 3:', ['$198 y $132 (inversos: 1/2:1/3 = 3:2. 330×(3/5)=198, 330×(2/5)=132)','$165 cada uno','$220,$110','$330,$0'], 0, 'Inversos 1/2, 1/3. MCM=6: 3/6, 2/6 → proporción 3:2.'),
    qMC('Reparto INVERSO significa:', ['Al CONTRARIO del directo: el que tiene MENOR índice recibe MAYOR parte','Igual que directo','Aleatorio','No definido'], 0, 'Lógica: si el índice es "recursos actuales", el que menos tiene, más recibe.'),
    qMC('Para convertir índices de inverso a directo:', ['Se toman los INVERSOS (1/índice) y se homogenizan para obtener la proporción directa equivalente','Se ignoran','Se suman','No hay método'], 0, 'Paso clave: inversos → común denominador → proporciones directas para el reparto.'),
    qMC('Repartir $1,200 inversamente a 1, 2, 3 (premio por menor puntuación):', ['$654.55, $327.27, $218.18 aprox. Inversos 1:1/2:1/3 = 6/6:3/6:2/6 = 6:3:2','$400 cada uno','$1,200 al primero','$600, $400, $200'], 0, 'Inversos homogenizados: 6:3:2. Suma=11 partes. Factor=$1200/11≈$109.09.'),
    qTF('En el reparto inverso, el de MAYOR índice recibe MENOR parte.', true, 'Es la definición. Inverso al índice: más grande el índice, menos le toca.'),
    qOrder('Ordena los pasos para repartir $500 inversamente a 4 y 6:', ['Calcular inversos: 1/4 y 1/6','Homogenizar (mcm=12): 3/12 y 2/12','Proporción directa: 3:2','Suma partes=5. Factor=$100','Reparto: 3×$100=$300, 2×$100=$200'], 'Método de reparto inverso: inversos → homogenizar → reparto directo equivalente.'),
    qMatch('Relaciona cada reparto con su tipo:', [{left:'Premio al mejor promedio',right:'DIRECTO a calificación'},{left:'Beca al que menos tiene',right:'INVERSO a ingresos'},{left:'Ganancia según inversión',right:'DIRECTO al capital'},{left:'Ayuda al más necesitado',right:'INVERSO a recursos'}], 'Identificar el contexto: ¿a más, más? → DIRECTO. ¿a más, menos? → INVERSO.'),
    qMC('Tres nietos reciben $900 inversamente a sus edades: 5, 8, 10 años:', ['$461.54, $288.46, $150 aprox. Inversos: 1/5=8/40, 1/8=5/40, 1/10=4/40 → 8:5:4. Suma=17. Factor≈$52.94','$300 cada uno','El menor $900','No se puede'], 0, 'Menor edad = mayor regalo. Reparto inverso.'),
    qWrite('Reparte $350 inversamente a 2 y 5.', ['250 y 100','$250 y $100'], 'Inversos 1/2:1/5=5:2. Suma=7.'),
    qWrite('Reparte $350 inversamente a 2 y 5.', ['250 y 100','$250 y $100'], 'Inversos 1/2:1/5=5:2.'),
  ],

  // ===== M71: Sucesiones aritméticas =====
  [
    qMC('Una SUCESIÓN es:', ['Una lista ordenada de números que siguen una REGLA o patrón','Un número solo','Una suma','No existe en matemáticas'], 0, 'Sucesión = secuencia. Ej: 2, 4, 6, 8, 10... (sumar 2 cada vez).'),
    qMC('En la sucesión 3, 7, 11, 15, 19... la regla es:', ['SUMAR 4 al término anterior (progresión aritmética de diferencia +4)','Multiplicar por 3','Restar','Dividir'], 0, '7-3=4, 11-7=4. La DIFERENCIA es constante. Es una progresión aritmética.'),
    qMC('El siguiente término en 5, 10, 15, 20, ___ es:', ['25 (la diferencia constante es +5)','30','20','18'], 0, '5+5=10, 10+5=15... El patrón es sumar 5.'),
    qMC('¿Qué número falta? 8, ___, 16, 20, 24 (diferencia +4):', ['12 (8+4=12, 12+4=16, 16+4=20...)','10','14','18'], 0, 'Encuentra la diferencia viendo términos conocidos: 20-16=4, 24-20=4.'),
    qMC('La fórmula del término n-ésimo de una progresión aritmética:', ['aₙ = a₁ + (n-1)×d, donde a₁=primer término, d=diferencia','aₙ = a₁×n','No existe','aₙ = a₁ + n'], 0, 'Ej: sucesión 3,7,11,15... a₁=3, d=4. El término 10: a₁₀=3+(10-1)×4=3+36=39.'),
    qMC('Si a₁=5 y d=3, el término 8 es:', ['5+(8-1)×3=5+21=26','5×8=40','5+8=13','5+3=8'], 0, 'Aplica fórmula: quinto término=5+4×3=17, octavo=26.'),
    qTF('En una progresión aritmética, la diferencia entre términos CONSECUTIVOS es CONSTANTE.', true, 'Definición de progresión aritmética. Si cambia la diferencia, no es aritmética.'),
    qOrder('Ordena los pasos para encontrar el término 15 de 2, 6, 10, 14...:', ['Identificar a₁=2','Calcular d: 6-2=4','Usar fórmula: a₁₅=2+(15-1)×4','a₁₅=2+14×4=2+56=58','Resultado: 58'], 'Fórmula universal para cualquier progresión aritmética.'),
    qMatch('Relaciona cada sucesión con su regla:', [{left:'1, 3, 5, 7, 9...',right:'Sumar 2 (d=+2)'},{left:'10, 20, 30, 40...',right:'Sumar 10 (d=+10)'},{left:'100, 90, 80, 70...',right:'Restar 10 (d=-10)'},{left:'7, 14, 21, 28...',right:'Sumar 7 (d=+7)'}], 'Las sucesiones pueden crecer (d>0) o decrecer (d<0). El patrón es la clave.'),
    qMC('¿Cuál es el término que falta? 13, 18, 23, ___, 33:', ['28 (diferencia=5, 23+5=28, 28+5=33 ✓)','25','30','26'], 0, 'Verifica consistencia con los términos extremos.'),
    qWrite('¿Cuál es el décimo término de 1, 4, 7, 10...?', ['28'], 'd=3. a₁₀=1+9×3=28.'),
    qWrite('¿Décimo término de 1, 4, 7, 10...?', ['28'], 'd=3. a₁₀=1+9×3=28.'),
  ],

