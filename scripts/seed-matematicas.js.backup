  // ===== M95: Ganancia, pérdida y punto de equilibrio =====
  [
    qMC('La GANANCIA se calcula:', ['Ingresos - Costos (G = I - C). Resultado positivo','Ingresos + Costos','Solo ingresos','No se calcula'], 0, 'Si vendes $50,000 en tacos y tus costos fueron $35,000, ganancia = $15,000.'),
    qMC('Si un comerciante compra un producto en $80 y lo vende en $120, su ganancia:', ['$40 (ganancia bruta). Margen = 40/120 = 33.3%','$120','$80','-$40 (pierde)'], 0, 'Margen de ganancia = (Precio venta - Costo)/Precio venta × 100.'),
    qMC('El PUNTO DE EQUILIBRIO es:', ['Cuando los INGRESOS = COSTOS (no hay ganancia ni pérdida)','Cuando hay máxima ganancia','Cuando se pierde todo','No existe'], 0, 'Ni ganas ni pierdes. Útil para saber el mínimo de ventas necesario para no quebrar.'),
    qMC('Un negocio con costos fijos de $10,000 y margen de $50 por producto:', ['Punto equilibrio = 10,000/50 = 200 productos (debe vender 200 para no perder)','5,000 productos','1 producto','No se puede calcular'], 0, 'PE = Costos fijos / Margen unitario. Cada producto después de 200 es GANANCIA.'),
    qMC('Si compras tenis en $500 y los vendes en $800:', ['Ganancia bruta = $300. Margen = 37.5% (300/800)','Ganancia $500','Pérdida $300','Margen 50%'], 0, 'Entre mayor el margen, más rentable el producto (generalmente).'),
    qMC('Para calcular el % de descuento de $200 a $150:', ['(200-150)/200 × 100 = 25% de descuento','50%','75%','15%'], 0, 'Descuento % = (Precio original - Precio rebajado) / Precio original × 100.'),
    qTF('Si el costo es mayor que el precio de venta, hay PÉRDIDA.', true, 'Costo > Precio venta = pérdida. Lo vendes por menos de lo que te costó.'),
    qOrder('Ordena los pasos para calcular el precio de venta si quieres 30% de margen sobre un costo de $200:', ['Entender: margen sobre PRECIO DE VENTA, no sobre costo','Si margen = 30% del precio, el costo es 70% del precio','$200 = 0.70 × Precio','Precio = 200/0.70 ≈ $285.71','Verificar: margen = 285.71-200=$85.71. 85.71/285.71=30% ✓'], 'Cálculo de precios = habilidad de negocio fundamental.'),
    qMatch('Relaciona cada situación financiera:', [{left:'Ingresos > Costos',right:'GANANCIA (superávit)'},{left:'Ingresos < Costos',right:'PÉRDIDA (déficit)'},{left:'Ingresos = Costos',right:'PUNTO DE EQUILIBRIO'},{left:'(Precio-Costo)/Precio',right:'MARGEN de ganancia'}], 'Conceptos financieros para emprendedores y la vida diaria.'),
    qMC('Costos de vender aguas frescas: vaso $3, agua $2, azúcar $1. Vendes a $12. ¿Ganancia por vaso?', ['$6 por vaso (12-3-2-1)','$9','$12','$3'], 0, 'Suma todos los costos (vaso + ingredientes) y resta al precio. Ganancia unitaria.'),
    qWrite('Costos fijos $5,000, margen $25/producto. ¿PE?', ['200','200 productos'], '5,000÷25=200 para punto de equilibrio.'),
    qWrite('Costos fijos $5000, margen $25/prod. ¿PE?', ['200','200 productos'], '5000÷25=200 para equilibrio.'),
  ],

