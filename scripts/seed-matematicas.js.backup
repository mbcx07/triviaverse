  // ===== M73: Sucesiones geométricas =====
  [
    qMC('En una progresión GEOMÉTRICA, cada término se obtiene:', ['MULTIPLICANDO el anterior por una RAZÓN CONSTANTE (r)','Sumando','Restando','No hay regla'], 0, 'Ej: 2, 6, 18, 54... Cada término ×3. r=3.'),
    qMC('La razón en: 3, 6, 12, 24, 48... es:', ['r=2 (cada término es el DOBLE del anterior)','r=3','r=1','r=6'], 0, '6÷3=2, 12÷6=2, 24÷12=2. Razón constante.'),
    qMC('El siguiente término de 1, 4, 16, 64, ___ es:', ['256 (×4 cada vez: 64×4=256)','128','100','70'], 0, '1×4=4, 4×4=16, 16×4=64, 64×4=256. Crecimiento acelerado.'),
    qMC('La fórmula del término n-ésimo geométrico:', ['aₙ = a₁ × rⁿ⁻¹','aₙ = a₁ + (n-1)r','aₙ = a₁×n','No existe'], 0, 'Ej: 3, 6, 12... a₁=3, r=2. a₅=3×2⁴=3×16=48.'),
    qMC('Si a₁=5 y r=3, el cuarto término:', ['5×3³=5×27=135','5×3×4=60','5+4×3=17','5×4=20'], 0, 'a₄=a₁×r³=5×27=135. El crecimiento geométrico es mucho más rápido.'),
    qMC('Las progresiones geométricas modelan:', ['Crecimiento exponencial: bacterias, interés compuesto, poblaciones','Solo suma','Nada real','Solo juegos'], 0, 'Las bacterias se duplican cada 20 min. Interés compuesto: el dinero crece multiplicándose.'),
    qTF('En 2, 4, 8, 16... la razón es 2 y los términos CRECEN muy rápido.', true, 'r=2. a₁₀=2×2⁹=2×512=1,024. Diez pasos y ya es enorme.'),
    qOrder('Ordena los pasos para encontrar a₇ de 2, 6, 18...:', ['Identificar a₁=2','Calcular r=6÷2=3','Aplicar a₇=2×3⁶','3⁶=729','2×729=1,458','Resultado: 1,458'], 'Fórmula de progresión geométrica con cálculo de potencia.'),
    qMatch('Relaciona cada PG con su razón:', [{left:'1, 2, 4, 8, 16...',right:'r=2'},{left:'1, 3, 9, 27, 81...',right:'r=3'},{left:'80, 40, 20, 10, 5...',right:'r=1/2 (decrece)'},{left:'1, 10, 100, 1000...',right:'r=10'}], 'Las PG pueden crecer (r>1) o decrecer (0<r<1).'),
    qMC('Si un virus se duplica cada hora (r=2), empezando con 1, en 6 horas hay:', ['2⁶=64 virus (a₇=1×2⁶)','32 virus','12 virus','6 virus'], 0, 'Hora 0:1, H1:2, H2:4, H3:8, H4:16, H5:32, H6:64. ¡Exponencial!'),
    qWrite('En PG: 3, 12, 48... ¿cuál es la razón r?', ['4'], '12/3=4, 48/12=4. r=4.'),
    qWrite('En PG: 3, 12, 48... ¿cuál es la razón r?', ['4'], '12/3=4, 48/12=4. r=4.'),
  ],

