    qMC('El patrón de puntos: ●, ●●(en 2 filas), ●●●(en 3)... sigue:', ['1, 2, 3, 4... (números triangulares: n(n+1)/2 para total de puntos)','Siempre 1','No tiene patrón','Aleatorio'], 0, 'Triángulo de puntos: 1+2+3+4... Las figuras crecen con regla matemática.'),
    qMC('Patrón de cuadrados: 1²=1, 2²=4, 3²=9... La décima figura tendrá:', ['100 cuadraditos (10²)','10 cuadraditos','50','20'], 0, 'Figura n es un cuadrado de n×n. La figura 10 = 10×10=100.'),
    qMC('Patrón de cerillos para formar triángulos: 1 triángulo=3, 2=5, 3=7... Regla:', ['3 + (n-1)×2. Para 10 triángulos: 3+18=21 cerillos','n×3','2n','3n+1'], 0, 'Cada nuevo triángulo comparte 1 lado con el anterior.'),
    qMC('Torre de latas: fila 1=1, fila 2=3, fila 3=6, fila 4=10. ¿Fila 5?', ['15 (sumas: 1, 1+2=3, 3+3=6, 6+4=10, 10+5=15)','5','13','20'], 0, 'Números triangulares: Tₙ=n(n+1)/2. T₅=5×6/2=15.'),
    qMC('Para predecir la figura n en un patrón visual:', ['Encuentra la REGLA NUMÉRICA que genera el patrón (fórmulas como n², 2n+1, etc.)','Dibuja todas las figuras','No se puede','Advinas'], 0, 'Abstracción: el patrón visual se traduce a fórmula matemática.'),
    qTF('Los patrones geométricos SIEMPRE tienen una regla matemática subyacente.', true, 'Las figuras que siguen un patrón siempre pueden describirse con números y fórmulas.'),
    qOrder('Ordena los pasos para encontrar la regla de un patrón de puntos:', ['Contar puntos de las primeras figuras: F1=3, F2=6, F3=9, F4=12','Buscar patrón numérico: 3×1, 3×2, 3×3...','Deducir regla: Fₙ=3n','Predecir: figura 10 tendrá 30 puntos'], 'Traducción de lo visual a lo algebraico: habilidad matemática fundamental.'),
    qMatch('Relaciona cada patrón visual con su fórmula:', [{left:'Cuadrados n×n',right:'n²'},{left:'Rectángulos 2×n',right:'2n'},{left:'Triángulo de n filas',right:'n(n+1)÷2'},{left:'Línea de n puntos',right:'n'}], 'Los patrones visuales nos conectan con la geometría y el álgebra simultáneamente.'),
    qMC('Escalera de cubos: piso 1=1, piso 2=3, piso 3=5 cubos. Piso n:', ['2n-1 (números IMPARES)','n²','n','2n'], 0, '1=2(1)-1, 3=2(2)-1, 5=2(3)-1. El piso 8 tendrá 2(8)-1=15 cubos.'),
    qWrite('Patrón de círculos: 1, 3, 6, 10... expresión:', ['n(n+1)/2','triangulares'], 'Números triangulares Tₙ = n(n+1)/2.'),
    qWrite('Patrón círculos: 1, 3, 6, 10... expresión:', ['n(n+1)/2','triangulares'], 'Triangulares Tₙ=n(n+1)/2.'),
