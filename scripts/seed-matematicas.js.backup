    qMC('Ecuación: x/3 + 4 = 10:', ['x = 18 (x/3=6, x=18)','x = 30','x = 2','x = 42'], 0, 'Resta 4 → x/3=6. Multiplica por 3 → x=18.'),
    qMC('Pasos para 4x - 9 = 23:', ['Suma 9 → 4x=32. Divide entre 4 → x=8','Multiplica 4×9=36','x=23','No se puede'], 0, 'Dos operaciones inversas: suma y división.'),
    qMC('5x + 12 = 47. x es:', ['x = 7 (5x=35, x=7)','x = 5','x = 9.4','x = 59'], 0, 'Resta 12 → 5x=35 → x=7.'),
    qMC('La estrategia para ecuaciones de 2 pasos:', ['Primero ELIMINA el término INDEPENDIENTE (suma/resta), luego el COEFICIENTE (mult/div)','Todo al mismo tiempo','Ignora el orden','No hay estrategia'], 0, 'Deshacer en ORDEN INVERSO al de las operaciones (PEMDAS al revés: SAMDEP).'),
    qTF('En 2x + 8 = 16, primero resto 8 y luego divido entre 2.', true, '2x+8=16 → 2x=8 → x=4. Ese es el orden correcto.'),
    qOrder('Ordena los pasos para resolver 6x - 18 = 30:', ['Sumar 18 en ambos lados: 6x = 48','Dividir ambos entre 6: x = 8','Verificar: 6(8)-18=48-18=30 ✓'], 'Método de dos pasos: elimina constante, luego el coeficiente.'),
    qMatch('Relaciona cada ecuación con su solución:', [{left:'2x + 3 = 15',right:'x = 6'},{left:'3x - 5 = 16',right:'x = 7'},{left:'x/2 + 7 = 15',right:'x = 16'},{left:'5x + 10 = 45',right:'x = 7'}], 'Consolida la estrategia de dos pasos en distintas variantes.'),
    qMC('Juan compra 3 cuadernos iguales y un lápiz de $12. Total $72. ¿Cada cuaderno?', ['3x + 12 = 72. 3x=60, x=$20 cada cuaderno','x + 12 = 72','3x = 84','x = $24'], 0, 'Problema real que requiere ecuación de dos pasos.'),
    qWrite('Resuelve: 4x + 6 = 30. ¿x?', ['6'], '4x=24, x=6.'),
    qWrite('Resuelve: 4x + 6 = 30. ¿x?', ['6'], '4x=24, x=6.'),
  ],

  // ===== M80: Resolución de problemas con ecuaciones =====
  [
    qMC('"Un número más su doble suman 36". Ecuación:', ['x + 2x = 36 → x = 12 (número=12, doble=24)','x + 2 = 36','x×2 = 36','x = 36+2'], 0, 'Planteamiento: n + 2n = 3n = 36. n = 12.'),
    qMC('Edad de Luis = 2× edad de José. Suma de edades = 18:', ['José=6, Luis=12 (x+2x=18 → 3x=18 → x=6, 2x=12)','Luis=18, José=0','No se puede','Ambos 9'], 0, 'Problema de edades con ecuaciones. Una de las aplicaciones más comunes.'),
    qMC('Perímetro de rectángulo: largo=3×ancho. Perímetro=32 m:', ['Ancho=4m, Largo=12m (2(3x)+2x=8x=32, x=4)','Ancho=8m','No se puede','Largo=10m'], 0, 'Geometría + álgebra: combinación poderosa.'),
    qMC('Ana ahorró $x. Su mamá le dio el triple: $3x. Total $200:', ['x + 3x = 200 → 4x=200 → x=$50 ahorrados por Ana','x = $200','x = $100','No se puede'], 0, 'Situación familiar modelada con ecuaciones.'),
    qMC('La suma de tres números CONSECUTIVOS es 72. El primero:', ['x + (x+1) + (x+2) = 72 → 3x+3=72 → 3x=69 → x=23 (números: 23,24,25)','20','24','No hay'], 0, 'Consecutivos: n, n+1, n+2. Problema clásico.'),
    qMC('Gasté $45 de $x que tenía y me quedan $30. ¿Cuánto tenía?', ['x - 45 = 30 → x = $75','x = $15','x = $45','x = $30'], 0, 'Problema simple: planteamiento directo.'),
    qTF('Los problemas verbales SIEMPRE se pueden resolver con ecuaciones de primer grado.', false, 'Algunos requieren ecuaciones cuadráticas o sistemas. Pero MUCHOS problemas cotidianos sí se resuelven con ecuaciones simples.'),
    qOrder('Ordena los pasos para resolver "Un número más 15 es igual a su triple menos 5":', ['Plantear: x + 15 = 3x - 5','Agrupar variables: 15 + 5 = 3x - x','20 = 2x','x = 10','Verificar: 10+15=25. 3(10)-5=30-5=25 ✓'], 'Método completo: leer → plantear → resolver → verificar.'),
    qMatch('Relaciona el problema con su ecuación:', [{left:'El doble de un número + 8 = 30',right:'2x + 8 = 30'},{left:'Tres números consecutivos suman 54',right:'x+x+1+x+2 = 54'},{left:'Mitad de un número + 5 = 13',right:'x/2 + 5 = 13'},{left:'Un número y su triple suman 48',right:'x + 3x = 48'}], 'Plantear correctamente = 80% de la solución.'),
    qMC('El quíntuple de un número menos 12 es 48. ¿Cuál es el número?', ['x = 12 (5x-12=48, 5x=60, x=12)','x = 10','x = 60','x = 5'], 0, 'Quíntuple = ×5. Traducción precisa del lenguaje verbal.'),
    qWrite('Perímetro rectángulo 40 cm, largo triple del ancho. ¿Ancho?', ['5','5 cm'], '2(3x+x)=8x=40, x=5cm.'),
    qWrite('Perímetro rect. 40 cm, largo triple de ancho. ¿Ancho?', ['5','5 cm'], '2(3x+x)=8x=40, x=5.'),
  ],

  // ===== M81: Simetría axial (reflexión) =====
  [
    qMC('La SIMETRÍA AXIAL ocurre cuando:', ['Una figura se refleja respecto a una RECTA (eje de simetría) como un ESPEJO','Se gira','Se mueve','No cambia'], 0, 'Reflejar sobre un eje: cada punto y su imagen están a IGUAL distancia del eje.'),
    qMC('El eje de simetría es:', ['La recta que actúa como ESPEJO, dividiendo la figura en dos partes IDÉNTICAS','Cualquier línea','El borde','Un punto'], 0, 'Mariposa: un eje de simetría que la divide en dos alas iguales.'),
    qMC('¿Cuántos ejes de simetría tiene un CUADRADO?', ['4 ejes (2 por las diagonales, 2 por los puntos medios de lados opuestos)','2','1','Ninguno'], 0, 'El cuadrado es muy simétrico: vertical, horizontal y 2 diagonales.'),
    qMC('Un triángulo EQUILÁTERO tiene:', ['3 ejes de simetría (cada mediatriz es también eje)','1 eje','Ninguno','2 ejes'], 0, 'Muy simétrico: cada eje va de un vértice al punto medio del lado opuesto.'),
    qMC('Un rectángulo (no cuadrado) tiene:', ['2 ejes de simetría (horizontal y vertical por los puntos medios)','4 ejes','Ninguno','1 eje'], 0, 'Solo los ejes que pasan por los puntos medios de lados opuestos.'),
    qMC('La letra "A" tiene:', ['1 eje de SIMETRÍA VERTICAL','Ninguno','Simetría horizontal','2 ejes'], 0, 'Refleja la A sobre su eje vertical central y coincide consigo misma.'),
    qTF('Un círculo tiene INFINITOS ejes de simetría (cualquier recta por el centro).', true, 'Cada diámetro es un eje de simetría. El círculo es la figura más simétrica.'),
    qOrder('Ordena estos pasos para encontrar el reflejo de un punto A sobre un eje:', ['Trazar perpendicular desde A al eje','Medir la distancia de A al eje','Copiar esa distancia al otro lado del eje sobre la misma perpendicular','Ese punto es la imagen A\' de A'], 'Construcción geométrica de reflexión: perpendicular + igual distancia.'),
    qMatch('Relaciona cada figura con su número de ejes de simetría:', [{left:'Triángulo isósceles',right:'1 eje'},{left:'Cuadrado',right:'4 ejes'},{left:'Hexágono regular',right:'6 ejes'},{left:'Rombo (no cuadrado)',right:'2 ejes'}], 'La simetría es una propiedad geométrica que mide la regularidad de las figuras.'),
    qMC('En la naturaleza, la simetría axial aparece en:', ['Mariposas, rostros humanos, hojas, copos de nieve','Solo en matemáticas','No aparece','Solo dibujos'], 0, 'La naturaleza AMA la simetría bilateral. Es ubicua.'),
    qWrite('¿Cuántos ejes de simetría tiene un triángulo escaleno?', ['0','ninguno','cero'], 'Sin lados iguales, sin ejes de simetría.'),
    qWrite('¿Ejes de simetría de un triángulo escaleno?', ['0','ninguno','cero'], 'Sin lados iguales.'),
  ],

  // ===== M82: Simetría central (rotación de 180°) =====
  [
    qMC('La SIMETRÍA CENTRAL es:', ['Una rotación de 180° alrededor de un PUNTO (centro de simetría)','Una reflexión','Un desplazamiento','No existe'], 0, 'Cada punto y su imagen están alineados con el centro y a IGUAL distancia en dirección opuesta.'),
    qMC('El centro de simetría es:', ['El PUNTO alrededor del cual se gira 180° para que la figura coincida consigo misma','Una línea','Cualquier punto','No existe'], 0, 'Ej: centro de un rectángulo. Gira 180° y el rectángulo coincide consigo mismo.'),
    qMC('¿Tiene un triángulo equilátero simetría central?', ['NO (al girar 180° no coincide consigo mismo, aunque sí tiene rotacional de 120°)','SÍ','Depende','Siempre'], 0, 'La simetría central requiere que coincida EXACTAMENTE tras 180°.'),
    qMC('Un PARALELOGRAMO (no rectángulo) tiene:', ['Simetría CENTRAL (gira 180° y coincide) pero NO axial','Simetría axial','Ninguna simetría','Ambas'], 0, 'El centro del paralelogramo es centro de simetría. Gira media vuelta y coincide.'),
    qMC('La letra "S" tiene:', ['Simetría central (gira 180° y se ve igual)','Simetría axial','Ninguna','Ambas'], 0, 'La S mayúscula tiene centro de simetría en su punto medio.'),
    qMC('Simetría rotacional de orden n significa:', ['La figura coincide consigo misma al girar 360°/n grados','Solo axial','No existe','180° siempre'], 0, 'Triángulo equilátero: 120° (orden 3). Cuadrado: 90° (orden 4).'),
    qTF('Un rectángulo tiene TANTO simetría axial COMO central.', true, 'Rectángulo: 2 ejes axiales + centro de simetría (gira 180° y coincide).'),
    qOrder('Ordena los pasos para construir la imagen de un punto por simetría central:', ['Unir el punto A con el centro O','Prolongar la recta AO al otro lado de O','Copiar la distancia AO a partir de O en dirección opuesta','Marcar A\': ese es el simétrico de A'], 'Simetría central = duplicar el punto a través del centro. A y A\' están a misma distancia de O.'),
    qMatch('Relaciona cada figura con sus tipos de simetría:', [{left:'Círculo',right:'Infinitos ejes + central'},{left:'Cuadrado',right:'4 ejes + central'},{left:'Triángulo equilátero',right:'3 ejes, sin central'},{left:'Romboide (paralelogramo genérico)',right:'Solo central'}], 'Simetría axial y central pueden coexistir o presentarse separadamente.'),
    qMC('La simetría central es equivalente a:', ['Una rotación de 180° alrededor del centro','Un espejo','Un desplazamiento','No se sabe'], 0, 'Equivalencia: centro de simetría ≡ rotación de media vuelta.'),
    qWrite('¿La letra N mayúscula tiene simetría central?', ['si','sí'], 'Sí, la N tiene centro de simetría.'),
    qWrite('¿La letra N mayúscula tiene simetría central?', ['si','sí'], 'Sí, la N tiene centro de simetría.'),
  ],

  // ===== M83: Traslación de figuras =====
  [
    qMC('Una TRASLACIÓN es:', ['DESPLAZAR una figura sin GIRARLA ni cambiar su TAMAÑO','Girar','Agrandar','Reflejar'], 0, 'Traslación = mover en línea recta. Como deslizar una hoja sobre la mesa.'),
    qMC('En una traslación, la figura resultante:', ['Es CONGRUENTE (misma forma y tamaño), solo cambia su posición','Es más chica','Está girada','Es reflejada'], 0, 'Traslación = isometría. Conserva distancias y ángulos.'),
    qMC('Un vector de traslación (a, b) significa:', ['Mover a unidades en dirección X y b unidades en dirección Y','Solo X','Solo Y','No existe'], 0, 'Vector (3, -2): mover 3 a la derecha y 2 hacia abajo.'),
    qMC('Si trasladas el punto (5, 3) con vector (2, -4), queda en:', ['(7, -1) (5+2=7, 3-4=-1)','(3, 7)','(5, 3)','(2, -4)'], 0, 'Suma las coordenadas: x\' = x + a, y\' = y + b.'),
    qMC('Las traslaciones en el plano cartesiano se usan para:', ['Posicionar objetos en diseño gráfico, videojuegos, arquitectura','Solo matemáticas','No se usan','Solo exámenes'], 0, 'Todo movimiento sin giro en pantalla es una traslación.'),
    qMC('Un mosaico (teselado) se forma por:', ['TRASLACIONES repetidas de figuras que encajan sin huecos','Solo un dibujo','Círculos','No se puede'], 0, 'Teselados: traslaciones de triángulos, cuadrados o hexágonos. Arte islámico y de Escher.'),
    qTF('Una traslación conserva TODAS las propiedades geométricas: distancias, ángulos y orientación.', true, 'La figura trasladada es idéntica en todo excepto en su posición. Es una isometría.'),
    qOrder('Ordena los pasos para trasladar un triángulo con vector (4, -2):', ['Tomar cada vértice del triángulo','Sumar 4 a la coordenada x de cada vértice','Restar 2 a la coordenada y de cada vértice','Unir los nuevos vértices en el mismo orden','El triángulo trasladado está listo'], 'Traslación de figuras completas: mismo proceso para cada punto.'),
    qMatch('Relaciona cada transformación con su descripción:', [{left:'Traslación',right:'Desplazamiento sin giro'},{left:'Rotación',right:'Giro alrededor de un punto'},{left:'Reflexión',right:'Volteo sobre un eje (espejo)'},{left:'Homotecia',right:'Ampliación o reducción'}], 'Cuatro transformaciones geométricas fundamentales.'),
    qMC('Trasladar el punto P(-3, 6) con vector (-1, 4) lo deja en:', ['(-4, 10)','(-2, 10)','(-3, 6)','(4, 2)'], 0, '-3-1=-4, 6+4=10. P\': (-4, 10).'),
    qWrite('Traslada (4, -2) con vector (-3, 5). ¿Resultado?', ['(1,3)','1,3'], '4-3=1, -2+5=3.'),
    qWrite('Traslada (4, -2) con vector (-3, 5).', ['(1,3)','1,3'], '4-3=1, -2+5=3.'),
  ],

  // ===== M84: Rotación de figuras =====
  [
    qMC('Una ROTACIÓN es:', ['GIRAR una figura alrededor de un PUNTO FIJO (centro) un cierto ÁNGULO','Desplazar','Reflejar','Agrandar'], 0, 'Rotación = giro. Manecillas del reloj, rueda de la fortuna, ventilador.'),
    qMC('Rotar 90° en sentido ANTIHORARIO un punto (2, 3) alrededor del origen:', ['(-3, 2) La regla (x,y)→(-y,x) cuando el centro es (0,0)','(3, -2)','(-2, -3)','(2, 3)'], 0, 'Regla mnemotécnica: (x,y)→(-y,x). Verifica: ¡sí funciona!'),
    qMC('Rotación de 180° alrededor del origen transforma (x,y) en:', ['(-x, -y)','(y, x)','(-y, x)','(y, -x)'], 0, 'Media vuelta: cambia ambos signos. Es igual a la simetría central en el origen.'),
    qMC('Los giros del reloj son rotaciones de:', ['-6° por minuto (360° en 60 min) en sentido horario','+6° por minuto','-90°','+180°'], 0, '360°÷60=-6°/min. El signo negativo indica sentido horario.'),
    qMC('La rotación CONSERVA:', ['Distancias y ángulos (la figura NO se deforma)','Tamaño pero no forma','Solo ángulos','Nada'], 0, 'Rotación = isometría. Igual que traslación y reflexión.'),
    qMC('Para rotar un triángulo completo:', ['Se rota CADA vértice con la misma regla y se unen los puntos resultantes','Solo un vértice','Aleatorio','No se puede'], 0, 'Aplica la transformación a cada punto y reconstruye la figura.'),
    qTF('La rotación de 360° deja la figura EXACTAMENTE como estaba (vuelta completa).', true, 'Giro completo = identidad. La figura no cambia.'),
    qOrder('Ordena estos tipos de rotación de menor a mayor ángulo:', ['90° (cuarto de vuelta)','180° (media vuelta)','270° (tres cuartos)','360° (vuelta completa)'], 'Los ángulos notables de rotación: cada 90° es un cuarto de vuelta.'),
    qMatch('Relaciona cada ángulo de rotación con el efecto:', [{left:'90° antihorario',right:'(x,y)→(-y,x)'},{left:'180°',right:'(x,y)→(-x,-y) = sim. central'},{left:'270° antihorario (ó -90°)',right:'(x,y)→(y,-x)'},{left:'360°',right:'Identidad (x,y)→(x,y)'}], 'Rotaciones en el plano: reglas prácticas para puntos.'),
    qMC('Un cuadrado de lado 2, centrado en (1,1), al girar 90° antihorario alrededor del origen:', ['Sus vértices cambian según (x,y)→(-y,x)','Se hace más chico','Desaparece','No cambia'], 0, 'Cada vértice se transforma individualmente según la regla de rotación.'),
    qWrite('Rota (x,y) 180° alrededor del origen:', ['(-x,-y)'], 'Media vuelta: cambian ambos signos.'),
    qWrite('Rota (x,y) 180° alrededor del origen:', ['(-x,-y)'], 'Media vuelta: cambian ambos signos.'),
  ],

  // ===== M85: Homotecia (escalamiento) =====
  [
    qMC('Una HOMOTECIA es:', ['Una transformación que AMPLÍA o REDUCE una figura manteniendo su FORMA','Un giro','Un desplazamiento','Un espejo'], 0, 'Homotecia = zoom. Factor k>1 amplía, 0<k<1 reduce. k<0 invierte.'),
    qMC('Si k=2 en una homotecia, la figura resultante es:', ['El DOBLE de grande (cada coordenada se multiplica por 2)','Igual','La mitad','El triple'], 0, 'Factor 2 = duplica todas las distancias. Área se multiplica por k² = 4.'),
    qMC('Una homotecia con k=0.5:', ['Reduce a la MITAD cada dimensión (×0.5)','Duplica','No cambia','Triplica'], 0, 'Reducción: zoom out. Si k=0.5, el área se reduce a 0.5²=0.25 del original.'),
    qMC('Un triángulo de base 6 y altura 4, al aplicar k=3, la nueva base es:', ['18 (6×3), nueva altura 12. Área original=12, nueva=108=12×9=12×k²','9','12','6'], 0, 'k=3: dimensiones ×3. Área ×9. Importante relación cuadrática.'),
    qMC('La homotecia NO es una isometría porque:', ['CAMBIA el tamaño (no conserva las distancias originales)','Sí conserva','No cambia nada','Es igual a traslación'], 0, 'Isometría = misma medida. Homotecia cambia medidas pero conserva proporciones y ángulos.'),
    qMC('La homotecia conserva:', ['La FORMA y los ÁNGULOS, pero cambia el TAMAÑO','El tamaño','La posición','Todo'], 0, 'Figuras semejantes (no congruentes). Misma forma, diferente tamaño.'),
    qTF('Si k=1 en homotecia, la figura NO cambia (transformación identidad).', true, 'Homotecia de factor 1 = no hace nada.'),
    qOrder('Ordena los pasos para realizar homotecia de centro (0,0) y k=2 al punto (3,4):', ['Identificar coordenadas: x=3, y=4','Multiplicar cada coordenada por k=2','Nuevo punto: (3×2, 4×2) = (6,8)','La distancia al origen se duplicó: de 5 a 10'], 'Método: multiplica cada coordenada del punto por k.'),
    qMatch('Relaciona cada factor de homotecia con su efecto:', [{left:'k=2',right:'Duplica el tamaño'},{left:'k=0.5',right:'Reduce a la mitad'},{left:'k=3',right:'Triplica'},{left:'k=0.25',right:'Cuarta parte'}], 'Homotecia = escalamiento proporcional. Fundamental en diseño y cartografía.'),
    qMC('En una copia fotostática al 150%, el factor de homotecia es:', ['k = 1.5','k = 150','k = 0.15','k = 15'], 0, '150% = 150/100 = 1.5. Ampliación de ×1.5.'),
    qWrite('Homotecia con k=3. Segmento de 5 cm mide ahora:', ['15','15 cm'], '5×3=15 cm.'),
    qWrite('Homotecia k=3. Segmento de 5 cm:', ['15','15 cm'], '5×3=15 cm.'),
  ],

  // ===== M86: Sistema Internacional de Unidades (SI) =====
  [
    qMC('El Sistema Internacional de Unidades (SI) establece:', ['Unidades ESTÁNDAR para medir magnitudes físicas en TODO el mundo','Solo medidas de México','Unidades diferentes para cada país','No existe'], 0, 'SI: creado en 1960. 7 unidades base: metro, kilogramo, segundo, ampere, kelvin, mol, candela.'),
    qMC('Las 7 magnitudes fundamentales del SI son:', ['Longitud, masa, tiempo, corriente eléctrica, temperatura, cantidad de sustancia, intensidad luminosa','Solo 3','No están definidas','Varían por país'], 0, 'Todo lo demás (velocidad, fuerza, presión) son magnitudes DERIVADAS de estas 7.'),
    qMC('La unidad SI de longitud es el METRO (m). Originalmente se definió como:', ['La diezmillonésima parte del cuadrante terrestre. Hoy: distancia que viaja la luz en 1/299,792,458 s','La longitud del pie del rey','Algo aleatorio','100 cm'], 0, 'Definición moderna ultra precisa usando constantes universales.'),
    qMC('La unidad SI de masa:', ['El KILOGRAMO (kg). Es la ÚNICA unidad base con prefijo y la única definida por un objeto físico hasta 2019','El gramo','La tonelada','La libra'], 0, 'Desde 2019 el kg se define con la constante de Planck. El prototipo de platino-iridio en París quedó como reliquia histórica.'),
    qMC('La unidad SI de tiempo:', ['El SEGUNDO (s). Definido por vibraciones del átomo de cesio-133','La hora','El minuto','El día'], 0, '1 segundo = 9,192,631,770 oscilaciones de radiación del cesio-133. Precisión atómica.'),
    qMC('¿Cuál de estos es un MÚLTIPLO correcto en SI?', ['Kilo- = ×1,000','Mili- = ×100','Centi- = ×1,000','Deci- = ×100'], 0, 'Prefijos SI: mega (M)=10⁶, kilo (k)=10³, deci (d)=10⁻¹, centi (c)=10⁻², mili (m)=10⁻³.'),
    qTF('Todos los países del mundo usan obligatoriamente el Sistema Internacional de Unidades.', false, 'La mayoría sí, pero EE.UU., Liberia y Myanmar usan principalmente el sistema imperial (pulgadas, libras, galones).'),
    qOrder('Ordena estos prefijos SI de MAYOR a MENOR:', ['Giga- (10⁹)','Mega- (10⁶)','Kilo- (10³)','Unidad base (10⁰)','Centi- (10⁻²)','Mili- (10⁻³)','Micro- (10⁻⁶)'], 'Cada prefijo = potencia de 10. Así se miden átomos y galaxias con el mismo sistema.'),
    qMatch('Relaciona cada prefijo SI con su factor:', [{left:'Kilo (k)',right:'×1,000 = 10³'},{left:'Centi (c)',right:'×0.01 = 10⁻²'},{left:'Mili (m)',right:'×0.001 = 10⁻³'},{left:'Mega (M)',right:'×1,000,000 = 10⁶'}], 'Los prefijos convierten mediciones enormes o minúsculas en números manejables.'),
    qMC('La VELOCIDAD es una magnitud DERIVADA del SI. Su unidad es:', ['Metro por segundo (m/s), derivada de longitud y tiempo','Kilogramo','Segundo','Metro'], 0, 'm/s combina dos unidades base. mide qué tan rápido cambia la posición.'),
    qWrite('¿Qué factor representa el prefijo nano (n)?', ['10^-9','0.000000001'], 'Nano = mil millonésima (10⁻⁹).'),
    qWrite('¿Qué factor representa el prefijo nano (n)?', ['10^-9','0.000000001'], 'Nano = mil millonésima (10⁻⁹).'),
  ],

  // ===== M87: Conversiones entre sistemas de medida =====
  [
    qMC('1 pulgada = _____ cm:', ['2.54 cm (exacto por definición internacional desde 1959)','5 cm','10 cm','1 cm'], 0, 'Conversión exacta: 1 in = 2.54 cm. Fundamental para construcción y electrónica.'),
    qMC('1 milla terrestre equivale a:', ['1.60934 kilómetros (aproximadamente 1.6 km)','1 km','5 km','10 km'], 0, 'Milla = 1,609.344 m exactos. Usada en EE.UU. y Reino Unido para carreteras.'),
    qMC('1 libra (lb) equivale a:', ['0.4536 kilogramos (≈ 454 gramos)','1 kg','0.1 kg','2 kg'], 0, 'Libra avoirdupois = 453.592 g. Muy usada en gimnasios y recetas.'),
    qMC('1 galón estadounidense equivale a:', ['3.785 litros','1 litro','5 litros','10 litros'], 0, 'Galón USA = 3.785411784 L. Para gasolina en EE.UU.'),
    qMC('1 onza (oz) equivale aproximadamente a:', ['28.35 gramos','1 gramo','100 gramos','10 gramos'], 0, 'Onza avoirdupois. Muy común en joyería, cocina y productos envasados.'),
    qMC('Para convertir °F a °C:', ['°C = (°F - 32) × 5/9','°C = °F + 32','°C = °F × 2','No hay fórmula'], 0, 'Fahrenheit→Celsius: resta 32 y multiplica por 5/9. 100°F ≈ 37.8°C.'),
    qTF('1 kilogramo equivale a 2.2 libras aproximadamente.', true, '1 kg ≈ 2.2046 lb. Conversión muy práctica.'),
    qOrder('Ordena los pasos para convertir 68°F a Celsius:', ['Restar 32: 68-32=36','Multiplicar por 5/9: 36×5÷9=20','Resultado: 20°C (temperatura ambiente agradable)'], 'Conversión de temperatura: la más distinta por tener un punto de origen diferente.'),
    qMatch('Relaciona cada unidad imperial con su equivalente métrico:', [{left:'1 pulgada',right:'2.54 cm'},{left:'1 pie (12 pulgadas)',right:'30.48 cm'},{left:'1 yarda (3 pies)',right:'0.9144 m'},{left:'1 milla',right:'1.609 km'}], 'El sistema imperial tiene sus propias relaciones internas (12 pulg=1 pie, 3 pies=1 yarda).'),
    qMC('Una persona mide 5 pies 9 pulgadas. En metros es aproximadamente:', ['1.75 m (5×30.48 + 9×2.54 = 152.4 + 22.86 = 175.26 cm)','1.80 m','1.70 m','1.60 m'], 0, 'Conversión compuesta: pies a cm + pulgadas a cm, luego a metros.'),
    qWrite('¿1 yarda = cuántos pies?', ['3','tres'], '1 yarda = 3 pies = 36 pulgadas.'),
    qWrite('¿1 yarda = cuántos pies?', ['3','tres'], '1 yarda = 3 pies = 36 pulgadas.'),
  ],

  // ===== M88: Unidades de superficie y volumen en el SI =====
  [
    qMC('1 metro cuadrado (m²) = _____ centímetros cuadrados:', ['10,000 cm² (100×100)','100 cm²','1,000 cm²','10 cm²'], 0, 'Conversión de áreas: factor lineal al CUADRADO. 1m=100cm → 1m²=100²=10,000 cm².'),
    qMC('1 kilómetro cuadrado (km²) = _____ metros cuadrados:', ['1,000,000 m² (1000×1000)','1,000 m²','100 m²','10,000 m²'], 0, 'km²→m²: ×1,000,000. CDMX ≈ 1,485 km².'),
    qMC('¿Cuántos litros caben en 1 metro cúbico?', ['1,000 litros exactos (1 m³ = 1,000 dm³, y 1 dm³=1 L)','100 L','10 L','10,000 L'], 0, 'Relación perfecta: 1 m³ = 1,000 L. Una alberca de 50 m³ = 50,000 litros.'),
    qMC('1 hectárea (ha) =', ['10,000 m² (un cuadrado de 100 m × 100 m)','1,000 m²','100 m²','1 km²'], 0, 'Hectárea: unidad práctica para medir terrenos agrícolas. Campo de fútbol ≈ 0.7 ha.'),
    qMC('1 cm³ (centímetro cúbico) equivale a:', ['1 mililitro (mL). Exactamente la misma cantidad','1 litro','1 m³','Nada'], 0, '1 cm³ ≡ 1 mL. Relación fundamental volumen-capacidad. Jeringa de 5 mL = 5 cm³'),
    qMC('Para convertir 500 cm³ a litros:', ['500 cm³ = 500 mL = 0.5 L','500 L','50 L','5 L'], 0, 'cm³→mL (igual). mL→L (÷1000).'),
    qTF('1 dm³ = 1 litro EXACTAMENTE.', true, 'Decímetro cúbico = litro. Una de las relaciones más hermosas del SI.'),
    qOrder('Ordena estas áreas de menor a mayor:', ['1 cm² (0.0001 m²)','1 m² (cuadrado de 1×1 m)','1 área = 100 m²','1 hectárea = 10,000 m²','1 km² = 1,000,000 m²'], 'Las unidades de superficie crecen al cuadrado de la unidad lineal.'),
    qMatch('Relaciona cada volumen con su equivalencia:', [{left:'1 m³',right:'1,000 litros'},{left:'1 cm³',right:'1 mL'},{left:'1 dm³',right:'1 litro'},{left:'1 mL',right:'1 cm³ = 0.001 L'}], 'El SI conecta elegantemente volumen (m³, cm³) con capacidad (L, mL).'),
    qMC('Un tinaco cilíndrico de 2 m³ almacena:', ['2,000 litros de agua','200 litros','20 litros','2 litros'], 0, '2 m³ × 1,000 L/m³ = 2,000 L. Suficiente para una familia por varios días.'),
    qWrite('¿Cuántos litros hay en 3.5 m³?', ['3500','3,500'], '1 m³ = 1,000 L. 3.5×1,000=3,500 L.'),
    qWrite('¿Cuántos litros hay en 3.5 m³?', ['3500','3,500'], '1 m³ = 1,000 L. 3.5×1,000=3,500 L.'),
  ],

  // ===== M89: Unidades de velocidad y densidad =====
  [
    qMC('La velocidad se define como:', ['Distancia recorrida ÷ Tiempo empleado (v = d/t)','Tiempo × distancia','Distancia + tiempo','Masa × tiempo'], 0, 'v en m/s (SI) o km/h (cotidiano). 1 m/s = 3.6 km/h.'),
    qMC('Convertir 72 km/h a m/s:', ['72 ÷ 3.6 = 20 m/s','72 × 3.6 = 259.2 m/s','72 m/s','72 km'], 0, 'km/h → m/s: divide entre 3.6. m/s → km/h: multiplica por 3.6.'),
    qMC('La densidad se define como:', ['Masa ÷ Volumen (ρ = m/V). Qué tan "compacta" es una sustancia','Velocidad × tiempo','Masa + volumen','Área ÷ altura'], 0, 'Densidad del agua: 1 g/cm³ = 1,000 kg/m³. El oro: 19.3 g/cm³.'),
    qMC('Un objeto de 500 g ocupa 250 cm³. Su densidad es:', ['2 g/cm³ (500÷250)','0.5 g/cm³','5 g/cm³','2 kg/m³'], 0, '¿Flotará en agua? Densidad > 1 g/cm³ → se HUNDE.'),
    qMC('La velocidad del sonido en el aire es ≈ 340 m/s. En km/h:', ['340 × 3.6 = 1,224 km/h','340 km/h','94.4 km/h','3,400 km/h'], 0, 'Mach 1 = velocidad del sonido ≈ 1,224 km/h. Aviones supersónicos superan esta velocidad.'),
    qMC('La densidad del agua de mar es:', ['≈ 1.025 g/cm³ (ligeramente mayor que el agua dulce por la sal)','1 g/cm³','0.5 g/cm³','2 g/cm³'], 0, 'Por eso flotamos más fácil en el mar: mayor densidad empuja más hacia arriba. Principio de Arquímedes.'),
    qTF('Para convertir km/h a m/s, se multiplica por 3.6.', false, 'Es al revés. km/h ÷ 3.6 = m/s. 36 km/h = 10 m/s.'),
    qOrder('Ordena los pasos para calcular la densidad de un cubo de 5 cm de arista y 625 g:', ['Calcular volumen: V=5³=125 cm³','Aplicar fórmula: ρ=m/V=625/125','ρ=5 g/cm³','Comparar con agua: es 5× más denso que el agua'], 'Cálculo de densidad: masa conocida, volumen por geometría, división.'),
    qMatch('Relaciona cada velocidad con su contexto:', [{left:'Persona caminando',right:'≈ 5 km/h = 1.4 m/s'},{left:'Auto en ciudad',right:'≈ 50 km/h ≈ 14 m/s'},{left:'Auto en carretera',right:'≈ 110 km/h ≈ 30.6 m/s'},{left:'Avión comercial',right:'≈ 900 km/h ≈ 250 m/s'}], 'La velocidad contextualiza distancias y tiempos en la vida diaria.'),
    qMC('La velocidad límite en zona escolar (20 km/h) en m/s es:', ['≈ 5.56 m/s (20÷3.6)','20 m/s','72 m/s','2 m/s'], 0, 'Apenas 5.6 m/s. Un niño cruza la calle en segundos. Por eso el límite es bajo.'),
    qWrite('¿Densidad si masa=800 g y volumen=100 cm³?', ['8','8 g/cm³'], '800/100=8 g/cm³.'),
    qWrite('¿Densidad si masa=800 g y vol=100 cm³?', ['8','8 g/cm³'], '800/100=8 g/cm³.'),
  ],

  // ===== M90: Unidades de temperatura =====
  [
    qMC('Las tres escalas de temperatura principales son:', ['Celsius (°C), Fahrenheit (°F), Kelvin (K)','Solo Celsius','Celsius y metros','Fahrenheit y litros'], 0, 'Celsius: agua congela 0°, hierve 100°. Fahrenheit: congela 32°, hierve 212°. Kelvin: escala absoluta.'),
    qMC('El CERO ABSOLUTO (0 K) es:', ['-273.15°C. La temperatura MÍNIMA posible donde cesa todo movimiento molecular','0°C','100°C','-100°C'], 0, 'En 0 K = -273.15°C = -459.67°F. Teóricamente inalcanzable.'),
    qMC('Para convertir Celsius a Kelvin:', ['K = °C + 273.15','K = °C - 273','K = °C × 2','No hay fórmula'], 0, 'Kelvin no usa grados (°), solo K. 25°C = 298.15 K.'),
    qMC('¿A qué temperatura Celsius hierve el agua a nivel del mar?', ['100°C','0°C','212°C','50°C'], 0, '100°C = 212°F = 373.15 K. Dato fundamental.'),
    qMC('La temperatura corporal normal es ≈ 37°C. En Fahrenheit:', ['98.6°F (37×9/5+32)','37°F','100°F','212°F'], 0, '°F = °C × 9/5 + 32. 37 × 9/5 = 66.6 + 32 = 98.6°F.'),
    qMC('La escala KELVIN es la escala del SI. Su ventaja:', ['NO tiene valores negativos (0 K es el mínimo absoluto). Ideal para ciencia','Es más fácil','Es más antigua','No tiene ventaja'], 0, 'Kelvin es la escala termodinámica absoluta. 0 K = cero absoluto.'),
    qTF('En la escala Fahrenheit, el agua hierve a 212°F.', true, 'Correcto. 212°F = 100°C = 373.15 K.'),
    qOrder('Ordena estas temperaturas de la MÁS FRÍA a la MÁS CALIENTE:', ['-10°C (abrigo necesario)','0°C (agua se congela)','20°C (ambiente templado en La Paz BCS)','37°C (cuerpo humano)','100°C (agua hirviendo)'], 'En La Paz BCS, verano puede superar 40°C mientras invierno rara vez baja de 15°C.'),
    qMatch('Relaciona cada temperatura en °C con su equivalente en °F:', [{left:'0°C',right:'32°F (congelación del agua)'},{left:'20°C',right:'68°F (primavera)'},{left:'30°C',right:'86°F (calorcito)'},{left:'40°C',right:'104°F (¡mucho calor en La Paz!)'}], 'Conversión clave: dobla los °C mentalmente y suma 30 como estimación rápida.'),
    qMC('En La Paz BCS, un día de verano típico puede alcanzar 40°C. En Fahrenheit eso es:', ['104°F (40×9/5+32=72+32=104)','40°F','86°F','120°F'], 0, 'Verano en Baja California Sur: temperaturas extremas. Hidratación vital.'),
    qWrite('¿A qué temperatura Celsius congela el agua?', ['0','0°','0 grados'], '0°C = 32°F = 273.15 K.'),
    qWrite('¿A qué °C congela el agua?', ['0','0°','0 grados'], '0°C = 32°F = 273.15 K.'),
  ],

  // ===== M91: Introducción a las finanzas personales =====
  [
    qMC('Un PRESUPUESTO es:', ['Un PLAN que organiza INGRESOS y GASTOS en un período','Solo una lista de gastos','Solo ahorros','No sirve'], 0, 'Presupuesto familiar: ingresos ($10,000) - gastos ($8,000) = ahorro ($2,000).'),
    qMC('La regla 50-30-20 sugiere distribuir el ingreso:', ['Necesidades 50%, Deseos 30%, Ahorro/Deuda 20%','Todo en necesidades','50% ahorro','Todo igual'], 0, 'Guía financiera popular: mitad para lo esencial, 30% para gustos, 20% al futuro.'),
    qMC('Si ganas $8,000 al mes y gastas $6,500, ¿qué porcentaje ahorras?', ['18.75% ((8,000-6,500)/8,000 × 100)','25%','50%','10%'], 0, 'Tasa de ahorro = (Ingreso - Gasto)/Ingreso × 100.'),
    qMC('El ahorro es importante porque:', ['Permite enfrentar emergencias, alcanzar metas y generar tranquilidad financiera','No es importante','Solo para ricos','Es aburrido'], 0, 'Fondo de emergencia ideal: 3-6 meses de gastos básicos.'),
    qMC('Una necesidad vs un deseo:', ['Necesidad: comida, vivienda, salud. Deseo: cine, ropa de marca, nuevo celular','Son lo mismo','No hay diferencia','Todo es necesidad'], 0, 'Distinguir necesidades de deseos = base de finanzas sanas.'),
    qMC('Si ahorras $200/mes durante 1 año, al final tendrás:', ['$2,400 (sin intereses)','$200','$2,000','$1,200'], 0, 'Ahorro constante crece. Si además gana intereses, crece más.'),
    qTF('Tener un presupuesto es solo para personas con mucho dinero.', false, '¡Al contrario! Quien tiene menos necesita MÁS organizar sus finanzas. El presupuesto es para TODOS.'),
    qOrder('Ordena los pasos para crear un presupuesto mensual:', ['Anotar TODOS los ingresos','Listar gastos FIJOS (renta, servicios)','Listar gastos VARIABLES (comida, transporte)','Calcular diferencia: ingresos - gastos','Asignar el excedente a AHORRO o metas'], 'Presupuesto = foto financiera personal. El primer paso hacia la libertad económica.'),
    qMatch('Relaciona cada concepto financiero con su definición:', [{left:'Ingreso',right:'Dinero que recibes (sueldo, mesada)'},{left:'Gasto fijo',right:'Pago constante cada mes (renta, internet)'},{left:'Gasto variable',right:'Cambia cada mes (comida, gasolina)'},{left:'Ahorro',right:'Dinero guardado para el futuro'}], 'Conceptos financieros básicos que todos necesitamos dominar.'),
    qMC('Si tus gastos superan tus ingresos, tienes:', ['DÉFICIT (estás gastando más de lo que ganas, peligroso)','Superávit','Equilibrio','Es normal'], 0, 'Déficit continuo = deuda creciente. Hay que reducir gastos o aumentar ingresos.'),
    qWrite('Ingresos $9,500, gastos $7,600. Ahorro mensual:', ['1900','$1,900'], '9,500-7,600=1,900.'),
    qWrite('Ingresos $9500, gastos $7600. Ahorro mensual:', ['1900','$1,900'], '9500-7600=1900.'),
  ],

  // ===== M92: Interés simple =====
  [
    qMC('El interés SIMPLE se calcula:', ['I = C × i × t (Capital × tasa × tiempo). Interés fijo sobre el capital original','Sobre intereses acumulados','No existe','Aleatorio'], 0, 'Fórmula clásica. Si prestas $1,000 al 10% anual por 3 años: I = 1000×0.10×3 = $300.'),
    qMC('Si inviertes $5,000 al 8% de interés simple anual, en 2 años ganas:', ['$800 (5,000×0.08×2)','$400','$5,400','$5,800'], 0, 'Interés = 5,000×0.08×2=800. Monto final = 5,800.'),
    qMC('El CAPITAL en finanzas es:', ['La cantidad INICIAL de dinero invertido o prestado','El interés','El tiempo','El banco'], 0, 'Capital (C o P = Principal) = dinero original antes de intereses.'),
    qMC('La tasa de interés (i) se expresa:', ['Como PORCENTAJE anual (10% = 0.10 en la fórmula). Siempre en decimal','En pesos','En horas','En metros'], 0, '10% anual = 0.10. 5% mensual = 0.05. Asegúrate de que tiempo y tasa usen la misma unidad.'),
    qMC('Interés simple: $2,000 al 5% anual por 4 años =', ['$400 de interés (2,000×0.05×4). Total: $2,400','$200','$100','$2,500'], 0, 'Interés simple NO reinvierte los intereses ganados. Cada año se calcula sobre el capital original.'),
    qMC('La ventaja del interés simple es:', ['Es FÁCIL de calcular y entender. Útil para préstamos a corto plazo','Nunca se usa','Es más caro','No tiene ventaja'], 0, 'Préstamos personales, pagarés, CETES: frecuentemente usan interés simple.'),
    qTF('En interés simple, los intereses se calculan siempre sobre el capital ORIGINAL, nunca sobre intereses previos.', true, 'Definición: interés simple = no hay "interés sobre interés".'),
    qOrder('Ordena los pasos para calcular cuánto pagarás en total por un préstamo de $3,000 al 12% anual simple a 2 años:', ['Identificar: C=3,000, i=12%=0.12, t=2','Calcular interés: I=3,000×0.12×2=720','Sumar capital más interés: Monto=3,000+720=3,720','Pagarás $3,720 en total'], 'Cálculo simple: interés y monto total para decisiones financieras informadas.'),
    qMatch('Relaciona cada préstamo con el interés a pagar:', [{left:'$1,000, 10%, 1 año',right:'$100'},{left:'$2,000, 5%, 3 años',right:'$300'},{left:'$500, 20% anual, 2 años',right:'$200'},{left:'$4,000, 7.5%, 2 años',right:'$600'}], 'El interés representa el "costo del dinero prestado" o "premio por ahorrar".'),
    qMC('Pedro ahorra $10,000 en un pagaré al 6% anual simple. ¿Cuánto tiene en 5 años?', ['$13,000 (10,000 + 10,000×0.06×5)','$10,600','$16,000','$13,382'], 0, 'Interés=10,000×0.06×5=3,000. Total=13,000. Así crecen ahorros con interés simple.'),
    qWrite('Interés simple: $6,000 al 4% por 5 años. ¿Interés?', ['1200','$1,200'], '6000×0.04×5=1200.'),
    qWrite('Interés simple: $6000 al 4% por 5 años. ¿Interés?', ['1200','$1,200'], '6000×0.04×5=1200.'),
  ],

  // ===== M93: Interés compuesto =====
  [
    qMC('El interés COMPUESTO se diferencia del simple en:', ['Los intereses ganados se REINVIERTEN y generan MÁS intereses ("interés sobre interés")','Es más fácil','Es igual','No existe'], 0, 'Efecto "bola de nieve": cada período los intereses se suman al capital para el siguiente.'),
    qMC('Fórmula del monto con interés compuesto:', ['M = C(1 + i)ⁿ. Donde n = número de períodos','M = C + i×t','M = C×i','No existe'], 0, 'Ej: $1,000 al 10% compuesto anual por 3 años = 1,000×(1.10)³ = 1,000×1.331 = $1,331.'),
    qMC('$2,000 al 10% anual compuesto por 2 años:', ['$2,420 (Año 1: 2,000×1.1=2,200. Año 2: 2,200×1.1=2,420, comprobando: 2000(1.1)²=2420)','$2,400','$2,200','$2,500'], 0, 'Compara: interés simple daría $2,400. El compuesto da $2,420. $20 más por "interés sobre interés".'),
    qMC('A largo plazo, el interés compuesto supera al simple por MUCHO. $10,000 al 8% por 30 años:', ['Compuesto ≈ $100,627. Simple = $34,000. ¡Diferencia abismal!','Son casi iguales','Simple da más','No hay diferencia'], 0, 'Einstein llamó al interés compuesto "la octava maravilla del mundo". El tiempo es el factor mágico.'),
    qMC('La REGLA DEL 72 estima:', ['¿En cuántos años se DUPLICA el dinero? Años ≈ 72 ÷ tasa de interés','Nada útil','Solo para expertos','No funciona'], 0, 'Al 8% anual: 72÷8=9 años para duplicar. Al 12%: 72÷12=6 años.'),
    qMC('Si inviertes $5,000 al 5% compuesto ANUAL, en 10 años tendrás aproximadamente:', ['$8,144 (5,000×(1.05)¹⁰)','$7,500','$5,500','$10,000'], 0, 'Crecimiento compuesto: no lineal. Los primeros años parece lento, luego acelera.'),
    qTF('El interés compuesto genera MENOS ganancia que el interés simple.', false, 'Para períodos >1, el compuesto SIEMPRE da más (o igual si n=1).'),
    qOrder('Ordena los pasos para calcular el monto de $3,000 al 6% compuesto anual por 5 años:', ['Calcular (1+i)ⁿ: (1.06)⁵ ≈ 1.3382','Multiplicar por capital: 3,000×1.3382≈4,014.68','Monto total ≈ $4,014.68','Interés ganado = 4,014.68-3,000=$1,014.68'], 'La magia del interés compuesto: el factor (1+i)ⁿ crece exponencialmente.'),
    qMatch('Relaciona la inversión con su crecimiento compuesto estimado:', [{left:'$1,000, 10%, 10 años',right:'≈ $2,594 (1.1¹⁰≈2.594)'},{left:'$5,000, 7%, 5 años',right:'≈ $7,013'},{left:'$2,000, 5%, 20 años',right:'≈ $5,307'},{left:'$500, 12%, 15 años',right:'≈ $2,737'}], 'Pequeñas diferencias en tasa o tiempo producen grandes diferencias en el resultado.'),
    qMC('La CLAVE del interés compuesto para jóvenes:', ['EMPEZAR TEMPRANO. El tiempo es el mayor aliado. Incluso cantidades pequeñas crecen mucho','Esperar a tener mucho dinero','No ahorrar','Invertir al final'], 0, 'Quien empieza a ahorrar a los 20 vs 30, incluso con menos dinero, puede terminar con más.'),
    qWrite('Regla del 72: ¿en cuántos años se duplica al 6%?', ['12'], '72÷6=12 años.'),
    qWrite('Regla del 72: ¿en cuántos años se duplica al 6%?', ['12'], '72÷6=12 años.'),
  ],

  // ===== M94: Descuentos e IVA en compras =====
  [
    qMC('Para calcular el precio CON IVA (16%):', ['Precio × 1.16 (aumentar el 16%)','Precio × 0.16','Precio - 0.16','Precio/0.16'], 0, 'Multiplicar por 1.16 agrega el 16% del IVA al precio original. $100 × 1.16 = $116.'),
    qMC('Un artículo de $850 con 20% de descuento:', ['$850 × 0.80 = $680 (pagas el 80% del precio)','$850 × 0.20 = $170','$850 + 20 = $870','$850 - 20 = $830'], 0, 'Si descuentan 20%, PAGAS 80%. Precio final = precio × (1 - %descuento/100).'),
    qMC('Para calcular el precio SIN IVA a partir del precio total:', ['Total ÷ 1.16 (si el IVA es 16%)','Total × 0.16','Total - 16','No se puede'], 0, 'Si pagaste $1,160 con IVA, el precio sin IVA = $1,160/1.16 = $1,000.'),
    qMC('Dos descuentos SUCESIVOS del 10% y 20%:', ['NO suman 30%. Aplica el primer descuento y luego el segundo sobre el nuevo precio','Suman 30% directamente','No se pueden combinar','Son lo mismo'], 0, 'Si parto de $100: -10%=$90, -20% sobre $90=$72. Descuento real=28%, no 30%.'),
    qMC('¿Cuál es mejor: 30% de descuento directo o 20% + 10% sucesivos?', ['30% directo (deja en $70). Sucesivo deja en $72. Directo es mejor','Sucesivo','Son iguales','Depende'], 0, 'Descuentos sucesivos siempre rinden MENOS que la suma directa porque el segundo aplica sobre una base menor.'),
    qMC('Una licuadora cuesta $1,200 sin IVA. Precio final en México:', ['$1,392 (1,200 × 1.16)','$1,200','$1,360','$1,160'], 0, 'IVA 16% = $1,200 × 0.16 = $192. Total = $1,200+$192=$1,392.'),
    qTF('Si compras algo con 50%+50% de descuento sucesivo, es GRATIS.', false, '50% de $100 = $50. Otro 50% sobre $50 = $25. NO es gratis, cuesta $25.'),
    qOrder('Ordena los pasos para calcular precio final de $2,000 con 15% de descuento más IVA 16%:', ['Primero el descuento: 2,000×0.85=$1,700','Luego el IVA: 1,700×1.16=$1,972','Precio final: $1,972'], 'El orden importa: ¿primero IVA o primero descuento? Normalmente: descuento sobre precio de lista SIN IVA, luego agregas IVA.'),
    qMatch('Relaciona cada operación con su precio final:', [{left:'$500 + IVA 16%',right:'$580'},{left:'$800 - 25% descuento',right:'$600'},{left:'$1,000 sin IVA (calcular IVA)',right:'$1,160 con IVA'},{left:'$1,500 - 30%',right:'$1,050'}], 'Cálculos cotidianos en el súper, tiendas departamentales y facturas.'),
    qMC('En "El Buen Fin", un TV de $15,000 tiene 40% de descuento. Precio:', ['$9,000 (15,000 × 0.60)','$6,000','$15,000','$12,000'], 0, 'Descuento del 40% → se paga 60%. 15,000 × 0.60 = $9,000. Descuento real = $6,000.'),
    qWrite('Precio original $2,000 con 35% descuento. ¿Precio final?', ['1300','$1,300'], '2,000×0.65=1,300.'),
