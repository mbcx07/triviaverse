  // ===== M76: Introducción al álgebra - Variables =====
  [
    qMC('En álgebra, una VARIABLE es:', ['Un SÍMBOLO (letra) que representa un VALOR DESCONOCIDO o variable','Un número fijo','Solo la letra x','Un triángulo'], 0, 'En "x + 5 = 12", x es la variable que debemos encontrar. x = 7.'),
    qMC('La expresión "3n" significa:', ['3 MULTIPLICADO por n. Tres veces el valor de n','3 + n','n³','3-n'], 0, 'En álgebra, pegar número y letra = MULTIPLICACIÓN. 5x = 5×x.'),
    qMC('Traduce "un número aumentado en 8" a álgebra:', ['x + 8','8x','x - 8','x/8'], 0, 'Aumentado = suma. Disminuido = resta. Del lenguaje común al algebraico.'),
    qMC('"El doble de un número" es:', ['2n','n²','n+2','n/2'], 0, 'Doble = ×2. Triple = ×3. Mitad = ÷2 = n/2.'),
    qMC('¿Cuánto vale x si 5 + x = 13?', ['x = 8 (13 - 5)','x = 18','x = 5','x = 2.6'], 0, 'Despejar: x = 13 - 5 = 8. Verifica: 5+8=13 ✓.'),
    qMC('Si 3y = 18, entonces y es:', ['6 (divide ambos lados entre 3: y=6)','3','9','54'], 0, 'Operación inversa: 3×y=18 → y=18÷3=6.'),
    qTF('Una variable puede representar CUALQUIER número.', false, 'No cualquier número, sino aquel que SATISFACE la ecuación. En x+3=7, x DEBE ser 4.'),
    qOrder('Ordena los pasos para plantear "La suma de un número y su doble es 15":', ['Definir variable: número = x','El doble del número = 2x','Plantear ecuación: x + 2x = 15','Resolver: 3x = 15, x = 5','Verificar: 5 + 10 = 15 ✓'], 'Traducción lenguaje natural → álgebra: habilidad que abre todo un mundo matemático.'),
    qMatch('Relaciona cada frase con su expresión algebraica:', [{left:'Un número más 7',right:'x + 7'},{left:'El triple de un número',right:'3x'},{left:'Un número menos 4',right:'x - 4'},{left:'La mitad de un número',right:'x/2'}], 'El álgebra es un LENGUAJE que traduce situaciones a símbolos.'),
    qMC('"El producto de un número y 9" es:', ['9x','x + 9','x/9','9 + x'], 0, 'Producto = multiplicación. Cociente = división.'),
    qWrite('Traduce: un número menos el doble de otro.', ['x-2y','x − 2y'], 'Lenguaje algebraico: x - 2y.'),
    qWrite('Traduce: un número menos el doble de otro.', ['x-2y','x - 2y'], 'Lenguaje algebraico: x - 2y.'),
  ],

  // ===== M77: Ecuaciones de primer grado (suma/resta) =====
  [
    qMC('Una ECUACIÓN es:', ['Una IGUALDAD entre dos expresiones que contienen al menos una variable','Un número','Una operación','Un dibujo'], 0, 'x + 5 = 12. Hay igualdad y una incógnita. Resolver = encontrar el valor de x.'),
    qMC('Para resolver x + 9 = 15:', ['Restar 9 en AMBOS lados: x = 6','Sumar 9','Multiplicar','Dividir'], 0, 'Operación INVERSAS en ambos lados para mantener la igualdad. 15-9=6.'),
    qMC('En x - 7 = 12, la x vale:', ['19 (sumar 7 a ambos: x = 12 + 7)','5','-5','84'], 0, 'Sumas 7 (operación inversa de restar) para despejar x.'),
    qMC('Resolver 32 = x + 18:', ['x = 14 (32 - 18)','x = 50','x = 32','x = 18'], 0, 'Incógnita a la derecha: igual de válido. 32-18=14.'),
    qMC('Una BALANZA con objetos representa:', ['Una ECUACIÓN (igual peso = igualdad). Quitar/agregar peso = operaciones algebraicas','Solo pesos','Nada matemático','Solo dibujo'], 0, 'Analogía perfecta: el equilibrio de ambos platillos simboliza la IGUALDAD de la ecuación.'),
    qMC('Si x + 25 = 100, ¿cuánto vale x?', ['x = 75','x = 125','x = 4','x = 25'], 0, '100 - 25 = 75. Problema tipo ahorro: ¿cuánto me falta para llegar a 100?'),
    qTF('Para despejar x en x + a = b, resto a en ambos lados: x = b - a.', true, 'Regla fundamental: operación INVERSA aplicada a AMBOS lados.'),
    qOrder('Ordena los pasos para resolver 15 + x = 42:', ['Identificar operación: suma','Operación inversa: resta','Restar 15 en ambos lados: x = 42 - 15','Calcular: x = 27','Verificar: 15 + 27 = 42 ✓'], 'Método sistemático de resolución.'),
    qMatch('Relaciona cada ecuación con su solución:', [{left:'x + 8 = 20',right:'x = 12'},{left:'x - 5 = 11',right:'x = 16'},{left:'25 = x + 10',right:'x = 15'},{left:'x - 13 = 0',right:'x = 13'}], 'Practica el despeje con los dos tipos: suma y resta.'),
    qMC('María tiene cierta cantidad de estampas. Compra 8 más y ahora tiene 25. Plantea:', ['x + 8 = 25 → x = 17 estampas','x - 8 = 25','8x = 25','x/8 = 25'], 0, 'Problema contextualizado: traducción a ecuación y resolución.'),
    qWrite('Resuelve: x + 23 = 50. ¿x?', ['27'], '50-23=27.'),
    qWrite('Resuelve: x + 23 = 50. ¿x?', ['27'], '50-23=27.'),
  ],

