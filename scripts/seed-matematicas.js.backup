    qMatch('Relaciona cada ecuación con su solución:', [{left:'2x = 18',right:'x = 9'},{left:'x/4 = 5',right:'x = 20'},{left:'7x = 56',right:'x = 8'},{left:'x/10 = 3',right:'x = 30'}], 'Dominar ambos tipos: multiplicación y división en ecuaciones.'),
